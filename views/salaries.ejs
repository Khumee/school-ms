<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-wallet2"></i> Staff Salaries & Payroll Ledger</h1>
</div>

<div class="form-grid" style="grid-template-columns: 1fr 2fr; gap: 1.5rem; margin-bottom: 2rem;">
    <!-- Form to execute Payout -->
    <div class="card">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);">Issue Salary Payout</h3>
        <form action="/salaries/pay" method="POST">
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="employee_id">Select Employee *</label>
                <select name="employee_id" id="employee_id" class="form-control" required onchange="setSalaryDefault()">
                    <option value="">-- Select Employee --</option>
                    <% employees.forEach(e => { %>
                        <option value="<%= e.id %>" data-salary="<%= e.default_salary %>"><%= e.name %> (<%= e.designation %>)</option>
                    <% }) %>
                </select>
            </div>
            
            <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                    <label for="basic_salary">Basic Salary *</label>
                    <input type="number" step="0.01" id="basic_salary" name="basic_salary" class="form-control" required placeholder="0.00">
                </div>
                
                <div class="form-group">
                    <label for="paid_date">Paid Date</label>
                    <input type="date" id="paid_date" name="paid_date" class="form-control">
                </div>
            </div>
            
            <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                    <label for="month">For Month *</label>
                    <select name="month" id="month" class="form-control" required>
                        <% const monthsList = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']; %>
                        <% monthsList.forEach((m, idx) => { %>
                            <option value="<%= idx + 1 %>" <%= new Date().getMonth() === idx ? 'selected' : '' %>><%= m %></option>
                        <% }) %>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="year">For Year *</label>
                    <input type="number" id="year" name="year" class="form-control" required value="2026">
                </div>
            </div>
            
            <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                <div class="form-group">
                    <label for="bonus">Bonus / Eid Bonus</label>
                    <input type="number" step="0.01" id="bonus" name="bonus" class="form-control" placeholder="0.00" value="0.00">
                </div>
                
                <div class="form-group">
                    <label for="bonus_description">Bonus Description</label>
                    <input type="text" id="bonus_description" name="bonus_description" class="form-control" placeholder="e.g. Eid ul Fitr">
                </div>
            </div>
            
            <button type="submit" class="btn-primary" style="width: 100%;">Record Payment</button>
        </form>
    </div>
    
    <!-- Table list -->
    <div class="card">
        <h3 style="margin-bottom: 1rem;">Payroll Transactions Log (2026)</h3>
        
        <div class="table-container" style="border: none; max-height: 420px; overflow-y: auto;">
            <table>
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Month/Year</th>
                        <th style="text-align: right;">Basic (PKR)</th>
                        <th style="text-align: right;">Bonus (PKR)</th>
                        <th>Bonus Details</th>
                        <th style="text-align: right; background-color: #f1f5f9;">Total Paid</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (salaries.length > 0) { %>
                        <% salaries.forEach(s => { %>
                            <tr>
                                <td style="font-weight: 600;"><%= s.employee_name %><br><span style="font-size: 0.75rem; color: #64748b; font-weight: 400;"><%= s.designation %></span></td>
                                <td><%= monthsList[s.month - 1] %> <%= s.year %></td>
                                <td style="text-align: right;"><%= s.basic_salary.toLocaleString() %></td>
                                <td style="text-align: right; color: <%= s.bonus > 0 ? '#16a34a' : '#64748b' %>">
                                    <%= s.bonus > 0 ? s.bonus.toLocaleString() : '-' %>
                                </td>
                                <td><%= s.bonus_description || '-' %></td>
                                <td style="text-align: right; font-weight: 700; background-color: #f8fafc;">
                                    <%= (parseFloat(s.basic_salary) + parseFloat(s.bonus)).toLocaleString() %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" style="text-align: center; color: #64748b;">No payroll payments logged.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function setSalaryDefault() {
        const select = document.getElementById('employee_id');
        const selectedOption = select.options[select.selectedIndex];
        const salaryVal = selectedOption.getAttribute('data-salary');
        if (salaryVal) {
            document.getElementById('basic_salary').value = parseFloat(salaryVal);
        } else {
            document.getElementById('basic_salary').value = '0.00';
        }
    }
</script>

<%- include('partials/footer') %>
