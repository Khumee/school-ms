<%- include('partials/header') %>

<% const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December']; %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-person-vcard-fill"></i> <%= student.name %></h1>
    <div style="display: flex; gap: 0.5rem;">
        <a href="/students/edit/<%= student.id %>" class="btn-secondary"><i class="bi bi-pencil-square"></i> Edit</a>
        <a href="/students" class="btn-secondary"><i class="bi bi-arrow-left"></i> Back to Directory</a>
    </div>
</div>

<div class="kpi-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 1.5rem;">
    <div class="card kpi-card">
        <span class="kpi-icon blue"><i class="bi bi-credit-card-2-front-fill"></i></span>
        <span class="kpi-label">Registration No.</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= student.reg_no %></span>
    </div>
    <div class="card kpi-card">
        <span class="kpi-icon purple"><i class="bi bi-mortarboard-fill"></i></span>
        <span class="kpi-label">Class</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= student.class_name || 'Unassigned' %></span>
    </div>
    <div class="card kpi-card">
        <span class="kpi-icon amber"><i class="bi bi-tags-fill"></i></span>
        <span class="kpi-label">Monthly Fee (Net)</span>
        <span class="kpi-value" style="font-size: 1.4rem;">
            <% if (student.is_hifz_class) { %>
                PKR 0 (Hifz)
            <% } else { %>
                PKR <%= (parseFloat(student.default_monthly_fee || 0) - parseFloat(student.custom_monthly_fee || 0)).toLocaleString() %>
            <% } %>
        </span>
        <span class="kpi-subtitle">
            <% if (student.is_hifz_class) { %>
                Hifz Student
            <% } else { %>
                <%= student.has_concession ? 'Concessional Rate' : 'Standard Rate' %>
            <% } %>
        </span>
    </div>
    <div class="card kpi-card">
        <span class="kpi-icon green"><i class="bi bi-cash-stack"></i></span>
        <span class="kpi-label">Total Fees Paid (2026)</span>
        <span class="kpi-value" style="font-size: 1.4rem;">PKR <%= totalPaid.toLocaleString() %></span>
    </div>
</div>

<div class="form-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); margin-bottom: 2rem;">
    <div class="card">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);"><i class="bi bi-person-lines-fill"></i> Admission & Demographic Details</h3>
        <table class="details-table" style="width: 100%; font-size: 0.875rem;">
            <tr><td style="font-weight: 600; padding: 6px 0; width: 45%;">Date of Admission</td><td style="padding: 6px 0;"><%= student.date_of_admission ? new Date(student.date_of_admission).toLocaleDateString() : '-' %></td></tr>
            <tr><td style="font-weight: 600; padding: 6px 0;">Date of Birth</td><td style="padding: 6px 0;"><%= student.date_of_birth ? new Date(student.date_of_birth).toLocaleDateString() : '-' %></td></tr>
            <tr><td style="font-weight: 600; padding: 6px 0;">Gender</td><td style="padding: 6px 0; text-transform: capitalize;"><%= student.gender || '-' %></td></tr>
            <tr><td style="font-weight: 600; padding: 6px 0;">Status</td><td style="padding: 6px 0; text-transform: capitalize;"><%= student.status %></td></tr>
            <tr><td style="font-weight: 600; padding: 6px 0;">Father's Name</td><td style="padding: 6px 0;"><%= student.father_name || '-' %></td></tr>
            <tr><td style="font-weight: 600; padding: 6px 0;">Father's Phone</td><td style="padding: 6px 0;"><%= student.father_phone || '-' %></td></tr>
            <tr><td style="font-weight: 600; padding: 6px 0;">Emergency Contact</td><td style="padding: 6px 0;"><%= student.emergency_contact || '-' %></td></tr>
            <tr><td style="font-weight: 600; padding: 6px 0;">Address</td><td style="padding: 6px 0;"><%= student.address || '-' %></td></tr>
            <tr><td style="font-weight: 600; padding: 6px 0;">Blood Group</td><td style="padding: 6px 0;"><%= student.blood_group || '-' %></td></tr>
            <tr><td style="font-weight: 600; padding: 6px 0;">Previous School</td><td style="padding: 6px 0;"><%= student.previous_school_info || '-' %></td></tr>
        </table>
    </div>

    <div class="card">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);"><i class="bi bi-tags-fill"></i> Fee Concession Details</h3>
        <table class="details-table" style="width: 100%; font-size: 0.875rem;">
            <% if (student.is_hifz_class) { %>
                <tr><td style="font-weight: 600; padding: 6px 0; width: 45%;">Class Standard Fee</td><td style="padding: 6px 0;">PKR 0 (Hifz Class)</td></tr>
                <tr><td style="font-weight: 600; padding: 6px 0;">Concession Amount</td><td style="padding: 6px 0;">-</td></tr>
                <tr><td style="font-weight: 600; padding: 6px 0;">Net Monthly Fee</td><td style="padding: 6px 0;">PKR 0</td></tr>
                <tr><td style="font-weight: 600; padding: 6px 0;">Has Concession</td><td style="padding: 6px 0;">N/A (Hifz)</td></tr>
                <tr><td style="font-weight: 600; padding: 6px 0;">Notes</td><td style="padding: 6px 0;">Hifz student exemption</td></tr>
            <% } else { %>
                <tr><td style="font-weight: 600; padding: 6px 0; width: 45%;">Class Standard Fee</td><td style="padding: 6px 0;">PKR <%= (student.default_monthly_fee || 0).toLocaleString() %></td></tr>
                <tr><td style="font-weight: 600; padding: 6px 0;">Concession Amount</td><td style="padding: 6px 0;">PKR <%= parseFloat(student.custom_monthly_fee || 0).toLocaleString() %></td></tr>
                <tr><td style="font-weight: 600; padding: 6px 0;">Net Monthly Fee</td><td style="padding: 6px 0;">PKR <%= (parseFloat(student.default_monthly_fee || 0) - parseFloat(student.custom_monthly_fee || 0)).toLocaleString() %></td></tr>
                <tr><td style="font-weight: 600; padding: 6px 0;">Has Concession</td><td style="padding: 6px 0;"><%= student.has_concession ? 'Yes' : 'No' %></td></tr>
                <tr><td style="font-weight: 600; padding: 6px 0;">Notes</td><td style="padding: 6px 0;"><%= student.concession_notes || '-' %></td></tr>
            <% } %>
        </table>
    </div>

    <div class="card">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);"><i class="bi bi-cash-stack"></i> Admission Fee Details</h3>
        <table class="details-table" style="width: 100%; font-size: 0.875rem; margin-bottom: 1rem;">
            <tr>
                <td style="font-weight: 600; padding: 6px 0; width: 45%;">Admission Fee</td>
                <td style="padding: 6px 0; font-weight: 600;">PKR <%= (student.admission_fee || 0).toLocaleString() %></td>
            </tr>
            <tr>
                <td style="font-weight: 600; padding: 6px 0;">Status</td>
                <td style="padding: 6px 0;">
                    <% if (student.admission_fee_status === 'paid') { %>
                        <span class="status-cell status-paid" style="background-color: #f0fdf4; color: #16a34a; padding: 2px 8px; border-radius: 4px; font-weight: 600;"><i class="bi bi-check-circle-fill"></i> PAID</span>
                    <% } else if (student.admission_fee_status === 'waived') { %>
                        <span class="status-cell" style="background-color: #f1f5f9; color: #475569; padding: 2px 8px; border-radius: 4px; font-weight: 600;"><i class="bi bi-slash-circle-fill"></i> WAIVED</span>
                    <% } else { %>
                        <span class="status-cell status-unpaid" style="background-color: #fef2f2; color: #dc2626; padding: 2px 8px; border-radius: 4px; font-weight: 600;"><i class="bi bi-exclamation-triangle-fill"></i> UNPAID</span>
                    <% } %>
                </td>
            </tr>
            <% if (student.admission_fee_status === 'paid' && student.admission_fee_payment_date) { %>
                <tr>
                    <td style="font-weight: 600; padding: 6px 0;">Payment Date</td>
                    <td style="padding: 6px 0;"><%= new Date(student.admission_fee_payment_date).toLocaleDateString() %></td>
                </tr>
            <% } %>
        </table>
        
        <% if (student.admission_fee_status !== 'paid') { %>
            <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                <form action="/students/update-admission-fee/<%= student.id %>" method="POST" style="margin: 0; display: inline-block; width: 100%;">
                    <input type="hidden" name="status" value="paid">
                    <button type="submit" class="btn-primary" style="width: 100%; font-size: 0.8rem; padding: 0.4rem 0.2rem;"><i class="bi bi-credit-card-fill"></i> Mark as Paid</button>
                </form>
                <% if (student.admission_fee_status !== 'waived') { %>
                    <form action="/students/update-admission-fee/<%= student.id %>" method="POST" style="margin: 0; display: inline-block; width: 100%;">
                        <input type="hidden" name="status" value="waived">
                        <button type="submit" class="btn-secondary" style="width: 100%; font-size: 0.8rem; padding: 0.4rem 0.2rem;"><i class="bi bi-slash-circle"></i> Waive Fee</button>
                    </form>
                <% } %>
            </div>
        <% } %>
    </div>
</div>

<% if (hifzEnrollment) { %>
<div class="card" style="margin-bottom: 2rem; border-left: 4px solid var(--primary-color);">
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.75rem; margin-bottom: 1rem;">
        <h3 style="margin: 0; color: var(--primary-color);"><i class="bi bi-book"></i> Hifz Memorization Status</h3>
        <a href="/hifz/student/<%= student.id %>" class="btn-primary" style="padding: 0.25rem 0.75rem; font-size: 0.85rem;"><i class="bi bi-eye"></i> View Hifz Profile</a>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; font-size: 0.9rem;">
        <div>
            <span style="color: #64748b; font-size: 0.8rem; display: block; text-transform: uppercase;">Current Para</span>
            <strong style="font-size: 1.1rem; color: #1e3a8a;">Para <%= hifzEnrollment.current_para || 'None' %></strong>
        </div>
        <div>
            <span style="color: #64748b; font-size: 0.8rem; display: block; text-transform: uppercase;">Phase</span>
            <strong style="font-size: 1.1rem; text-transform: capitalize;"><%= hifzEnrollment.current_phase.replace(/_/g, ' ') %></strong>
        </div>
        <div>
            <span style="color: #64748b; font-size: 0.8rem; display: block; text-transform: uppercase;">Total Lines Memorized</span>
            <strong style="font-size: 1.1rem;"><%= hifzEnrollment.total_lines_memorized %> lines</strong>
        </div>
    </div>
</div>
<% } %>

<div class="section-header">
    <h2 class="section-title"><i class="bi bi-clock-history"></i> Fee Payment History</h2>
</div>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Month</th>
                <th>Year</th>
                <th style="text-align: right;">Amount Paid (PKR)</th>
                <th>Payment Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            <% if (payments.length > 0) { %>
                <% payments.forEach(p => { %>
                    <tr>
                        <td style="font-weight: 600;">
                            <%= p.month === 0 ? 'Admission Fee' : monthNames[p.month - 1] %>
                        </td>
                        <td><%= p.year %></td>
                        <td style="text-align: right; font-weight: 600; color: #15803d;">PKR <%= parseFloat(p.amount_paid).toLocaleString() %></td>
                        <td><%= new Date(p.payment_date).toLocaleDateString() %></td>
                        <td>
                            <div style="display: flex; gap: 0.4rem; justify-content: flex-end;">
                                <% if (p.month > 0) { %>
                                    <a href="/fees/receipt/<%= p.id %>" class="btn-secondary nav-btn" target="_blank" title="Print PDF Receipt"><i class="bi bi-printer-fill"></i> Receipt</a>
                                <% } %>
                                <button type="button" class="btn-secondary nav-btn" onclick="openPaymentModal('<%= student.id %>', '<%= student.name %>', <%= p.month %>, <%= p.year %>, <%= p.amount_paid %>, <%= p.fine_amount || 0 %>, <%= p.fine_waived || 0 %>, <%= p.additional_fee || 0 %>, '<%= p.additional_fee_description || '' %>', '<%= new Date(p.payment_date).toISOString().substring(0, 10) %>')"><i class="bi bi-pencil-fill"></i> Edit</button>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="5" style="text-align: center; color: #64748b;">No fee payments recorded yet.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<!-- Payment Modal -->
<div id="paymentModal" class="card" style="display: none; max-width: 400px; margin: 1rem auto; position: fixed; top: 20%; left: 50%; transform: translate(-50%, 0); z-index: 1000; box-shadow: 0 10px 25px rgba(0,0,0,0.2); box-sizing: border-box; width: 90%;">
    <h3 style="margin-bottom: 1rem;" id="modalTitle">Record Payment</h3>
    <form action="/fees/pay" method="POST">
        <input type="hidden" id="modalStudentId" name="student_id">
        <input type="hidden" id="modalMonth" name="month">
        <input type="hidden" id="modalYear" name="year">
        <input type="hidden" name="redirect_url" value="/students/view/<%= student.id %>">
        
        <div class="form-group" style="margin-bottom: 1.25rem;">
            <label for="modalAmount">Amount Paid (PKR)</label>
            <input type="number" step="0.01" id="modalAmount" name="amount" class="form-control" required>
        </div>

        <div class="form-group" style="margin-bottom: 1.25rem;">
            <label for="modalPaymentDate">Payment Date</label>
            <input type="date" id="modalPaymentDate" name="payment_date" class="form-control" required>
        </div>

        <div id="monthlyFeeExtraFields">
            <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1.25rem;">
                <div class="form-group">
                    <label for="modalAdditionalFee">Additional Fee (PKR)</label>
                    <input type="number" step="0.01" id="modalAdditionalFee" name="additional_fee" class="form-control" value="0">
                </div>
                
                <div class="form-group">
                    <label for="modalAdditionalFeeDesc">Fee Description</label>
                    <input type="text" id="modalAdditionalFeeDesc" name="additional_fee_description" class="form-control" placeholder="e.g. Exam fee">
                </div>
            </div>
            
            <div class="form-group" style="margin-bottom: 1.25rem;">
                <label for="modalFine">Late Fee Fine (PKR)</label>
                <input type="number" step="0.01" id="modalFine" name="fine_amount" class="form-control" value="0">
            </div>
            
            <div class="form-checkbox" style="margin-bottom: 1.25rem; display: flex; flex-direction: row; align-items: center; justify-content: flex-start; gap: 0.5rem;">
                <input type="checkbox" id="modalFineWaived" name="fine_waived" value="1" onchange="toggleWaive(this.checked)" style="width: 18px; height: 18px; cursor: pointer; margin: 0;">
                <label for="modalFineWaived" style="margin-bottom: 0; cursor: pointer; font-weight: 500;">Waive Late Fee Fine</label>
            </div>
        </div>
        
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
            <button type="button" class="btn-secondary" onclick="closeModal()">Cancel</button>
            <button type="submit" class="btn-primary">Save Changes</button>
        </div>
    </form>
</div>
<div id="modalOverlay" style="display: none; position: fixed; top: 0; left: 0; width:100%; height:100%; background: rgba(0,0,0,0.4); z-index: 999;" onclick="closeModal()"></div>

<script>
    function openPaymentModal(studentId, studentName, month, year, currentAmount, fineAmount, fineWaived, additionalFee, additionalFeeDesc, paymentDate) {
        const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
        document.getElementById('modalStudentId').value = studentId;
        document.getElementById('modalMonth').value = month;
        document.getElementById('modalYear').value = year;
        document.getElementById('modalAmount').value = currentAmount || '';
        document.getElementById('modalPaymentDate').value = paymentDate || new Date().toISOString().substring(0, 10);
        
        if (month === 0) {
            document.getElementById('modalTitle').innerText = 'Edit Admission Fee: ' + studentName;
            document.getElementById('monthlyFeeExtraFields').style.display = 'none';
        } else {
            document.getElementById('modalTitle').innerText = 'Edit Fee: ' + studentName + ' (' + months[month - 1] + ' ' + year + ')';
            document.getElementById('monthlyFeeExtraFields').style.display = 'block';
            document.getElementById('modalAdditionalFee').value = additionalFee || 0;
            document.getElementById('modalAdditionalFeeDesc').value = additionalFeeDesc || '';
            document.getElementById('modalFine').value = fineAmount || 0;
            document.getElementById('modalFineWaived').checked = fineWaived === 1;
            toggleWaive(fineWaived === 1);
        }
        
        document.getElementById('paymentModal').style.display = 'block';
        document.getElementById('modalOverlay').style.display = 'block';
    }

    function toggleWaive(checked) {
        const fineInput = document.getElementById('modalFine');
        if (checked) {
            fineInput.value = 0;
            fineInput.readOnly = true;
        } else {
            fineInput.readOnly = false;
        }
    }

    function closeModal() {
        document.getElementById('paymentModal').style.display = 'none';
        document.getElementById('modalOverlay').style.display = 'none';
    }
</script>

<%- include('partials/footer') %>
