<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Super Admin - Tenants</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root {
            --primary-color: #4f46e5;
            --secondary-color: #4338ca;
        }
    </style>
</head>
<body>
    <nav class="main-nav">
        <div class="nav-container">
            <a href="/admin" class="brand-link">
                <span class="login-icon" style="width: 36px; height: 36px; font-size: 1.1rem; margin: 0; border-radius: 9px; background: rgb(255 255 255 / 0.18); box-shadow: none;"><i class="bi bi-buildings-fill"></i></span>
                <span class="brand-name">Super Admin Console</span>
            </a>
            <ul class="nav-links">
                <li class="user-menu">
                    <span class="user-greeting"><i class="bi bi-person-circle"></i> Hi, <%= username %></span>
                    <a href="/admin/logout" class="btn-danger nav-btn"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </li>
            </ul>
        </div>
    </nav>

    <main class="main-content">
        <div class="section-header">
            <h1 class="section-title"><i class="bi bi-buildings"></i> Tenants</h1>
        </div>

        <% if (success) { %>
            <div class="alert alert-success"><i class="bi bi-check-circle-fill"></i> <%= success %></div>
        <% } %>

        <div class="card table-container">
            <table>
                <thead>
                    <tr>
                        <th>Logo</th>
                        <th>School Name</th>
                        <th>Subdomain</th>
                        <th>Custom Domain</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% tenants.forEach(t => { %>
                        <tr>
                            <td><img src="<%= t.logo_url %>" alt="logo" style="height: 32px; max-width: 80px; object-fit: contain;"></td>
                            <td style="font-weight: 600;"><%= t.school_name %></td>
                            <td><%= t.subdomain %></td>
                            <td><%= t.custom_domain || '-' %></td>
                            <td>
                                <span class="status-cell <%= t.status === 'active' ? 'status-paid' : 'status-unpaid' %>">
                                    <i class="bi <%= t.status === 'active' ? 'bi-check-circle-fill' : 'bi-pause-circle-fill' %>"></i>
                                    <%= t.status.toUpperCase() %>
                                </span>
                            </td>
                            <td><%= new Date(t.created_at).toLocaleDateString() %></td>
                            <td><a href="/admin/tenants/<%= t.id %>/edit" class="btn-secondary nav-btn"><i class="bi bi-pencil-square"></i> Edit</a></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>
