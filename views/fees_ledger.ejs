<%- include('partials/header') %>

<%
    // Current month settings
    const activeMonthNum = locals.activeMonthNum !== undefined ? locals.activeMonthNum : (new Date().getMonth() + 1);
    const activeYear = locals.activeYear !== undefined ? locals.activeYear : new Date().getFullYear();
    const monthsList = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
    const activeMonthName = monthsList[activeMonthNum - 1];

    // Compute simple view statistics
    let totalExpected = 0;
    let totalCollected = 0;
    let paidCount = 0;
    let defaulterCount = 0;

    students.forEach(s => {
        const expectedFee = s.is_hifz_class ? 0 : (parseFloat(s.default_monthly_fee || 0) - parseFloat(s.custom_monthly_fee || 0));
        totalExpected += expectedFee;
        
        const payObj = paymentMap[s.id] && paymentMap[s.id][activeMonthNum];
        if (payObj && payObj.amount_paid > 0) {
            totalCollected += parseFloat(payObj.amount_paid);
            paidCount++;
        } else {
            defaulterCount++;
        }
    });

    // Grouping for Class Summary
    const classGroups = {};
    classes.forEach(c => {
        classGroups[c.id] = {
            id: c.id,
            name: c.name,
            totalStudents: 0,
            paidCount: 0,
            totalCollected: 0,
            students: []
        };
    });
    // Unassigned group
    classGroups['unassigned'] = {
        id: 'unassigned',
        name: 'Unassigned',
        totalStudents: 0,
        paidCount: 0,
        totalCollected: 0,
        students: []
    };

    students.forEach(s => {
        const cId = s.class_id || 'unassigned';
        if (!classGroups[cId]) {
            classGroups[cId] = { id: cId, name: s.class_name || 'Unknown', totalStudents: 0, paidCount: 0, totalCollected: 0, students: [] };
        }
        
        const payObj = paymentMap[s.id] && paymentMap[s.id][activeMonthNum];
        const madePayment = payObj && payObj.amount_paid > 0;
        const expectedFee = s.is_hifz_class ? 0 : (parseFloat(s.default_monthly_fee || 0) - parseFloat(s.custom_monthly_fee || 0));
        const isFullWaiver = !s.is_hifz_class && expectedFee <= 0 && parseFloat(s.default_monthly_fee || 0) > 0;
        
        const isPaid = madePayment || isFullWaiver || s.is_hifz_class;
        
        classGroups[cId].totalStudents++;
        if (madePayment) {
            classGroups[cId].paidCount++;
            classGroups[cId].totalCollected += parseFloat(payObj.amount_paid);
        } else if (isFullWaiver || s.is_hifz_class) {
            classGroups[cId].paidCount++; // Count them as paid so they don't break KPI
        }
        
        classGroups[cId].students.push({
            ...s,
            isPaid,
            isFullWaiver,
            madePayment,
            payObj,
            expectedFee
        });
    });

    // Sort students within each group: unpaid first, then paid
    Object.values(classGroups).forEach(group => {
        group.students.sort((a, b) => {
            if (a.isPaid === b.isPaid) return 0;
            return a.isPaid ? 1 : -1; // Unpaid (-1) comes before Paid (1)
        });
    });
    
    // Find Nursery class ID if exists
    let nurseryClassId = null;
    const nurseryClass = classes.find(c => c.name.toLowerCase().includes('nursery'));
    if (nurseryClass) {
        nurseryClassId = nurseryClass.id.toString();
    }
%>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-cash-coin"></i> Monthly Fee Ledger</h1>
</div>

<!-- Quick Statistics Grid (Always visible) -->
<div class="kpi-grid" style="margin-bottom: 1.5rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
    <div class="card kpi-card" style="padding: 1rem;">
        <span class="kpi-label">Month Collection Progress</span>
        <span class="kpi-value" style="font-size: 1.4rem;">PKR <%= totalCollected.toLocaleString() %> / <%= totalExpected.toLocaleString() %></span>
        <span class="kpi-subtitle">Progress Rate: <%= totalExpected > 0 ? Math.round((totalCollected / totalExpected) * 100) : 0 %>%</span>
    </div>
    <div class="card kpi-card" style="padding: 1rem;">
        <span class="kpi-label">Paid Students</span>
        <span class="kpi-value" style="font-size: 1.4rem; color: #16a34a;"><%= paidCount %> / <%= students.length %></span>
        <span class="kpi-subtitle">Received this month</span>
    </div>
    <div class="card kpi-card" style="padding: 1rem;">
        <span class="kpi-label">Defaulters</span>
        <span class="kpi-value" style="font-size: 1.4rem; color: #dc2626;"><%= defaulterCount %></span>
        <span class="kpi-subtitle">Awaiting payment</span>
    </div>
</div>

<!-- View Toggles (Tabs) -->
<div class="nav-tabs" style="margin-bottom: 1.5rem; display: flex; gap: 0.5rem; border-bottom: 2px solid var(--border); padding-bottom: 0.5rem;">
    <button class="nav-tab active" id="tab-recent-btn" onclick="switchTab('recent')"><i class="bi bi-clock-history"></i> Recent Activity</button>
    <button class="nav-tab" id="tab-class-btn" onclick="switchTab('class')"><i class="bi bi-diagram-3-fill"></i> Monthly Class Summary (<%= activeMonthName %>)</button>
    <button class="nav-tab" id="tab-matrix-btn" onclick="switchTab('matrix')"><i class="bi bi-grid-3x3-gap-fill"></i> Full Year Matrix</button>
</div>

<!-- Tab: Recent Activity Pane -->
<div id="pane-recent">
    <div style="display: flex; flex-direction: column; gap: 2rem;">
        <!-- Top: Recent Collections -->
        <div>
            <h3 style="margin-bottom: 1rem; color: var(--ink);"><i class="bi bi-clock-history"></i> Recent Fee Collections</h3>
            <div style="margin-bottom: 1rem; color: var(--muted); font-weight: 500;">
                Showing the last 10 fee payments collected.
            </div>
    <div class="table-container">
        <table class="simple-ledger-table">
            <thead>
                <tr>
                    <th style="text-align: left;">Date</th>
                    <th style="text-align: left;">Reg No</th>
                    <th style="text-align: left;">Student Name</th>
                    <th style="text-align: left;">Class</th>
                    <th style="text-align: left;">Month</th>
                    <th style="text-align: right;">Amount Paid</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (locals.recentPayments && recentPayments.length > 0) { %>
                    <% recentPayments.forEach(rp => { %>
                        <tr class="student-row status-row-paid">
                            <td style="font-weight: 500; text-align: left;"><%= new Date(rp.payment_date).toLocaleDateString('en-GB') %></td>
                            <td style="font-weight: 600; text-align: left;"><%= rp.reg_no %></td>
                            <td style="text-align: left; font-weight: 500;"><a href="/students/view/<%= rp.student_id %>" style="color: var(--primary-color); text-decoration: underline;"><%= rp.student_name %></a></td>
                            <td style="text-align: left;"><%= rp.class_name || 'Unassigned' %></td>
                            <td style="text-align: left;"><%= monthsList[rp.month - 1] %> <%= rp.year %></td>
                            <td style="text-align: right; font-weight: 600; color: #16a34a;">PKR <%= parseFloat(rp.amount_paid).toLocaleString() %></td>
                            <td style="text-align: center;">
                                <a href="/fees/receipt/<%= rp.id %>" class="btn-secondary nav-btn" target="_blank" title="Print PDF Receipt"><i class="bi bi-printer-fill"></i> Receipt</a>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="7" style="text-align: center; color: #64748b; padding: 2rem;">No recent payments found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
        <% if (locals.recentPayments && recentPayments.length === 10) { %>
            <div style="text-align: center; margin-top: 1rem; margin-bottom: 0.5rem;">
                <button id="btn-load-more-recent" class="btn-secondary" onclick="loadMoreRecent()" style="width: 100%; max-width: 300px; padding: 0.5rem;"><i class="bi bi-arrow-down-circle"></i> Load 10 More</button>
            </div>
        <% } %>
    </div>
</div>
        
        <!-- Bottom: Top Defaulters -->
        <div>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                <h3 style="color: var(--ink); margin: 0;"><i class="bi bi-exclamation-triangle-fill" style="color: #dc2626;"></i> Year-to-Date Top Defaulters</h3>
            </div>
            <div style="margin-bottom: 1rem; color: var(--muted); font-weight: 500;">
                Students with the highest accrued unpaid balances for <%= activeYear %> across all classes.
            </div>
            <div class="table-container">
                <table class="simple-ledger-table" id="defaulters-table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">Reg No</th>
                            <th style="text-align: left;">Student Name</th>
                            <th style="text-align: left;">Class</th>
                            <th style="text-align: right;">Total Due</th>
                            <th style="text-align: center;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (locals.topDefaulters && topDefaulters.length > 0) { %>
                            <% topDefaulters.forEach(s => { %>
                                <tr class="student-row status-row-unpaid">
                                    <td style="font-weight: 600; text-align: left;"><%= s.reg_no %></td>
                                    <td style="text-align: left; font-weight: 500;"><a href="/students/view/<%= s.id %>" style="color: var(--primary-color); text-decoration: underline;"><%= s.name %></a></td>
                                    <td style="text-align: left;"><%= s.class_name %></td>
                                    <td style="text-align: right; font-weight: 600; color: #dc2626;">PKR <%= s.due.toLocaleString() %></td>
                                    <td style="text-align: center;">
                                        <button type="button" class="btn-primary nav-btn" style="padding: 0.3rem 0.5rem; font-size: 0.8rem;" onclick="openPaymentModal('<%= s.id %>', '<%= s.name.replace(/'/g, "\\'") %>', <%= activeMonthNum %>, '', <%= s.expectedFee %>, <%= s.default_monthly_fee || 0 %>, <%= s.custom_monthly_fee || 0 %>, 0, '')"><i class="bi bi-credit-card-fill"></i> Collect</button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" style="text-align: center; color: #16a34a; padding: 2rem;"><i class="bi bi-check-circle-fill"></i> No defaulters found!</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
                <% if (locals.topDefaulters && topDefaulters.length === 10) { %>
                    <div style="text-align: center; margin-top: 1rem; margin-bottom: 0.5rem;">
                        <button id="btn-load-more-defaulters" class="btn-secondary" onclick="loadMoreDefaulters()" style="width: 100%; max-width: 300px; padding: 0.5rem;"><i class="bi bi-arrow-down-circle"></i> Load 10 More</button>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Tab: Class Summary Pane -->
<div id="pane-class" style="display: none;">
    <!-- Filters Collapsible Panel -->
    <details class="filter-panel" <%= (classId || search || locals.activeMonthNum || locals.activeYear) ? 'open' : '' %>>
        <summary>
            <span><i class="bi bi-funnel-fill"></i> Filter & Search Fees</span>
            <i class="bi bi-chevron-down toggle-icon"></i>
        </summary>
        <form action="/fees/ledger" method="GET" class="filter-content">
            <input type="hidden" name="view" id="filter-view-input" value="recent">
            <div class="form-group">
                <label for="classId">Class</label>
                <select name="classId" id="classId" class="form-control" onchange="this.form.submit()">
                    <option value="">-- All Classes --</option>
                    <% classes.forEach(c => { %>
                        <option value="<%= c.id %>" <%= classId == c.id ? 'selected' : '' %>><%= c.name %></option>
                    <% }) %>
                </select>
            </div>
            
            <div class="form-group">
                <label for="month">Month</label>
                <select name="month" id="month" class="form-control" onchange="this.form.submit()">
                    <% monthsList.forEach((mName, idx) => { %>
                        <option value="<%= idx + 1 %>" <%= activeMonthNum == (idx + 1) ? 'selected' : '' %>><%= mName %></option>
                    <% }) %>
                </select>
            </div>
            
            <div class="form-group">
                <label for="year">Year</label>
                <select name="year" id="year" class="form-control" onchange="this.form.submit()">
                    <% [2024, 2025, 2026, 2027, 2028].forEach(y => { %>
                        <option value="<%= y %>" <%= activeYear == y ? 'selected' : '' %>><%= y %></option>
                    <% }) %>
                </select>
            </div>
            
            <div class="form-group">
                <label for="search">Search</label>
                <input type="text" name="search" id="search" class="form-control" value="<%= search || '' %>" placeholder="Search by name or Reg No...">
            </div>
            
            <div style="display: flex; gap: 0.5rem; align-items: flex-end;">
                <button type="submit" class="btn-secondary" style="height: 38px;">Search</button>
                <a href="/fees/ledger" class="btn-secondary" style="height: 38px; display: inline-flex; align-items: center;">Reset</a>
            </div>
        </form>
    </details>
    <div style="margin-bottom: 1rem; color: var(--muted); font-weight: 500;">
        Students grouped by class. Defaulters (unpaid) are shown first.
    </div>

    <% Object.values(classGroups).forEach((group, index) => { %>
        <% if (group.id !== 'unassigned' && group.totalStudents > 0) { %>
            <% 
                // Determine if expanded
                let isExpanded = false;
                if (classId && classId == group.id) {
                    isExpanded = true;
                } else if (!classId) {
                    if (nurseryClassId && group.id == nurseryClassId) {
                        isExpanded = true;
                    } else if (!nurseryClassId && index === 0) {
                        isExpanded = true;
                    }
                }
            %>
            <details class="card" style="margin-bottom: 1rem;" <%= isExpanded ? 'open' : '' %>>
                <summary style="padding: 1rem; cursor: pointer; display: flex; justify-content: space-between; align-items: center; background-color: #f8fafc; border-bottom: 1px solid var(--border);">
                    <div>
                        <strong style="font-size: 1.1rem;"><%= group.name %></strong>
                        <span style="margin-left: 1rem; font-size: 0.9rem; color: var(--muted);">
                            <i class="bi bi-people-fill"></i> <%= group.totalStudents %> Students
                        </span>
                    </div>
                    <div style="display: flex; gap: 1.5rem; align-items: center; font-size: 0.9rem;">
                        <span style="<%= group.paidCount === group.totalStudents ? 'color: #16a34a;' : (group.paidCount === 0 ? 'color: #dc2626;' : 'color: #eab308;') %> font-weight: 600;">
                            Paid: <%= group.paidCount %> / <%= group.totalStudents %>
                        </span>
                        <span style="font-weight: 600;">
                            Collected: PKR <%= group.totalCollected.toLocaleString() %>
                        </span>
                        <i class="bi bi-chevron-down toggle-icon"></i>
                    </div>
                </summary>
                <div style="padding: 0;">
                    <table class="simple-ledger-table" style="margin: 0; border: none; box-shadow: none;">
                        <thead>
                            <tr>
                                <th style="text-align: left; padding-left: 1rem;">Reg No</th>
                                <th style="text-align: left;">Student Name</th>
                                <th style="text-align: right;">Monthly Fee</th>
                                <th style="text-align: right;">Amount Paid</th>
                                <th>Status</th>
                                <th style="padding-right: 1rem;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% group.students.forEach(s => { %>
                                <tr class="student-row <%= s.isPaid ? 'status-row-paid' : 'status-row-unpaid' %>">
                                    <td style="font-weight: 600; text-align: left; padding-left: 1rem;"><%= s.reg_no %></td>
                                    <td style="text-align: left; font-weight: 500;"><a href="/students/view/<%= s.id %>" style="color: var(--primary-color); text-decoration: underline; cursor: pointer;"><%= s.name %></a></td>
                                    <td style="text-align: right; font-weight: 600;">PKR <%= s.expectedFee.toLocaleString() %></td>
                                    <td style="text-align: right; font-weight: 600; color: #16a34a;">
                                        <%= s.madePayment ? 'PKR ' + s.payObj.amount_paid.toLocaleString() : '-' %>
                                    </td>
                                    <td>
                                        <% if (s.isFullWaiver && !s.madePayment) { %>
                                            <span class="status-cell status-paid" style="background-color: #f3f4f6; color: #4b5563;"><i class="bi bi-gift-fill"></i> FULL WAIVER</span>
                                        <% } else if (s.isPaid) { %>
                                            <span class="status-cell status-paid"><i class="bi bi-check-circle-fill"></i> PAID</span>
                                        <% } else { %>
                                            <span class="status-cell status-unpaid"><i class="bi bi-exclamation-triangle-fill"></i> DEFAULTER</span>
                                        <% } %>
                                    </td>
                                    <td style="padding-right: 1rem;">
                                        <div style="display: flex; gap: 0.4rem; justify-content: center;">
                                            <% if (s.is_hifz_class) { %>
                                                <span style="color: #16a34a; font-weight: 600; font-size: 0.85rem;"><i class="bi bi-shield-check"></i> Hifz (No Fee)</span>
                                            <% } else if (s.madePayment) { %>
                                                <a href="/fees/receipt/<%= s.payObj.id %>" class="btn-secondary nav-btn" target="_blank" title="Print PDF Receipt"><i class="bi bi-printer-fill"></i> Receipt</a>
                                                <button type="button" class="btn-secondary nav-btn" onclick="openPaymentModal('<%= s.id %>', '<%= s.name %>', <%= activeMonthNum %>, <%= s.payObj.amount_paid %>, <%= s.expectedFee %>, <%= s.default_monthly_fee || 0 %>, <%= s.custom_monthly_fee || 0 %>, <%= s.payObj.additional_fee || 0 %>, '<%= s.payObj.additional_fee_description || '' %>')"><i class="bi bi-pencil-fill"></i> Edit</button>
                                            <% } else if (s.isFullWaiver) { %>
                                                <button type="button" class="btn-secondary nav-btn" onclick="openPaymentModal('<%= s.id %>', '<%= s.name %>', <%= activeMonthNum %>, '', <%= s.expectedFee %>, <%= s.default_monthly_fee || 0 %>, <%= s.custom_monthly_fee || 0 %>, 0, '')"><i class="bi bi-plus-circle"></i> Add Fee</button>
                                            <% } else { %>
                                                <button type="button" class="btn-primary nav-btn" onclick="openPaymentModal('<%= s.id %>', '<%= s.name %>', <%= activeMonthNum %>, '', <%= s.expectedFee %>, <%= s.default_monthly_fee || 0 %>, <%= s.custom_monthly_fee || 0 %>, 0, '')"><i class="bi bi-credit-card-fill"></i> Collect</button>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </details>
        <% } %>
    <% }) %>
    <% if (Object.values(classGroups).every(group => group.id === 'unassigned' || group.totalStudents === 0)) { %>
        <div style="text-align: center; color: #64748b; padding: 3rem; background: #fff; border-radius: 8px; border: 1px solid var(--border);">
            <i class="bi bi-inbox" style="font-size: 2.5rem; color: var(--border); margin-bottom: 1rem; display: block;"></i>
            <h4>No Records Found</h4>
            <p>No students match your current filter and search criteria.</p>
        </div>
    <% } %>
</div>

<!-- Tab 1: Simple View Pane -->
<div id="pane-simple" style="display: none;">
    <!-- Quick Statistics Grid -->
    <div class="kpi-grid" style="margin-bottom: 1.5rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
        <div class="card kpi-card" style="padding: 1rem; cursor: pointer;" onclick="filterByStatus('all')" title="Click to show all students">
            <span class="kpi-label">Month Collection Progress</span>
            <span class="kpi-value" style="font-size: 1.4rem;">PKR <%= totalCollected.toLocaleString() %> / <%= totalExpected.toLocaleString() %></span>
            <span class="kpi-subtitle">Progress Rate: <%= totalExpected > 0 ? Math.round((totalCollected / totalExpected) * 100) : 0 %>%</span>
        </div>
        <div class="card kpi-card" style="padding: 1rem; cursor: pointer;" onclick="filterByStatus('paid')" title="Click to show paid students only">
            <span class="kpi-label">Paid Students</span>
            <span class="kpi-value" style="font-size: 1.4rem; color: #16a34a;"><%= paidCount %> / <%= students.length %></span>
            <span class="kpi-subtitle">Received this month</span>
        </div>
        <div class="card kpi-card" style="padding: 1rem; cursor: pointer;" onclick="filterByStatus('unpaid')" title="Click to show defaulters only">
            <span class="kpi-label">Defaulters</span>
            <span class="kpi-value" style="font-size: 1.4rem; color: #dc2626;"><%= defaulterCount %></span>
            <span class="kpi-subtitle">Awaiting payment</span>
        </div>
    </div>

    <!-- Quick filter checkbox -->
    <div style="margin-bottom: 1rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <div style="display: flex; align-items: center; gap: 0.5rem;">
            <input type="checkbox" id="show-defaulters-checkbox" onchange="toggleDefaultersOnly(this.checked)" style="width: 18px; height: 18px; cursor: pointer;">
            <label for="show-defaulters-checkbox" style="font-size: 0.9rem; font-weight: 600; cursor: pointer; color: var(--ink);">Show Defaulters Only</label>
        </div>
        <div style="font-size: 0.85rem; color: var(--muted); font-weight: 600;">
            Showing <%= students.length %> students
        </div>
    </div>

    <!-- Simple Table -->
    <div class="table-container">
        <table class="simple-ledger-table">
            <thead>
                <tr>
                    <th style="text-align: left;">Reg No</th>
                    <th style="text-align: left;">Student Name</th>
                    <th style="text-align: left;">Class</th>
                    <th style="text-align: right;">Monthly Fee</th>
                    <th style="text-align: right;">Amount Paid</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (students.length > 0) { %>
                    <% students.forEach(s => { %>
                        <% 
                            const expectedFee = s.is_hifz_class ? 0 : (parseFloat(s.default_monthly_fee || 0) - parseFloat(s.custom_monthly_fee || 0));
                            const payObj = paymentMap[s.id] && paymentMap[s.id][activeMonthNum];
                            const isPaid = payObj && payObj.amount_paid > 0;
                        %>
                        <tr class="student-row <%= isPaid ? 'status-row-paid' : 'status-row-unpaid' %>">
                            <td style="font-weight: 600; text-align: left;"><%= s.reg_no %></td>
                            <td style="text-align: left; font-weight: 500;"><a href="/students/view/<%= s.id %>" style="color: var(--primary-color, #4f46e5); text-decoration: underline; cursor: pointer;"><%= s.name %></a></td>
                            <td style="text-align: left;"><%= s.class_name || 'Unassigned' %></td>
                            <td style="text-align: right; font-weight: 600;">PKR <%= expectedFee.toLocaleString() %></td>
                            <td style="text-align: right; font-weight: 600; color: #16a34a;">
                                <%= isPaid ? 'PKR ' + payObj.amount_paid.toLocaleString() : '-' %>
                            </td>
                            <td>
                                <% if (isPaid) { %>
                                    <span class="status-cell status-paid"><i class="bi bi-check-circle-fill"></i> PAID</span>
                                <% } else { %>
                                    <span class="status-cell status-unpaid"><i class="bi bi-exclamation-triangle-fill"></i> DEFAULTER</span>
                                <% } %>
                            </td>
                            <td>
                                <div style="display: flex; gap: 0.4rem; justify-content: center;">
                                    <% if (s.is_hifz_class) { %>
                                        <span style="color: #16a34a; font-weight: 600; font-size: 0.85rem;"><i class="bi bi-shield-check"></i> Hifz (No Fee)</span>
                                    <% } else if (isPaid) { %>
                                        <a href="/fees/receipt/<%= payObj.id %>" class="btn-secondary nav-btn" target="_blank" title="Print PDF Receipt"><i class="bi bi-printer-fill"></i> Receipt</a>
                                        <button type="button" class="btn-secondary nav-btn" onclick="openPaymentModal('<%= s.id %>', '<%= s.name %>', <%= activeMonthNum %>, <%= payObj.amount_paid %>, <%= expectedFee %>, <%= s.default_monthly_fee || 0 %>, <%= s.custom_monthly_fee || 0 %>, <%= payObj.additional_fee || 0 %>, '<%= payObj.additional_fee_description || '' %>')"><i class="bi bi-pencil-fill"></i> Edit</button>
                                    <% } else { %>
                                        <button type="button" class="btn-primary nav-btn" onclick="openPaymentModal('<%= s.id %>', '<%= s.name %>', <%= activeMonthNum %>, '', <%= expectedFee %>, <%= s.default_monthly_fee || 0 %>, <%= s.custom_monthly_fee || 0 %>, 0, '')"><i class="bi bi-credit-card-fill"></i> Collect</button>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="7" style="text-align: center; color: #64748b; padding: 2rem;">No students found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Tab 2: Full Year Matrix Pane -->
<div id="pane-matrix" style="display: none;">
    <div class="table-container">
        <table class="matrix-table">
            <thead>
                <tr>
                    <th style="text-align: left;">Reg No</th>
                    <th style="text-align: left; min-width: 150px;">Student Name</th>
                    <th style="text-align: left;">Due Fee</th>
                    <th>Jan</th>
                    <th>Feb</th>
                    <th>Mar</th>
                    <th>Apr</th>
                    <th>May</th>
                    <th>Jun</th>
                    <th>Jul</th>
                    <th>Aug</th>
                    <th>Sep</th>
                    <th>Oct</th>
                    <th>Nov</th>
                    <th>Dec</th>
                </tr>
            </thead>
            <tbody>
                <% if (students.length > 0) { %>
                    <% students.forEach(s => { %>
                        <% 
                            const expectedFee = s.is_hifz_class ? 0 : (parseFloat(s.default_monthly_fee || 0) - parseFloat(s.custom_monthly_fee || 0));
                            const studentPayments = paymentMap[s.id] || {};
                        %>
                        <tr>
                            <td style="font-weight: 600; text-align: left;"><%= s.reg_no %></td>
                            <td style="text-align: left;"><a href="/students/view/<%= s.id %>" style="color: var(--primary-color, #4f46e5); text-decoration: underline; cursor: pointer;"><%= s.name %></a></td>
                            <td style="text-align: left; font-weight: 600; color: <%= s.has_concession ? '#b91c1c' : '#1e293b' %>">
                                <%= expectedFee.toLocaleString() %>
                            </td>
                            
                            <% for (let m = 1; m <= 12; m++) { %>
                                <% 
                                    const payObj = studentPayments[m];
                                    const amtPaid = payObj ? payObj.amount_paid : undefined;
                                %>
                                <% if (s.is_hifz_class) { %>
                                    <td class="status-cell status-paid" style="background-color: #f0fdf4; color: #16a34a; font-weight: 600;">
                                        Hifz
                                    </td>
                                <% } else if (amtPaid !== undefined && amtPaid > 0) { %>
                                    <td class="status-cell status-paid cell-amount" onclick="openPaymentModal('<%= s.id %>', '<%= s.name %>', <%= m %>, <%= amtPaid %>, <%= expectedFee %>, <%= s.default_monthly_fee || 0 %>, <%= s.custom_monthly_fee || 0 %>, <%= payObj.additional_fee || 0 %>, '<%= payObj.additional_fee_description || '' %>')">
                                        <%= amtPaid %>
                                    </td>
                                  <% } else { %>
                                    <td class="status-cell status-unpaid" onclick="openPaymentModal('<%= s.id %>', '<%= s.name %>', <%= m %>, '', <%= expectedFee %>, <%= s.default_monthly_fee || 0 %>, <%= s.custom_monthly_fee || 0 %>, 0, '')">
                                        -
                                    </td>
                                  <% } %>
                            <% } %>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="15" style="text-align: center; color: #64748b;">No students found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Payment Modal -->
<div id="paymentModal" class="card" style="display: none; max-width: 400px; margin: 1rem auto; position: fixed; top: 20%; left: 50%; transform: translate(-50%, 0); z-index: 1000; box-shadow: 0 10px 25px rgba(0,0,0,0.2); box-sizing: border-box; width: 90%;">
    <h3 style="margin-bottom: 1rem;" id="modalTitle">Record Payment</h3>
    <form action="/fees/pay" method="POST">
        <input type="hidden" id="modalStudentId" name="student_id">
        <input type="hidden" id="modalMonth" name="month">
        <input type="hidden" id="modalYear" name="year">
        
        <div style="background-color: #f8fafc; border: 1px solid #e2e8f0; padding: 0.75rem; border-radius: 0.375rem; margin-bottom: 1.25rem; font-size: 0.85rem; line-height: 1.5;">
            <div style="display: flex; justify-content: space-between;">
                <span>Total Class Fee:</span>
                <strong id="modalClassFeeDisplay">PKR 0</strong>
            </div>
            <div style="display: flex; justify-content: space-between; color: #b91c1c;">
                <span>Concession Support:</span>
                <strong id="modalConcessionDisplay">PKR 0</strong>
            </div>
            <hr style="border: 0; border-top: 1px solid #e2e8f0; margin: 0.5rem 0;">
            <div style="display: flex; justify-content: space-between; font-size: 0.95rem;">
                <span>Fee to Collect:</span>
                <strong id="modalExpectedFeeDisplay" style="color: var(--primary-color);">PKR 0</strong>
            </div>
        </div>

        <div class="form-group" style="margin-bottom: 1.25rem;">
            <label for="modalAmount">Amount Paid (PKR)</label>
            <input type="number" step="0.01" id="modalAmount" name="amount" class="form-control" required>
        </div>

        <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1.25rem;">
            <div class="form-group">
                <label for="modalAdditionalFee">Additional Fee (PKR)</label>
                <input type="number" step="0.01" id="modalAdditionalFee" name="additional_fee" class="form-control" value="0">
            </div>
            
            <div class="form-group">
                <label for="modalAdditionalFeeDesc">Fee Description</label>
                <input type="text" id="modalAdditionalFeeDesc" name="additional_fee_description" class="form-control" placeholder="e.g. Exam fee">
            </div>
        </div>
        
        <div class="form-group" style="margin-bottom: 1.25rem;">
            <label for="modalFine">Late Fee Fine (Rs. 20/day after 10th)</label>
            <input type="number" step="0.01" id="modalFine" name="fine_amount" class="form-control" value="0">
        </div>
        
        <div class="form-checkbox" style="margin-bottom: 1.25rem; display: flex; flex-direction: row; align-items: center; justify-content: flex-start; gap: 0.5rem;">
            <input type="checkbox" id="modalFineWaived" name="fine_waived" value="1" onchange="toggleWaive(this.checked)" style="width: 18px; height: 18px; cursor: pointer; margin: 0;">
            <label for="modalFineWaived" style="margin-bottom: 0; cursor: pointer; font-weight: 500;">Waive Late Fee Fine</label>
        </div>
        
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
            <button type="button" class="btn-secondary" onclick="closeModal()">Cancel</button>
            <button type="submit" class="btn-primary">Save Payment</button>
        </div>
    </form>
</div>
<div id="modalOverlay" style="display: none; position: fixed; top: 0; left: 0; width:100%; height:100%; background: rgba(0,0,0,0.4); z-index: 999;" onclick="closeModal()"></div>

<script>
    const clientClassGroups = <%- JSON.stringify(classGroups) %>;
    const clientActiveMonthNum = <%= activeMonthNum %>;

    let recentOffset = 10;
    let defaultersOffset = 10;

    async function loadMoreRecent() {
        const btn = document.getElementById('btn-load-more-recent');
        if(!btn) return;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Loading...';
        btn.disabled = true;

        try {
            const res = await fetch(`/fees/api/recent?offset=${recentOffset}`);
            const json = await res.json();
            if (json.success) {
                const tbody = document.querySelector('#pane-recent .table-container table tbody');
                let html = '';
                json.data.forEach(rp => {
                    const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
                    const dateStr = new Date(rp.payment_date).toLocaleDateString('en-GB');
                    html += `
                        <tr class="student-row status-row-paid">
                            <td style="font-weight: 500; text-align: left;">${dateStr}</td>
                            <td style="font-weight: 600; text-align: left;">${rp.reg_no}</td>
                            <td style="text-align: left; font-weight: 500;"><a href="/students/view/${rp.student_id}" style="color: var(--primary-color); text-decoration: underline;">${rp.student_name}</a></td>
                            <td style="text-align: left;">${rp.class_name || 'Unassigned'}</td>
                            <td style="text-align: left;">${months[rp.month - 1]} ${rp.year}</td>
                            <td style="text-align: right; font-weight: 600; color: #16a34a;">PKR ${parseFloat(rp.amount_paid).toLocaleString()}</td>
                            <td style="text-align: center;">
                                <a href="/fees/receipt/${rp.id}" class="btn-secondary nav-btn" target="_blank" title="Print PDF Receipt"><i class="bi bi-printer-fill"></i> Receipt</a>
                            </td>
                        </tr>
                    `;
                });
                tbody.insertAdjacentHTML('beforeend', html);
                recentOffset += json.data.length;

                if (json.data.length < 10) {
                    btn.parentElement.style.display = 'none';
                }
            }
        } catch (e) {
            console.error(e);
            alert('Failed to load more recent payments.');
        } finally {
            btn.innerHTML = '<i class="bi bi-arrow-down-circle"></i> Load 10 More';
            btn.disabled = false;
        }
    }

    async function loadMoreDefaulters() {
        const btn = document.getElementById('btn-load-more-defaulters');
        if(!btn) return;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Loading...';
        btn.disabled = true;

        try {
            const activeYear = <%= activeYear %>;
            const res = await fetch(`/fees/api/defaulters?offset=${defaultersOffset}&year=${activeYear}`);
            const json = await res.json();
            if (json.success) {
                const tbody = document.querySelector('#defaulters-table tbody');
                let html = '';
                json.data.forEach(s => {
                    const safeName = s.name.replace(/'/g, "\\'");
                    html += `
                        <tr class="student-row status-row-unpaid">
                            <td style="font-weight: 600; text-align: left;">${s.reg_no}</td>
                            <td style="text-align: left; font-weight: 500;"><a href="/students/view/${s.id}" style="color: var(--primary-color); text-decoration: underline;">${s.name}</a></td>
                            <td style="text-align: left;">${s.class_name}</td>
                            <td style="text-align: right; font-weight: 600; color: #dc2626;">PKR ${s.due.toLocaleString()}</td>
                            <td style="text-align: center;">
                                <button type="button" class="btn-primary nav-btn" style="padding: 0.3rem 0.5rem; font-size: 0.8rem;" onclick="openPaymentModal('${s.id}', '${safeName}', clientActiveMonthNum, '', ${s.expectedFee}, ${s.default_monthly_fee || 0}, ${s.custom_monthly_fee || 0}, 0, '')"><i class="bi bi-credit-card-fill"></i> Collect</button>
                            </td>
                        </tr>
                    `;
                });
                tbody.insertAdjacentHTML('beforeend', html);
                defaultersOffset += json.data.length;

                if (json.data.length < 10) {
                    btn.parentElement.style.display = 'none';
                }
            }
        } catch (e) {
            console.error(e);
            alert('Failed to load more defaulters.');
        } finally {
            btn.innerHTML = '<i class="bi bi-arrow-down-circle"></i> Load 10 More';
            btn.disabled = false;
        }
    }

    function openPaymentModal(studentId, studentName, month, currentAmount, expectedFee, classFee, concession, additionalFee, additionalFeeDesc) {
        const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
        document.getElementById('modalStudentId').value = studentId;
        document.getElementById('modalMonth').value = month;
        document.getElementById('modalAmount').value = currentAmount || expectedFee;
        document.getElementById('modalTitle').innerText = 'Pay Fee: ' + studentName + ' (' + months[month - 1] + ')';
        
        document.getElementById('modalClassFeeDisplay').innerText = 'PKR ' + parseFloat(classFee || 0).toLocaleString();
        document.getElementById('modalConcessionDisplay').innerText = 'PKR ' + parseFloat(concession || 0).toLocaleString();
        document.getElementById('modalExpectedFeeDisplay').innerText = 'PKR ' + parseFloat(expectedFee || 0).toLocaleString();

        document.getElementById('modalAdditionalFee').value = additionalFee || 0;
        document.getElementById('modalAdditionalFeeDesc').value = additionalFeeDesc || '';
        
        // Calculate late fee automatically based on year context
        const today = new Date();
        const currentDay = today.getDate();
        let calculatedFine = 0;
        const currentMonth = today.getMonth() + 1; // 1-indexed
        const currentYear = today.getFullYear();
        const selectedYear = document.getElementById('year') ? parseInt(document.getElementById('year').value) : currentYear;

        document.getElementById('modalYear').value = selectedYear;

        if (selectedYear < currentYear || (selectedYear === currentYear && month < currentMonth)) {
            const dueDate = new Date(selectedYear, month - 1, 10);
            const diffTime = Math.max(0, today - dueDate);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            calculatedFine = diffDays * 20;
        } else if (selectedYear === currentYear && month == currentMonth && currentDay > 10) {
            calculatedFine = (currentDay - 10) * 20;
        }

        document.getElementById('modalFine').value = calculatedFine;
        document.getElementById('modalFine').readOnly = false;
        document.getElementById('modalFineWaived').checked = false;
        
        document.getElementById('paymentModal').style.display = 'block';
        document.getElementById('modalOverlay').style.display = 'block';
    }
    
    function toggleWaive(checked) {
        const fineInput = document.getElementById('modalFine');
        if (checked) {
            fineInput.value = 0;
            fineInput.readOnly = true;
        } else {
            fineInput.readOnly = false;
            const month = document.getElementById('modalMonth').value;
            const today = new Date();
            const currentDay = today.getDate();
            let calculatedFine = 0;
            const currentMonth = today.getMonth() + 1;
            const currentYear = today.getFullYear();
            const selectedYear = document.getElementById('year') ? parseInt(document.getElementById('year').value) : currentYear;

            if (selectedYear < currentYear || (selectedYear === currentYear && month < currentMonth)) {
                const dueDate = new Date(selectedYear, month - 1, 10);
                const diffTime = Math.max(0, today - dueDate);
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                calculatedFine = diffDays * 20;
            } else if (selectedYear === currentYear && month == currentMonth && currentDay > 10) {
                calculatedFine = (currentDay - 10) * 20;
            }
            fineInput.value = calculatedFine;
        }
    }
    function closeModal() {
        document.getElementById('paymentModal').style.display = 'none';
        document.getElementById('modalOverlay').style.display = 'none';
    }

    // Tabs switching logic
    function switchTab(tabType) {
        const recentBtn = document.getElementById('tab-recent-btn');
        const classBtn = document.getElementById('tab-class-btn');
        const simpleBtn = document.getElementById('tab-simple-btn');
        const matrixBtn = document.getElementById('tab-matrix-btn');
        
        const recentPane = document.getElementById('pane-recent');
        const classPane = document.getElementById('pane-class');
        const simplePane = document.getElementById('pane-simple');
        const matrixPane = document.getElementById('pane-matrix');
        
        const filterViewInput = document.getElementById('filter-view-input');

        // Reset all
        [recentBtn, classBtn, simpleBtn, matrixBtn].forEach(b => { if(b) b.classList.remove('active'); });
        [recentPane, classPane, simplePane, matrixPane].forEach(p => { if(p) p.style.display = 'none'; });

        if (tabType === 'recent' && recentBtn) {
            recentBtn.classList.add('active');
            recentPane.style.display = 'block';
        } else if (tabType === 'class' && classBtn) {
            classBtn.classList.add('active');
            classPane.style.display = 'block';
        } else if (tabType === 'matrix' && matrixBtn) {
            matrixBtn.classList.add('active');
            matrixPane.style.display = 'block';
        } else {
            // default to simple
            if(simpleBtn) simpleBtn.classList.add('active');
            if(simplePane) simplePane.style.display = 'block';
            tabType = 'simple';
        }
        
        if (filterViewInput) filterViewInput.value = tabType;
        localStorage.setItem('fees_ledger_view', tabType);
    }

    // Quick filter check for defaulters
    function toggleDefaultersOnly(showDefaultersOnly) {
        const rows = document.querySelectorAll('#pane-class .student-row');
        rows.forEach(row => {
            if (showDefaultersOnly) {
                if (row.classList.contains('status-row-paid')) {
                    row.style.display = 'none';
                } else {
                    row.style.display = '';
                }
            } else {
                row.style.display = '';
            }
        });
        localStorage.setItem('fees_ledger_show_defaulters', showDefaultersOnly ? 'true' : 'false');
    }

    // Filter table by paid/unpaid status
    function filterByStatus(status) {
        // Automatically switch to Class Summary tab if KPI is clicked
        switchTab('class');
        
        const checkbox = document.getElementById('show-defaulters-checkbox');
        const rows = document.querySelectorAll('#pane-class .student-row');
        
        if (status === 'all') {
            if (checkbox) checkbox.checked = false;
            rows.forEach(row => row.style.display = '');
            localStorage.setItem('fees_ledger_show_defaulters', 'false');
        } else if (status === 'paid') {
            if (checkbox) checkbox.checked = false;
            rows.forEach(row => {
                if (row.classList.contains('status-row-paid')) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
            localStorage.setItem('fees_ledger_show_defaulters', 'false');
        } else if (status === 'unpaid') {
            if (checkbox) checkbox.checked = true;
            rows.forEach(row => {
                if (row.classList.contains('status-row-unpaid')) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
            localStorage.setItem('fees_ledger_show_defaulters', 'true');
        }
    }

    // Restore tab preference and checkbox state on load
    document.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const urlView = urlParams.get('view');
        let savedView = urlView || 'recent';
        
        switchTab(savedView);

        const showDefaultersOnly = localStorage.getItem('fees_ledger_show_defaulters') === 'true';
        const checkbox = document.getElementById('show-defaulters-checkbox');
        if (checkbox) {
            checkbox.checked = showDefaultersOnly;
            toggleDefaultersOnly(showDefaultersOnly);
        }
    });
</script>

<%- include('partials/footer') %>
