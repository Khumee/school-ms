<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title">2026 Monthly Fee Ledger Matrix</h1>
</div>

<!-- Filters -->
<form action="/fees/ledger" method="GET" class="filter-bar">
    <div class="form-group">
        <label for="classId">Class</label>
        <select name="classId" id="classId" class="form-control" onchange="this.form.submit()">
            <option value="">-- All Classes --</option>
            <% classes.forEach(c => { %>
                <option value="<%= c.id %>" <%= classId == c.id ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
        </select>
    </div>
    
    <div class="form-group">
        <label for="search">Search</label>
        <input type="text" name="search" id="search" class="form-control" value="<%= search || '' %>" placeholder="Search by name or Reg No...">
    </div>
    
    <button type="submit" class="btn-secondary">Search</button>
    <a href="/fees/ledger" class="btn-secondary" style="height: 38px; display: inline-flex; align-items: center;">Reset</a>
</form>

<!-- Payment Modal (Hidden by Default) -->
<div id="paymentModal" class="card" style="display: none; max-width: 400px; margin: 1rem auto; position: fixed; top: 20%; left: 50%; transform: translate(-50%, 0); z-index: 1000; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
    <h3 style="margin-bottom: 1rem;" id="modalTitle">Record Payment</h3>
    <form action="/fees/pay" method="POST">
        <input type="hidden" id="modalStudentId" name="student_id">
        <input type="hidden" id="modalMonth" name="month">
        
        <div class="form-group" style="margin-bottom: 1.25rem;">
            <label for="modalAmount">Amount Paid (PKR)</label>
            <input type="number" step="0.01" id="modalAmount" name="amount" class="form-control" required>
            <small style="color: #64748b; margin-top: 0.25rem; display: block;" id="modalExpectedFee"></small>
        </div>
        
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
            <button type="button" class="btn-secondary" onclick="closeModal()">Cancel</button>
            <button type="submit" class="btn-primary">Save Payment</button>
        </div>
    </form>
</div>
<div id="modalOverlay" style="display: none; position: fixed; top: 0; left: 0; width:100%; height:100%; background: rgba(0,0,0,0.4); z-index: 999;" onclick="closeModal()"></div>

<!-- Table Matrix -->
<div class="table-container">
    <table class="matrix-table">
        <thead>
            <tr>
                <th style="text-align: left;">Reg No</th>
                <th style="text-align: left; min-width: 150px;">Student Name</th>
                <th style="text-align: left;">Due Fee</th>
                <th>Jan</th>
                <th>Feb</th>
                <th>Mar</th>
                <th>Apr</th>
                <th>May</th>
                <th>Jun</th>
                <th>Jul</th>
                <th>Aug</th>
                <th>Sep</th>
                <th>Oct</th>
                <th>Nov</th>
                <th>Dec</th>
            </tr>
        </thead>
        <tbody>
            <% if (students.length > 0) { %>
                <% students.forEach(s => { %>
                    <% 
                        const expectedFee = s.custom_monthly_fee !== null ? s.custom_monthly_fee : (s.default_monthly_fee || 0);
                        const studentPayments = paymentMap[s.id] || {};
                    %>
                    <tr>
                        <td style="font-weight: 600; text-align: left;"><%= s.reg_no %></td>
                        <td style="text-align: left;"><%= s.name %></td>
                        <td style="text-align: left; font-weight: 600; color: <%= s.has_concession ? '#b91c1c' : '#1e293b' %>">
                            <%= expectedFee.toLocaleString() %>
                        </td>
                        
                        <% for (let m = 1; m <= 12; m++) { %>
                            <% const amtPaid = studentPayments[m]; %>
                            <% if (amtPaid !== undefined && amtPaid > 0) { %>
                                <td class="status-cell status-paid cell-amount" onclick="openPaymentModal('<%= s.id %>', '<%= s.name %>', <%= m %>, <%= amtPaid %>, <%= expectedFee %>)">
                                    <%= amtPaid %>
                                </td>
                            <% } else { %>
                                <td class="status-cell status-unpaid" onclick="openPaymentModal('<%= s.id %>', '<%= s.name %>', <%= m %>, '', <%= expectedFee %>)">
                                    -
                                </td>
                            <% } %>
                        <% } %>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="15" style="text-align: center; color: #64748b;">No students found.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<script>
    function openPaymentModal(studentId, studentName, month, currentAmount, expectedFee) {
        const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
        document.getElementById('modalStudentId').value = studentId;
        document.getElementById('modalMonth').value = month;
        document.getElementById('modalAmount').value = currentAmount || expectedFee;
        document.getElementById('modalTitle').innerText = 'Pay Fee: ' + studentName + ' (' + months[month - 1] + ')';
        document.getElementById('modalExpectedFee').innerText = 'Expected Fee: PKR ' + expectedFee;
        
        document.getElementById('paymentModal').style.display = 'block';
        document.getElementById('modalOverlay').style.display = 'block';
    }
    
    function closeModal() {
        document.getElementById('paymentModal').style.display = 'none';
        document.getElementById('modalOverlay').style.display = 'none';
    }
</script>

<%- include('partials/footer') %>
