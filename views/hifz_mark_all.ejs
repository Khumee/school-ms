<%- include('partials/header') %>

<style>
    .urdu-text {
        font-family: 'Noto Nastaliq Urdu', 'Noto Serif', serif;
        direction: rtl;
    }
    .status-group {
        display: flex;
        gap: 0.25rem;
        background-color: #f1f5f9;
        padding: 0.2rem;
        border-radius: 8px;
        width: fit-content;
    }
    .btn-toggle-chip {
        border: none;
        background: none;
        padding: 0.35rem 0.65rem;
        font-size: 0.75rem;
        font-weight: 700;
        cursor: pointer;
        border-radius: 6px;
        transition: all 0.15s ease;
        color: #64748b;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }
    /* Vibrant toggle states */
    .btn-toggle-chip.active-recited {
        background-color: #10b981;
        color: #ffffff;
        box-shadow: 0 2px 4px rgba(16,185,129,0.3);
    }
    .btn-toggle-chip.active-nagha {
        background-color: #ef4444;
        color: #ffffff;
        box-shadow: 0 2px 4px rgba(239,68,68,0.3);
    }
    .btn-toggle-chip.active-absent {
        background-color: #f59e0b;
        color: #ffffff;
        box-shadow: 0 2px 4px rgba(245,158,11,0.3);
    }
    .btn-toggle-chip.active-leave {
        background-color: #3b82f6;
        color: #ffffff;
        box-shadow: 0 2px 4px rgba(59,130,246,0.3);
    }
    .grid-input-row {
        display: flex;
        gap: 0.35rem;
        align-items: center;
    }
    /* Greying states */
    .row-absent, .row-leave {
        background-color: #f1f5f9 !important;
        opacity: 0.55;
    }
    .row-absent input, .row-leave input,
    .row-absent button:not(.btn-toggle-chip), 
    .row-leave button:not(.btn-toggle-chip) {
        pointer-events: none;
        background-color: #cbd5e1 !important;
    }
    /* Column disabled states */
    .sabaq-disabled, .sabqi-disabled, .manzil-disabled {
        opacity: 0.4;
        pointer-events: none;
    }
    .sabaq-disabled input, .sabqi-disabled input, .manzil-disabled input {
        background-color: #e2e8f0 !important;
    }
</style>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-grid-3x3-gap-fill"></i> Quick Mark Hifz Matrix</h1>
    <a href="/hifz" class="btn-secondary"><i class="bi bi-arrow-left"></i> Back to Roster</a>
</div>

<div class="card" style="margin-bottom: 1.5rem; padding: 1.25rem;">
    <form action="/hifz/mark-all" method="GET" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
        <label for="date" style="font-weight: 600; color: #475569;"><i class="bi bi-calendar3"></i> Diary Date:</label>
        <input type="date" id="date" name="date" class="form-control" style="width: auto;" value="<%= today %>" onchange="this.form.submit()">
        <span style="color: #64748b; font-size: 0.9rem;">(Changing date will load entries for that day)</span>
    </form>
</div>

<% if (typeof req !== 'undefined' && req.query.success) { %>
    <div style="background-color: #ecfdf5; color: #065f46; padding: 1rem; border-radius: 6px; border: 1px solid #a7f3d0; margin-bottom: 1.5rem; font-weight: 600;">
        <i class="bi bi-check-circle-fill"></i> Hifz diary entries saved successfully for <%= today %>.
    </div>
<% } %>

<form action="/hifz/mark-all" method="POST">
    <input type="hidden" name="date" value="<%= today %>">

    <div style="display: flex; flex-direction: column; gap: 1.25rem;">
        <% if (students.length > 0) { %>
            <% students.forEach(s => { %>
                <% 
                    let rowClass = '';
                    let initialStatus = 'present';
                    if (s.is_absent) {
                        rowClass = 'row-absent';
                        initialStatus = 'absent';
                    } else if (s.sabaq_status === 'leave') {
                        rowClass = 'row-leave';
                        initialStatus = 'leave';
                    }

                    const sabaqStatus = s.sabaq_status || 'recited';
                    const sabqiStatus = s.sabqi_status || 'recited';
                    const manzilStatus = s.manzil_status || 'recited';
                    const isWaqafActive = s.is_in_waqaf > 0;
                %>
                <div id="row-<%= s.student_id %>" class="card student-diary-card <%= rowClass %>" style="padding: 1.25rem; border-left: 5px solid #3b82f6; transition: border-color 0.2s;">
                    <!-- Student Info & Attendance Header -->
                    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #f1f5f9; padding-bottom: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.75rem;">
                        <div>
                            <strong style="color: #0f172a; font-size: 1.05rem;"><%= s.student_name %></strong>
                            <span style="font-size: 0.8rem; color: #64748b; margin-left: 0.5rem;"><%= s.reg_no %> | <%= s.phase.label %></span>
                            <% if (isWaqafActive) { %>
                                <span class="status-cell" style="background-color: #fef3c7; color: #d97706; font-size: 0.75rem; padding: 0.15rem 0.4rem; font-weight: 600; margin-left: 0.5rem;"><i class="bi bi-lock-fill"></i> WAQAF REVISION ACTIVE</span>
                            <% } %>
                        </div>
                        <div class="status-group">
                            <button type="button" class="btn-toggle-chip <%= initialStatus === 'present' ? 'active-recited' : '' %>" onclick="selectAttendance('<%= s.student_id %>', 'present', this)" title="Present"><i class="bi bi-check-lg"></i> Present</button>
                            <button type="button" class="btn-toggle-chip <%= initialStatus === 'absent' ? 'active-absent' : '' %>" onclick="selectAttendance('<%= s.student_id %>', 'absent', this)" title="Absent"><i class="bi bi-person-x"></i> Absent</button>
                            <button type="button" class="btn-toggle-chip <%= initialStatus === 'leave' ? 'active-leave' : '' %>" onclick="selectAttendance('<%= s.student_id %>', 'leave', this)" title="Leave">Leave</button>
                        </div>
                        <input type="hidden" id="status-<%= s.student_id %>" name="entries[<%= s.student_id %>][sabaq_status]" value="<%= s.sabaq_status || 'recited' %>">
                        <input type="hidden" id="sabqi-status-<%= s.student_id %>" name="entries[<%= s.student_id %>][sabqi_status]" value="<%= s.sabqi_status || 'recited' %>">
                        <input type="hidden" id="manzil-status-<%= s.student_id %>" name="entries[<%= s.student_id %>][manzil_status]" value="<%= s.manzil_status || 'recited' %>">
                        <input type="hidden" id="absent-<%= s.student_id %>" name="entries[<%= s.student_id %>][is_absent]" value="<%= s.is_absent ? 'on' : 'off' %>">
                    </div>

                    <!-- Recitation Components: Sabaq, Sabqi, Manzil -->
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; align-items: start;">
                        <!-- Sabaq Section -->
                        <div class="sabaq-section" style="background-color: #eff6ff; border: 1px solid #dbeafe; border-radius: 8px; padding: 0.75rem; <%= isWaqafActive ? 'opacity: 0.55; pointer-events: none;' : '' %>">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                                <span style="font-weight: 700; color: #1e3a8a; font-size: 0.85rem;"><i class="bi bi-book"></i> Sabaq (New Lesson)</span>
                                <% if (!isWaqafActive) { %>
                                    <div class="status-group" style="padding: 0.1rem;">
                                        <button type="button" class="btn-toggle-chip <%= sabaqStatus === 'recited' ? 'active-recited' : '' %>" onclick="selectColStatus('<%= s.student_id %>', 'sabaq', 'recited', this)" style="padding: 0.2rem 0.5rem; font-size: 0.7rem;"><i class="bi bi-check-lg"></i> Recited</button>
                                        <button type="button" class="btn-toggle-chip <%= sabaqStatus === 'not_recited' ? 'active-nagha' : '' %>" onclick="selectColStatus('<%= s.student_id %>', 'sabaq', 'not_recited', this)" style="padding: 0.2rem 0.5rem; font-size: 0.7rem;"><i class="bi bi-x-lg"></i> Nagha</button>
                                    </div>
                                <% } else { %>
                                    <span style="font-size: 0.75rem; font-weight: 600; color: #b45309;"><i class="bi bi-shield-fill-exclamation"></i> Revision Break</span>
                                <% } %>
                            </div>

                            <div class="sabaq-inputs <%= (sabaqStatus === 'not_recited' || isWaqafActive) ? 'sabaq-disabled' : '' %>" style="display: flex; flex-direction: column; gap: 0.5rem;">
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <span style="font-size: 0.8rem; font-weight: 600; width: 40px;">Para:</span>
                                    <input type="number" name="entries[<%= s.student_id %>][sabaq_from_para]" placeholder="From" class="form-control" style="padding: 0.2rem; font-size: 0.8rem; width: 60px;" min="1" max="30"
                                           value="<%= s.sabaq_from_para || (s.prefill ? s.prefill.sabaq_from_para : '') %>">
                                    <span style="font-size: 0.8rem; color: #64748b;">to</span>
                                    <input type="number" name="entries[<%= s.student_id %>][sabaq_to_para]" placeholder="To" class="form-control" style="padding: 0.2rem; font-size: 0.8rem; width: 60px;" min="1" max="30"
                                           value="<%= s.sabaq_to_para || (s.prefill ? s.prefill.sabaq_to_para : '') %>">
                                </div>
                                <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                                    <span style="font-size: 0.8rem; font-weight: 600; width: 40px; color: #1e3a8a;">Start:</span>
                                    <span style="font-size: 0.8rem;">Page</span>
                                    <input type="number" id="from-page-<%= s.student_id %>" name="entries[<%= s.student_id %>][sabaq_from_page]" class="form-control" style="padding: 0.2rem; font-size: 0.8rem; width: 55px;" min="1" max="30"
                                           value="<%= s.sabaq_from_page || (s.prefill ? s.prefill.sabaq_from_page : 1) %>" onchange="calcTotalLines('<%= s.student_id %>')">
                                    <span style="font-size: 0.8rem;">Line</span>
                                    <input type="number" id="from-line-<%= s.student_id %>" name="entries[<%= s.student_id %>][sabaq_from_line]" class="form-control" style="padding: 0.2rem; font-size: 0.8rem; width: 55px;" min="1" max="16"
                                           value="<%= s.sabaq_from_line || (s.prefill ? s.prefill.sabaq_from_line : 1) %>" onchange="calcTotalLines('<%= s.student_id %>')">
                                </div>
                                <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                                    <span style="font-size: 0.8rem; font-weight: 600; width: 40px; color: #1e3a8a;">End:</span>
                                    <span style="font-size: 0.8rem;">Page</span>
                                    <input type="number" id="to-page-<%= s.student_id %>" name="entries[<%= s.student_id %>][sabaq_to_page]" class="form-control" style="padding: 0.2rem; font-size: 0.8rem; width: 55px;" min="1" max="30"
                                           value="<%= s.sabaq_to_page || (s.prefill ? s.prefill.sabaq_to_page : 1) %>" onchange="calcTotalLines('<%= s.student_id %>')">
                                    <span style="font-size: 0.8rem;">Line</span>
                                    <input type="number" id="to-line-<%= s.student_id %>" name="entries[<%= s.student_id %>][sabaq_to_line]" class="form-control" style="padding: 0.2rem; font-size: 0.8rem; width: 55px;" min="1" max="16"
                                           value="<%= s.sabaq_to_line || (s.prefill ? s.prefill.sabaq_to_line : 16) %>" onchange="calcTotalLines('<%= s.student_id %>')">
                                </div>
                                <div style="font-size: 0.8rem; font-weight: 700; color: #0284c7; margin-top: 0.15rem;">
                                    Total lines: <span id="total-lines-<%= s.student_id %>">--</span>
                                </div>
                            </div>
                        </div>

                        <!-- Sabqi Section -->
                        <div class="sabqi-section" style="background-color: #f0fdf4; border: 1px solid #dcfce7; border-radius: 8px; padding: 0.75rem;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                                <span style="font-weight: 700; color: #166534; font-size: 0.85rem;"><i class="bi bi-journal-text"></i> Sabqi (Recent Para)</span>
                                <div class="status-group" style="padding: 0.1rem;">
                                    <button type="button" class="btn-toggle-chip <%= sabqiStatus === 'recited' ? 'active-recited' : '' %>" onclick="selectColStatus('<%= s.student_id %>', 'sabqi', 'recited', this)" style="padding: 0.2rem 0.5rem; font-size: 0.7rem;"><i class="bi bi-check-lg"></i> Recited</button>
                                    <button type="button" class="btn-toggle-chip <%= sabqiStatus === 'not_recited' ? 'active-nagha' : '' %>" onclick="selectColStatus('<%= s.student_id %>', 'sabqi', 'not_recited', this)" style="padding: 0.2rem 0.5rem; font-size: 0.7rem;"><i class="bi bi-x-lg"></i> Nagha</button>
                                </div>
                            </div>

                            <div class="sabqi-inputs <%= sabqiStatus === 'not_recited' ? 'sabqi-disabled' : '' %>" style="display: flex; align-items: center; gap: 0.5rem; padding-top: 0.5rem;">
                                <span style="font-size: 0.8rem; font-weight: 600;">Para:</span>
                                <input type="number" name="entries[<%= s.student_id %>][sabqi_para]" placeholder="Para" class="form-control" style="padding: 0.2rem; font-size: 0.8rem; width: 65px;" min="1" max="30"
                                       value="<%= s.sabqi_para || (s.prefill ? s.prefill.sabqi_para : '') %>">
                            </div>
                        </div>

                        <!-- Manzil Section -->
                        <div class="manzil-section" style="background-color: #fffbeb; border: 1px solid #fef3c7; border-radius: 8px; padding: 0.75rem;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                                <span style="font-weight: 700; color: #854d0e; font-size: 0.85rem;"><i class="bi bi-bookmark-star"></i> Manzil (Revision)</span>
                                <div class="status-group" style="padding: 0.1rem;">
                                    <button type="button" class="btn-toggle-chip <%= manzilStatus === 'recited' ? 'active-recited' : '' %>" onclick="selectColStatus('<%= s.student_id %>', 'manzil', 'recited', this)" style="padding: 0.2rem 0.5rem; font-size: 0.7rem;"><i class="bi bi-check-lg"></i> Recited</button>
                                    <button type="button" class="btn-toggle-chip <%= manzilStatus === 'not_recited' ? 'active-nagha' : '' %>" onclick="selectColStatus('<%= s.student_id %>', 'manzil', 'not_recited', this)" style="padding: 0.2rem 0.5rem; font-size: 0.7rem;"><i class="bi bi-x-lg"></i> Nagha</button>
                                </div>
                            </div>

                            <div class="manzil-inputs <%= manzilStatus === 'not_recited' ? 'manzil-disabled' : '' %>" style="display: flex; gap: 0.4rem; padding-top: 0.5rem; flex-wrap: wrap; align-items: center;">
                                <span style="font-size: 0.8rem; font-weight: 600; width: 100%; margin-bottom: -0.15rem;">Revision Paras:</span>
                                <input type="number" name="entries[<%= s.student_id %>][manzil_para_1]" placeholder="P1" class="form-control" style="padding: 0.2rem; font-size: 0.8rem; width: 55px;" min="1" max="30"
                                       value="<%= s.manzil_para_1 || (s.prefill ? s.prefill.manzil_para_1 : '') %>">
                                <input type="number" name="entries[<%= s.student_id %>][manzil_para_2]" placeholder="P2" class="form-control" style="padding: 0.2rem; font-size: 0.8rem; width: 55px;" min="1" max="30"
                                       value="<%= s.manzil_para_2 || (s.prefill ? s.prefill.manzil_para_2 : '') %>">
                                <input type="number" name="entries[<%= s.student_id %>][manzil_para_3]" placeholder="P3" class="form-control" style="padding: 0.2rem; font-size: 0.8rem; width: 55px;" min="1" max="30"
                                       value="<%= s.manzil_para_3 || (s.prefill ? s.prefill.manzil_para_3 : '') %>">
                            </div>
                        </div>
                    </div>

                    <!-- Remarks Line -->
                    <div style="margin-top: 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
                        <span style="font-weight: 600; font-size: 0.8rem; color: #475569; width: 60px;">Remarks:</span>
                        <input type="text" name="entries[<%= s.student_id %>][teacher_remarks]" class="form-control" style="padding: 0.3rem 0.5rem; font-size: 0.85rem; flex: 1;" placeholder="Enter assessment notes or corrections..." value="<%= s.teacher_remarks || '' %>">
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="card" style="text-align: center; color: #64748b; padding: 2rem;">
                No active Hifz students enrolled.
            </div>
        <% } %>
    </div>

    <% if (students.length > 0) { %>
        <div style="margin-top: 1.5rem; display: flex; justify-content: flex-end; gap: 1rem;">
            <a href="/hifz" class="btn-secondary" style="height: 42px; display: inline-flex; align-items: center;">Cancel</a>
            <button type="submit" class="btn-primary" style="height: 42px; font-weight: 600; padding: 0 2rem;"><i class="bi bi-save"></i> Save All Entries</button>
        </div>
    <% } %>
</form>

<script>
    function calcTotalLines(studentId) {
        const fromPage = parseInt(document.getElementById('from-page-' + studentId).value) || 0;
        const toPage = parseInt(document.getElementById('to-page-' + studentId).value) || 0;
        const fromLine = parseInt(document.getElementById('from-line-' + studentId).value) || 0;
        const toLine = parseInt(document.getElementById('to-line-' + studentId).value) || 0;
        const display = document.getElementById('total-lines-' + studentId);

        if (fromPage > 0 && toPage >= fromPage) {
            const linesPerPage = 15; // standard Quran lines per page
            let total = 0;
            if (toPage === fromPage) {
                total = Math.max(0, toLine - fromLine + 1);
            } else {
                total = Math.max(0, (linesPerPage - fromLine + 1) + (toPage - fromPage - 1) * linesPerPage + toLine);
            }
            display.textContent = total;
        } else {
            display.textContent = '--';
        }
    }

    function selectColStatus(studentId, colType, status, btn) {
        const row = document.getElementById('row-' + studentId);
        
        // Reset toggles in this group
        const group = btn.parentElement;
        group.querySelectorAll('.btn-toggle-chip').forEach(b => {
            b.className = 'btn-toggle-chip';
        });

        // Set status hidden input
        const statusInput = document.getElementById(colType + '-status-' + studentId) || document.getElementById('status-' + studentId);
        statusInput.value = status;

        const targetDiv = row.querySelector('.' + colType + '-inputs');

        if (status === 'recited') {
            btn.classList.add('active-recited');
            if (targetDiv) targetDiv.classList.remove(colType + '-disabled');
        } else {
            btn.classList.add('active-nagha');
            if (targetDiv) targetDiv.classList.add(colType + '-disabled');
        }
    }

    function selectAttendance(studentId, status, btn) {
        const row = document.getElementById('row-' + studentId);
        
        // Remove old row classes
        row.classList.remove('row-absent', 'row-leave');

        // Reset toggles in this group
        const group = btn.parentElement;
        group.querySelectorAll('.btn-toggle-chip').forEach(b => {
            b.className = 'btn-toggle-chip';
        });

        const absentInput = document.getElementById('absent-' + studentId);
        const sabaqStatusInput = document.getElementById('status-' + studentId);
        const sabqiStatusInput = document.getElementById('sabqi-status-' + studentId);
        const manzilStatusInput = document.getElementById('manzil-status-' + studentId);

        if (status === 'present') {
            btn.classList.add('active-recited');
            absentInput.value = 'off';
            
            // Restore hidden values to inputs
            sabaqStatusInput.value = sabaqStatusInput.getAttribute('data-prev') || 'recited';
            sabqiStatusInput.value = sabqiStatusInput.getAttribute('data-prev') || 'recited';
            manzilStatusInput.value = manzilStatusInput.getAttribute('data-prev') || 'recited';

            // Re-apply sub-column disabled states
            const sabaqDiv = row.querySelector('.sabaq-inputs');
            if (sabaqStatusInput.value === 'not_recited') {
                sabaqDiv.classList.add('sabaq-disabled');
            } else {
                sabaqDiv.classList.remove('sabaq-disabled');
            }

            const sabqiDiv = row.querySelector('.sabqi-inputs');
            if (sabqiStatusInput.value === 'not_recited') {
                sabqiDiv.classList.add('sabqi-disabled');
            } else {
                sabqiDiv.classList.remove('sabqi-disabled');
            }

            const manzilDiv = row.querySelector('.manzil-inputs');
            if (manzilStatusInput.value === 'not_recited') {
                manzilDiv.classList.add('manzil-disabled');
            } else {
                manzilDiv.classList.remove('manzil-disabled');
            }
        } else if (status === 'absent') {
            btn.classList.add('active-absent');
            row.classList.add('row-absent');
            absentInput.value = 'on';
        } else if (status === 'leave') {
            btn.classList.add('active-leave');
            row.classList.add('row-leave');
            absentInput.value = 'off';
            
            // Backup previous statuses before setting them to leave
            sabaqStatusInput.setAttribute('data-prev', sabaqStatusInput.value);
            sabqiStatusInput.setAttribute('data-prev', sabqiStatusInput.value);
            manzilStatusInput.setAttribute('data-prev', manzilStatusInput.value);

            sabaqStatusInput.value = 'leave';
            sabqiStatusInput.value = 'leave';
            manzilStatusInput.value = 'leave';
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        const rows = document.querySelectorAll('tr[id^="row-"]');
        rows.forEach(row => {
            const studentId = row.id.split('-')[1];
            calcTotalLines(studentId);
        });
    });
</script>

<%- include('partials/footer') %>
