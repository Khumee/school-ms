<%- include('partials/header') %>

<style>
    .urdu-text {
        font-family: 'Noto Nastaliq Urdu', 'Noto Serif', serif;
        direction: rtl;
    }
    .quality-select {
        border-radius: 4px;
        padding: 0.25rem;
        font-size: 0.9rem;
    }
    .absent-row {
        background-color: #fcf2f2 !important;
        opacity: 0.8;
    }
    .absent-row input:not(.absent-check), 
    .absent-row select {
        pointer-events: none;
        background-color: #e2e8f0;
    }
</style>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-grid-3x3-gap-fill"></i> Quick Mark Hifz Matrix</h1>
    <a href="/hifz" class="btn-secondary"><i class="bi bi-arrow-left"></i> Back to Roster</a>
</div>

<div class="card" style="margin-bottom: 1.5rem; padding: 1.25rem;">
    <form action="/hifz/mark-all" method="GET" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
        <label for="date" style="font-weight: 600; color: #475569;"><i class="bi bi-calendar3"></i> Diary Date:</label>
        <input type="date" id="date" name="date" class="form-control" style="width: auto;" value="<%= today %>" onchange="this.form.submit()">
        <span style="color: #64748b; font-size: 0.9rem;">(Changing date will load entries for that day)</span>
    </form>
</div>

<% if (typeof req !== 'undefined' && req.query.success) { %>
    <div style="background-color: #ecfdf5; color: #065f46; padding: 1rem; border-radius: 6px; border: 1px solid #a7f3d0; margin-bottom: 1.5rem; font-weight: 600;">
        <i class="bi bi-check-circle-fill"></i> Hifz diary entries saved successfully for <%= today %>.
    </div>
<% } %>

<form action="/hifz/mark-all" method="POST">
    <input type="hidden" name="date" value="<%= today %>">

    <div class="table-container" style="overflow-x: auto;">
        <table style="min-width: 1100px;">
            <thead>
                <tr>
                    <th style="width: 50px; text-align: center;">Absent</th>
                    <th style="width: 180px;">Student</th>
                    <th style="width: 80px;">Phase</th>
                    
                    <!-- Sabaq Column Group -->
                    <th style="background-color: #eff6ff; border-left: 2px solid #3b82f6; width: 280px; text-align: center;">Sabaq (New Lesson)</th>
                    
                    <!-- Sabqi Column Group -->
                    <th style="background-color: #f0fdf4; border-left: 2px solid #22c55e; width: 220px; text-align: center;">Sabqi (Recent Lessons)</th>
                    
                    <!-- Manzil Column Group -->
                    <th style="background-color: #fffbeb; border-left: 2px solid #eab308; width: 260px; text-align: center;">Manzil (Revision)</th>
                    
                    <th>Remarks</th>
                </tr>
            </thead>
            <tbody>
                <% if (students.length > 0) { %>
                    <% students.forEach(s => { %>
                        <tr id="row-<%= s.student_id %>" class="<%= s.is_absent ? 'absent-row' : '' %>">
                            <!-- Absent -->
                            <td style="text-align: center; vertical-align: middle;">
                                <input type="checkbox" name="entries[<%= s.student_id %>][is_absent]" class="absent-check" style="transform: scale(1.3);" 
                                       <%= s.is_absent ? 'checked' : '' %> onchange="toggleAbsent('<%= s.student_id %>')">
                            </td>
                            
                            <!-- Student details -->
                            <td>
                                <strong style="color: #1e293b;"><%= s.student_name %></strong>
                                <div style="font-size: 0.8rem; color: #64748b;"><%= s.reg_no %> | <%= s.class_name %></div>
                            </td>
                            
                            <!-- Phase -->
                            <td>
                                <span style="font-size: 0.8rem; font-weight: 600; color: #475569; display: block; text-align: center; background-color: #f1f5f9; padding: 0.2rem 0.4rem; border-radius: 4px;">
                                    <%= s.phase.label %>
                                </span>
                            </td>

                            <!-- SABAQ -->
                            <td style="background-color: #f8fafc; border-left: 2px solid #3b82f6;">
                                <div style="display: flex; gap: 0.4rem; align-items: center; margin-bottom: 0.25rem;">
                                    <select name="entries[<%= s.student_id %>][sabaq_status]" class="form-control" style="padding: 0.25rem; font-size: 0.85rem; width: 90px;">
                                        <option value="recited" <%= s.sabaq_status === 'recited' ? 'selected' : (s.prefill ? 'selected' : '') %>>Recited</option>
                                        <option value="not_recited" <%= s.sabaq_status === 'not_recited' ? 'selected' : '' %>>Not Recited</option>
                                        <option value="memorized_no_recite" <%= s.sabaq_status === 'memorized_no_recite' ? 'selected' : '' %>>Memorized, No Recite</option>
                                    </select>
                                    
                                    <input type="number" name="entries[<%= s.student_id %>][sabaq_para]" placeholder="Para" class="form-control" style="padding: 0.25rem; font-size: 0.85rem; width: 50px;" min="1" max="30"
                                           value="<%= s.sabaq_para || (s.prefill ? s.prefill.sabaq_para : '') %>">

                                    <input type="number" name="entries[<%= s.student_id %>][sabaq_lines]" placeholder="Lines" class="form-control" style="padding: 0.25rem; font-size: 0.85rem; width: 55px;" min="1" max="30"
                                           value="<%= s.sabaq_lines || (s.prefill ? s.prefill.sabaq_lines : '') %>">
                                </div>
                                
                                <div style="display: flex; gap: 0.4rem;">
                                    <select name="entries[<%= s.student_id %>][sabaq_quality]" class="form-control quality-select" style="padding: 0.25rem; font-size: 0.85rem; flex: 1;">
                                        <option value="">-- Sabaq Quality --</option>
                                        <option value="Excellent" <%= s.sabaq_quality === 'Excellent' ? 'selected' : '' %>>ممتاز (Excellent)</option>
                                        <option value="Good" <%= s.sabaq_quality === 'Good' ? 'selected' : '' %>>جید جداً (Good)</option>
                                        <option value="Average" <%= s.sabaq_quality === 'Average' ? 'selected' : '' %>>جید (Average)</option>
                                        <option value="Weak" <%= s.sabaq_quality === 'Weak' ? 'selected' : '' %>>مقبول (Weak)</option>
                                        <option value="Very Weak" <%= s.sabaq_quality === 'Very Weak' ? 'selected' : '' %>>غیر مقبول (Very Weak)</option>
                                    </select>
                                    
                                    <select name="entries[<%= s.student_id %>][sabaq_tajweed]" class="form-control" style="padding: 0.25rem; font-size: 0.85rem; width: 85px;">
                                        <option value="clear" <%= s.sabaq_tajweed === 'clear' ? 'selected' : '' %>>Tajweed OK</option>
                                        <option value="mistakes" <%= s.sabaq_tajweed === 'mistakes' ? 'selected' : '' %>>Mistakes</option>
                                    </select>
                                </div>
                            </td>

                            <!-- SABQI -->
                            <td style="background-color: #fcfdfd; border-left: 2px solid #22c55e;">
                                <div style="display: flex; gap: 0.4rem; align-items: center; margin-bottom: 0.25rem;">
                                    <select name="entries[<%= s.student_id %>][sabqi_status]" class="form-control" style="padding: 0.25rem; font-size: 0.85rem; width: 90px;">
                                        <option value="recited" <%= s.sabqi_status === 'recited' ? 'selected' : (s.prefill ? 'selected' : '') %>>Recited</option>
                                        <option value="not_recited" <%= s.sabqi_status === 'not_recited' ? 'selected' : '' %>>Not Recited</option>
                                    </select>
                                    
                                    <input type="number" name="entries[<%= s.student_id %>][sabqi_para]" placeholder="Para" class="form-control" style="padding: 0.25rem; font-size: 0.85rem; width: 55px;" min="1" max="30"
                                           value="<%= s.sabqi_para || (s.prefill ? s.prefill.sabqi_para : '') %>">
                                </div>
                                
                                <select name="entries[<%= s.student_id %>][sabqi_quality]" class="form-control quality-select" style="padding: 0.25rem; font-size: 0.85rem; width: 100%;">
                                    <option value="">-- Sabqi Quality --</option>
                                    <option value="Excellent" <%= s.sabqi_quality === 'Excellent' ? 'selected' : '' %>>ممتاز (Excellent)</option>
                                    <option value="Good" <%= s.sabqi_quality === 'Good' ? 'selected' : '' %>>جید جداً (Good)</option>
                                    <option value="Average" <%= s.sabqi_quality === 'Average' ? 'selected' : '' %>>جید (Average)</option>
                                    <option value="Weak" <%= s.sabqi_quality === 'Weak' ? 'selected' : '' %>>مقبول (Weak)</option>
                                    <option value="Very Weak" <%= s.sabqi_quality === 'Very Weak' ? 'selected' : '' %>>غیر مقبول (Very Weak)</option>
                                </select>
                            </td>

                            <!-- MANZIL -->
                            <td style="background-color: #fefdfb; border-left: 2px solid #eab308;">
                                <div style="display: flex; gap: 0.3rem; align-items: center; margin-bottom: 0.25rem;">
                                    <select name="entries[<%= s.student_id %>][manzil_status]" class="form-control" style="padding: 0.25rem; font-size: 0.85rem; width: 90px;">
                                        <option value="recited" <%= s.manzil_status === 'recited' ? 'selected' : (s.prefill ? 'selected' : '') %>>Recited</option>
                                        <option value="not_recited" <%= s.manzil_status === 'not_recited' ? 'selected' : '' %>>Not Recited</option>
                                    </select>
                                    
                                    <input type="number" name="entries[<%= s.student_id %>][manzil_from_para]" placeholder="From" class="form-control" style="padding: 0.25rem; font-size: 0.85rem; width: 50px;" min="1" max="30"
                                           value="<%= s.manzil_from_para || (s.prefill ? s.prefill.manzil_from_para : '') %>">
                                    <span style="font-size: 0.8rem; color: #64748b;">to</span>
                                    <input type="number" name="entries[<%= s.student_id %>][manzil_to_para]" placeholder="To" class="form-control" style="padding: 0.25rem; font-size: 0.85rem; width: 50px;" min="1" max="30"
                                           value="<%= s.manzil_to_para || (s.prefill ? s.prefill.manzil_to_para : '') %>">
                                </div>
                                
                                <select name="entries[<%= s.student_id %>][manzil_quality]" class="form-control quality-select" style="padding: 0.25rem; font-size: 0.85rem; width: 100%;">
                                    <option value="">-- Manzil Quality --</option>
                                    <option value="Excellent" <%= s.manzil_quality === 'Excellent' ? 'selected' : '' %>>ممتاز (Excellent)</option>
                                    <option value="Good" <%= s.manzil_quality === 'Good' ? 'selected' : '' %>>جید جداً (Good)</option>
                                    <option value="Average" <%= s.manzil_quality === 'Average' ? 'selected' : '' %>>جید (Average)</option>
                                    <option value="Weak" <%= s.manzil_quality === 'Weak' ? 'selected' : '' %>>مقبول (Weak)</option>
                                    <option value="Very Weak" <%= s.manzil_quality === 'Very Weak' ? 'selected' : '' %>>غیر مقبول (Very Weak)</option>
                                </select>
                            </td>

                            <!-- Remarks -->
                            <td>
                                <input type="text" name="entries[<%= s.student_id %>][teacher_remarks]" class="form-control" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;" placeholder="Remarks..." value="<%= s.teacher_remarks || '' %>">
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="7" style="text-align: center; color: #64748b; padding: 2rem;">
                            No active Hifz students.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <% if (students.length > 0) { %>
        <div style="margin-top: 1.5rem; display: flex; justify-content: flex-end; gap: 1rem;">
            <a href="/hifz" class="btn-secondary" style="height: 42px; display: inline-flex; align-items: center;">Cancel</a>
            <button type="submit" class="btn-primary" style="height: 42px; font-weight: 600; padding: 0 2rem;"><i class="bi bi-save"></i> Save All Entries</button>
        </div>
    <% } %>
</form>

<script>
    function toggleAbsent(studentId) {
        const row = document.getElementById('row-' + studentId);
        const check = row.querySelector('.absent-check');
        if (check.checked) {
            row.classList.add('absent-row');
        } else {
            row.classList.remove('absent-row');
        }
    }
</script>

<%- include('partials/footer') %>
