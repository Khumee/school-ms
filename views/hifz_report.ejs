<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-printer"></i> Hifz Weekly Progress Report</h1>
    <div style="display: flex; gap: 0.75rem;">
        <a href="/hifz" class="btn-secondary"><i class="bi bi-arrow-left"></i> Back to Roster</a>
        <button onclick="window.print()" class="btn-primary"><i class="bi bi-printer-fill"></i> Print Report</button>
    </div>
</div>

<div class="card" style="padding: 1.5rem; margin-bottom: 2rem;">
    <div style="text-align: center; margin-bottom: 1.5rem;">
        <h2 style="margin: 0; color: #0f172a;">Weekly Quran Memorization Assessment</h2>
        <p style="color: #64748b; margin: 0.25rem 0 0 0;">Report generated for week starting: <strong><%= weekAgoStr %></strong></p>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Student Details</th>
                    <th>Class</th>
                    <th>Current Para</th>
                    <th>Pace (Avg Lines/Day)</th>
                    <th>Attendance (Days Logged)</th>
                    <th>Alert Status</th>
                </tr>
            </thead>
            <tbody>
                <% if (students.length > 0) { %>
                    <% students.forEach(s => { %>
                        <% 
                            const isCritical = s.alarms.some(a => a.severity === 'critical');
                            const isWarning = s.alarms.some(a => a.severity === 'warning' || a.severity === 'alert');
                        %>
                        <tr>
                            <td>
                                <strong style="color: #0f172a; display: block;"><%= s.student_name %></strong>
                                <small style="color: #64748b;"><%= s.reg_no %></small>
                            </td>
                            <td><%= s.class_name %></td>
                            <td style="font-weight: bold; color: #1e3a8a; text-align: center;"><%= s.current_para || '-' %></td>
                            <td>
                                <%= s.avg_lines ? `${parseFloat(s.avg_lines).toFixed(1)} lines/day` : 'No lessons recited' %>
                            </td>
                            <td>
                                <%= s.days_logged %> days active
                                <% if (s.days_absent > 0) { %>
                                    <span style="color: #dc2626; font-size: 0.8rem; display: block;">(<%= s.days_absent %> days absent)</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (isCritical) { %>
                                    <span class="status-cell status-unpaid" style="font-size: 0.75rem;"><i class="bi bi-exclamation-octagon-fill"></i> CRITICAL ALARM</span>
                                <% } else if (isWarning) { %>
                                    <span class="status-cell" style="background-color: #fffbeb; color: #b45309; font-size: 0.75rem; border: 1px solid #fde68a;"><i class="bi bi-exclamation-triangle-fill"></i> WARNING</span>
                                <% } else { %>
                                    <span class="status-cell status-paid" style="font-size: 0.75rem;"><i class="bi bi-check-circle"></i> CLEAR</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" style="text-align: center; color: #64748b; padding: 2rem;">No students found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<style>
    @media print {
        header, footer, nav, .btn-primary, .btn-secondary, .section-header {
            display: none !important;
        }
        .card {
            border: none !important;
            box-shadow: none !important;
            padding: 0 !important;
        }
        body {
            background-color: white !important;
            color: black !important;
        }
    }
</style>

<%- include('partials/footer') %>
