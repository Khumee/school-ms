<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-calendar-check"></i> Hifz Holiday Calendar</h1>
    <a href="/hifz" class="btn-secondary"><i class="bi bi-arrow-left"></i> Back to Roster</a>
</div>

<div style="display: grid; grid-template-columns: 1fr 2fr; gap: 1.5rem; margin-bottom: 2rem;">
    <!-- Left Column: Add Holiday Form -->
    <div class="card" style="padding: 1.5rem; height: fit-content;">
        <h3 style="margin-top: 0; margin-bottom: 1rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem; color: #0f172a;"><i class="bi bi-calendar-plus"></i> Add School Holiday</h3>
        
        <form action="/hifz/calendar" method="POST">
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="holiday_date" style="font-weight: 600;">Holiday Date</label>
                <input type="date" name="holiday_date" id="holiday_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>
            
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label for="description" style="font-weight: 600;">Description / Reason</label>
                <input type="text" name="description" id="description" class="form-control" placeholder="e.g. Eid-ul-Adha, Winter Break, Sunday" required>
            </div>

            <button type="submit" class="btn-primary" style="width: 100%; height: 42px; font-weight: 600;"><i class="bi bi-plus-circle"></i> Add Holiday</button>
        </form>
    </div>

    <!-- Right Column: Holidays List -->
    <div class="card" style="padding: 1.5rem;">
        <h3 style="margin-top: 0; margin-bottom: 1rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem; color: #0f172a;"><i class="bi bi-calendar3"></i> Scheduled Holidays</h3>
        
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Day</th>
                        <th>Description</th>
                        <th style="width: 100px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (holidays.length > 0) { %>
                        <% holidays.forEach(h => { %>
                            <tr>
                                <td style="font-weight: 600;"><%= new Date(h.holiday_date).toLocaleDateString() %></td>
                                <td><%= new Date(h.holiday_date).toLocaleDateString(undefined, {weekday: 'long'}) %></td>
                                <td><%= h.description || '-' %></td>
                                <td>
                                    <form action="/hifz/calendar/delete/<%= h.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this holiday?')">
                                        <button type="submit" class="btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.8rem; color: #dc2626; border-color: #fca5a5;">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% else { %>
                        <tr>
                            <td colspan="4" style="text-align: center; color: #64748b; padding: 2rem;">No holidays registered yet.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
