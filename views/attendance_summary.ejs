<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-calendar2-range"></i> Employee Attendance Summary</h1>
    <div style="display: flex; gap: 0.5rem;">
        <a href="/attendance/employees" class="btn-secondary"><i class="bi bi-arrow-left"></i> Mark Attendance</a>
    </div>
</div>

<!-- Filter Panel -->
<div class="card" style="margin-bottom: 1.5rem; padding: 1.25rem 1.5rem;">
    <h3 style="margin-bottom: 1rem; color: var(--primary-color);"><i class="bi bi-funnel-fill"></i> Filter Attendance Period</h3>
    <form action="/attendance/employees/summary" method="GET" style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;">
        <div class="form-group" style="flex: 1 1 200px; min-width: 150px;">
            <label for="filterType">Preset Range</label>
            <select name="filterType" id="filterType" class="form-control" onchange="toggleCustomDates(this.value)">
                <option value="month"  <%= filterType === 'month'  ? 'selected' : '' %>>Current Month</option>
                <option value="today"  <%= filterType === 'today'  ? 'selected' : '' %>>Today (One Day)</option>
                <option value="week"   <%= filterType === 'week'   ? 'selected' : '' %>>This Week (Mon-Sun)</option>
                <option value="custom" <%= filterType === 'custom' ? 'selected' : '' %>>Custom Date Range</option>
            </select>
        </div>
        <div class="form-group" id="custom-start-group" style="flex: 1 1 180px; min-width: 130px; <%= filterType !== 'custom' ? 'display: none;' : '' %>">
            <label for="startDate">Start Date</label>
            <input type="date" name="startDate" id="startDate" class="form-control" value="<%= startDate %>">
        </div>
        <div class="form-group" id="custom-end-group" style="flex: 1 1 180px; min-width: 130px; <%= filterType !== 'custom' ? 'display: none;' : '' %>">
            <label for="endDate">End Date</label>
            <input type="date" name="endDate" id="endDate" class="form-control" value="<%= endDate %>">
        </div>
        <div style="flex: 0 0 auto;">
            <button type="submit" class="btn-primary" style="height: 38px; display: inline-flex; align-items: center;"><i class="bi bi-search"></i> Apply Filter</button>
            <a href="/attendance/employees/summary" class="btn-secondary" style="height: 38px; display: inline-flex; align-items: center; margin-left: 0.5rem;">Reset</a>
        </div>
    </form>
</div>

<!-- Info banner -->
<div style="background-color: #f8fafc; border-left: 4px solid var(--primary-color); color: #334155; padding: 0.85rem 1.25rem; border-radius: 6px; margin-bottom: 1.5rem; font-weight: 500; font-size: 0.95rem; display: flex; justify-content: space-between; align-items: center;">
    <span>
        <i class="bi bi-clock-history" style="margin-right: 0.5rem; color: var(--primary-color);"></i>
        Showing summary from <strong><%= new Date(startDate).toLocaleDateString('en-GB') %></strong> to <strong><%= new Date(endDate).toLocaleDateString('en-GB') %></strong>.
    </span>
    <span class="status-cell status-paid" style="text-transform: uppercase; font-size: 0.75rem;">Range: <%= filterType %></span>
</div>

<!-- Summary Table -->
<div class="card">
    <div class="table-container" style="border: none;">
        <table>
            <thead>
                <tr>
                    <th style="text-align: left;">Employee Name</th>
                    <th style="text-align: left;">Designation</th>
                    <th style="text-align: center;">Presents</th>
                    <th style="text-align: center;">Absents</th>
                    <th style="text-align: center;">Leaves</th>
                    <th style="text-align: center;">Total Days</th>
                    <th style="text-align: right;">Attendance Rate</th>
                </tr>
            </thead>
            <tbody>
                <% if (summary.length > 0) { %>
                    <% summary.forEach(e => { %>
                        <%
                            const presents  = parseInt(e.presents  || 0);
                            const absents   = parseInt(e.absents   || 0);
                            const leaves    = parseInt(e.leaves    || 0);
                            const totalDays = presents + absents + leaves;
                            const rate      = totalDays > 0 ? Math.round((presents / totalDays) * 100) : 0;
                            let rateColor   = '#16a34a';
                            if (rate < 75) rateColor = '#d97706';
                            if (rate < 50) rateColor = '#dc2626';
                        %>
                        <tr>
                            <td style="font-weight: 600; text-align: left;">
                                <a href="#"
                                   onclick="openDetail('<%= e.employee_id %>', '<%= e.name.replace(/'/g, "\\'") %>', '<%= e.designation.replace(/'/g, "\\'") %>'); return false;"
                                   style="color: #2563eb; text-decoration: none; border-bottom: 1px dashed #93c5fd; cursor: pointer;"
                                   title="Click to view full attendance log">
                                    <i class="bi bi-person-lines-fill" style="font-size:0.8rem; margin-right:0.3rem; opacity:0.6;"></i><%= e.name %>
                                </a>
                            </td>
                            <td style="text-align: left; color: #475569;"><%= e.designation %></td>
                            <td style="text-align: center; font-weight: 700; color: #16a34a;"><%= presents %></td>
                            <td style="text-align: center; font-weight: 700; color: #dc2626;"><%= absents %></td>
                            <td style="text-align: center; font-weight: 700; color: #d97706;"><%= leaves %></td>
                            <td style="text-align: center; font-weight: 600; color: #475569;"><%= totalDays %></td>
                            <td style="text-align: right;">
                                <div style="display: inline-flex; align-items: center; gap: 0.5rem; justify-content: flex-end; width: 100%;">
                                    <div style="width: 70px; background-color: #e2e8f0; height: 8px; border-radius: 4px; overflow: hidden; display: inline-block;">
                                        <div style="width: <%= rate %>%; background-color: <%= rateColor %>; height: 100%;"></div>
                                    </div>
                                    <strong style="color: <%= rateColor %>; font-size: 0.95rem; width: 42px; text-align: right;"><%= rate %>%</strong>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="7" style="text-align: center; color: #64748b; padding: 2rem;">No active employees found to display summary.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- ===== Detail Drawer ===== -->
<div id="detailBackdrop" onclick="closeDetail()" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:999;"></div>

<div id="detailDrawer" style="display:none; position:fixed; top:0; right:0; height:100%; width:min(520px,100vw); background:#fff; z-index:1000; box-shadow:-6px 0 28px rgba(0,0,0,0.18); flex-direction:column; overflow:hidden;">

    <!-- Drawer Header -->
    <div style="padding:1.5rem; border-bottom:1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:flex-start; background:linear-gradient(135deg,#1e3a8a 0%,#2563eb 100%); color:#fff; flex-shrink:0;">
        <div>
            <h2 id="drawerName" style="margin:0; font-size:1.15rem; font-weight:700;"></h2>
            <p id="drawerDesig" style="margin:0.3rem 0 0; font-size:0.82rem; opacity:0.75;"></p>
        </div>
        <button onclick="closeDetail()" style="background:rgba(255,255,255,0.18); border:none; color:#fff; border-radius:50%; width:34px; height:34px; font-size:1.2rem; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0;">&times;</button>
    </div>

    <!-- Loading state -->
    <div id="drawerLoading" style="padding:3rem; text-align:center; color:#64748b; flex-shrink:0;">
        <div style="border:4px solid #e2e8f0; border-top:4px solid #2563eb; border-radius:50%; width:36px; height:36px; animation:spin 1s linear infinite; margin:0 auto 1rem;"></div>
        Loading attendance records…
    </div>

    <!-- Content -->
    <div id="drawerContent" style="display:none; flex:1; overflow-y:auto; flex-direction:column;">

        <!-- Stats bar -->
        <div id="drawerStats" style="display:flex; border-bottom:1px solid #e2e8f0; background:#f8fafc; flex-shrink:0;"></div>

        <!-- Records table -->
        <table style="width:100%; border-collapse:collapse; font-size:0.88rem;">
            <thead>
                <tr style="background:#f1f5f9; position:sticky; top:0; z-index:2;">
                    <th style="padding:0.7rem 1rem; text-align:left; font-weight:600; color:#475569; border-bottom:2px solid #e2e8f0;">Date</th>
                    <th style="padding:0.7rem 0.5rem; text-align:center; font-weight:600; color:#475569; border-bottom:2px solid #e2e8f0;">Day</th>
                    <th style="padding:0.7rem 0.5rem; text-align:center; font-weight:600; color:#475569; border-bottom:2px solid #e2e8f0;">Status</th>
                    <th style="padding:0.7rem 1rem; text-align:center; font-weight:600; color:#475569; border-bottom:2px solid #e2e8f0;">Edit</th>
                </tr>
            </thead>
            <tbody id="drawerTableBody"></tbody>
        </table>

        <div id="drawerEmpty" style="display:none; padding:3rem; text-align:center; color:#94a3b8;">
            <i class="bi bi-calendar-x" style="font-size:2.5rem; display:block; margin-bottom:0.75rem;"></i>
            No attendance records found.
        </div>
    </div>
</div>

<style>
@keyframes spin    { 0%{transform:rotate(0deg)} 100%{transform:rotate(360deg)} }
@keyframes slideIn { from{transform:translateX(100%)} to{transform:translateX(0)} }
#detailDrawer.open  { animation: slideIn 0.28s ease-out forwards; }
.drawer-stat        { flex:1; padding:0.9rem 0.5rem; text-align:center; border-right:1px solid #e2e8f0; }
.drawer-stat:last-child { border-right:none; }
.drawer-stat .ds-val { font-size:1.5rem; font-weight:700; display:block; }
.drawer-stat .ds-lbl { font-size:0.7rem; text-transform:uppercase; letter-spacing:0.06em; color:#64748b; display:block; margin-top:0.2rem; }
.drawer-row:hover   { background:#f8fafc; }
.edit-btn { display:inline-flex; align-items:center; gap:0.3rem; font-size:0.78rem; color:#2563eb; text-decoration:none; border:1px solid #bfdbfe; background:#eff6ff; padding:0.22rem 0.6rem; border-radius:6px; font-weight:600; transition:background 0.15s, transform 0.1s; }
.edit-btn:hover { background:#dbeafe; transform:translateY(-1px); }
</style>

<script>
const DAYS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
let currentEmpId = null;

const STATUS_CFG = {
    present: { bg:'#d1fae5', color:'#065f46', label:'Present', btnBg:'#10b981', btnColor:'#fff' },
    absent:  { bg:'#fee2e2', color:'#991b1b', label:'Absent',  btnBg:'#ef4444', btnColor:'#fff' },
    leave:   { bg:'#fef3c7', color:'#92400e', label:'Leave',   btnBg:'#f59e0b', btnColor:'#fff' }
};

function statusBadge(status) {
    const s = STATUS_CFG[status] || { bg:'#f1f5f9', color:'#64748b', label: status || '—' };
    return `<span id="badge_${status}" style="padding:0.2rem 0.65rem;border-radius:9999px;font-size:0.78rem;font-weight:600;background:${s.bg};color:${s.color};">${s.label}</span>`;
}

function openDetail(empId, name, designation) {
    currentEmpId = empId;
    document.getElementById('drawerName').textContent  = name;
    document.getElementById('drawerDesig').textContent = designation;
    document.getElementById('drawerLoading').style.display = 'block';
    document.getElementById('drawerContent').style.display = 'none';

    document.getElementById('detailBackdrop').style.display = 'block';
    const drawer = document.getElementById('detailDrawer');
    drawer.style.display = 'flex';
    drawer.classList.add('open');

    loadHistory();
}

function loadHistory() {
    document.getElementById('drawerLoading').style.display = 'block';
    document.getElementById('drawerContent').style.display = 'none';

    fetch(`/attendance/employees/${currentEmpId}/history?full=1`)
        .then(r => r.json())
        .then(data => {
            document.getElementById('drawerLoading').style.display = 'none';
            const content = document.getElementById('drawerContent');
            content.style.display = 'flex';

            const records  = data.history || [];
            const presents = records.filter(r => r.status === 'present').length;
            const absents  = records.filter(r => r.status === 'absent').length;
            const leaves   = records.filter(r => r.status === 'leave').length;
            const total    = records.length;
            const rate     = total > 0 ? Math.round((presents / total) * 100) : 0;
            const rateCol  = rate >= 75 ? '#16a34a' : rate >= 50 ? '#d97706' : '#dc2626';

            document.getElementById('drawerStats').innerHTML = `
                <div class="drawer-stat"><span class="ds-val" style="color:#16a34a">${presents}</span><span class="ds-lbl">Present</span></div>
                <div class="drawer-stat"><span class="ds-val" style="color:#dc2626">${absents}</span><span class="ds-lbl">Absent</span></div>
                <div class="drawer-stat"><span class="ds-val" style="color:#d97706">${leaves}</span><span class="ds-lbl">Leave</span></div>
                <div class="drawer-stat"><span class="ds-val" style="color:${rateCol}">${rate}%</span><span class="ds-lbl">Rate</span></div>
            `;

            const tbody = document.getElementById('drawerTableBody');
            const empty = document.getElementById('drawerEmpty');

            if (records.length === 0) {
                tbody.innerHTML = '';
                empty.style.display = 'block';
            } else {
                empty.style.display = 'none';
                tbody.innerHTML = records.map((rec, idx) => {
                    const d   = new Date(rec.date);
                    const day = DAYS[d.getUTCDay()];
                    const fmt = d.toLocaleDateString('en-GB', { timeZone:'UTC', year:'numeric', month:'short', day:'numeric' });
                    const iso = rec.date.substring(0, 10);
                    const rowId   = `row_${idx}`;
                    const editId  = `edit_${idx}`;

                    return `
                    <tr id="${rowId}" class="drawer-row" style="border-bottom:1px solid #f1f5f9;">
                        <td style="padding:0.6rem 1rem;font-weight:500;color:#1e293b;">${fmt}</td>
                        <td style="padding:0.6rem 0.5rem;text-align:center;color:#64748b;font-size:0.8rem;font-weight:600;">${day}</td>
                        <td id="status_${idx}" style="padding:0.6rem 0.5rem;text-align:center;">${statusBadge(rec.status)}</td>
                        <td style="padding:0.6rem 1rem;text-align:center;">
                            <button onclick="showEditRow(${idx},'${iso}','${rec.status}')"
                                    id="editBtn_${idx}"
                                    style="display:inline-flex;align-items:center;gap:0.3rem;font-size:0.78rem;color:#2563eb;border:1px solid #bfdbfe;background:#eff6ff;padding:0.22rem 0.6rem;border-radius:6px;font-weight:600;cursor:pointer;transition:background 0.15s;"
                                    onmouseover="this.style.background='#dbeafe'" onmouseout="this.style.background='#eff6ff'">
                                <i class="bi bi-pencil-fill"></i> Edit
                            </button>
                        </td>
                    </tr>
                    <tr id="${editId}" style="display:none; background:#f8fafc; border-bottom:2px solid #bfdbfe;">
                        <td colspan="4" style="padding:0.75rem 1rem;">
                            <div style="display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap;">
                                <span style="font-size:0.8rem;color:#64748b;font-weight:600;">Set to:</span>
                                <button onclick="saveStatus(${idx},'${iso}','present')" style="padding:0.3rem 0.8rem;border:none;border-radius:6px;background:#10b981;color:#fff;font-weight:600;font-size:0.8rem;cursor:pointer;display:inline-flex;align-items:center;gap:0.3rem;"><i class="bi bi-check-circle-fill"></i> Present</button>
                                <button onclick="saveStatus(${idx},'${iso}','absent')"  style="padding:0.3rem 0.8rem;border:none;border-radius:6px;background:#ef4444;color:#fff;font-weight:600;font-size:0.8rem;cursor:pointer;display:inline-flex;align-items:center;gap:0.3rem;"><i class="bi bi-x-circle-fill"></i> Absent</button>
                                <button onclick="saveStatus(${idx},'${iso}','leave')"   style="padding:0.3rem 0.8rem;border:none;border-radius:6px;background:#f59e0b;color:#fff;font-weight:600;font-size:0.8rem;cursor:pointer;display:inline-flex;align-items:center;gap:0.3rem;"><i class="bi bi-calendar2-minus-fill"></i> Leave</button>
                                <button onclick="hideEditRow(${idx})" style="padding:0.3rem 0.7rem;border:1px solid #cbd5e1;border-radius:6px;background:#fff;color:#64748b;font-weight:600;font-size:0.8rem;cursor:pointer;">Cancel</button>
                                <span id="saveMsg_${idx}" style="font-size:0.78rem;color:#16a34a;display:none;"><i class="bi bi-check-lg"></i> Saved!</span>
                                <span id="errMsg_${idx}"  style="font-size:0.78rem;color:#dc2626;display:none;"></span>
                            </div>
                        </td>
                    </tr>`;
                }).join('');
            }
        })
        .catch(() => {
            document.getElementById('drawerLoading').innerHTML = '<p style="color:#dc2626;padding:1rem;">Failed to load records. Please try again.</p>';
        });
}

function showEditRow(idx, iso, currentStatus) {
    // Hide any other open edit rows first
    document.querySelectorAll('[id^="edit_"]').forEach(r => r.style.display = 'none');
    document.getElementById(`edit_${idx}`).style.display = 'table-row';
}

function hideEditRow(idx) {
    document.getElementById(`edit_${idx}`).style.display = 'none';
}

function saveStatus(idx, date, newStatus) {
    const saveMsg = document.getElementById(`saveMsg_${idx}`);
    const errMsg  = document.getElementById(`errMsg_${idx}`);
    saveMsg.style.display = 'none';
    errMsg.style.display  = 'none';

    fetch('/attendance/employees/update-one', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ employee_id: currentEmpId, date, status: newStatus })
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            // Update the badge in-place
            const s = STATUS_CFG[newStatus];
            document.getElementById(`status_${idx}`).innerHTML =
                `<span style="padding:0.2rem 0.65rem;border-radius:9999px;font-size:0.78rem;font-weight:600;background:${s.bg};color:${s.color};">${s.label}</span>`;

            // Flash saved message then hide edit row
            saveMsg.style.display = 'inline';
            setTimeout(() => {
                saveMsg.style.display = 'none';
                hideEditRow(idx);
                // Refresh stats bar
                loadHistory();
            }, 900);
        } else {
            errMsg.textContent = data.error || 'Failed to save.';
            errMsg.style.display = 'inline';
        }
    })
    .catch(() => {
        errMsg.textContent = 'Network error.';
        errMsg.style.display = 'inline';
    });
}

function closeDetail() {
    document.getElementById('detailBackdrop').style.display = 'none';
    const drawer = document.getElementById('detailDrawer');
    drawer.style.display = 'none';
    drawer.classList.remove('open');
    currentEmpId = null;
}

function toggleCustomDates(val) {
    document.getElementById('custom-start-group').style.display = val === 'custom' ? 'block' : 'none';
    document.getElementById('custom-end-group').style.display   = val === 'custom' ? 'block' : 'none';
    if (val !== 'custom') document.forms[0].submit();
}
</script>

<%- include('partials/footer') %>
