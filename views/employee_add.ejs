<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-person-plus-fill"></i> Onboard New Employee</h1>
    <a href="/employees" class="btn-secondary"><i class="bi bi-arrow-left"></i> Back to Directory</a>
</div>

<% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="card">
    <form action="/employees/add" method="POST">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);">1. Employment Details</h3>
        <div class="form-grid">
            <div class="form-group">
                <label for="name">Employee Full Name *</label>
                <input type="text" id="name" name="name" class="form-control" required placeholder="e.g. Qari Usama sb">
            </div>
            
            <div class="form-group">
                <label for="designation">Designation *</label>
                <select id="designation" name="designation" class="form-control" required>
                    <option value="">-- Select Designation --</option>
                    <option value="Principal">Principal</option>
                    <option value="Vice Principal / Coordinator">Vice Principal / Coordinator</option>
                    <option value="Primary School Teacher">Primary School Teacher</option>
                    <option value="Montessori Teacher">Montessori Teacher</option>
                    <option value="Qari (Male Quran Teacher)">Qari (Male Quran Teacher)</option>
                    <option value="Qaria (Female Quran Teacher)">Qaria (Female Quran Teacher)</option>
                    <option value="Hifz Nazim / Supervisor">Hifz Nazim / Supervisor (ناظم)</option>
                    <option value="Course Coordinator">Course Coordinator</option>
                    <option value="Class Coordinator">Class Coordinator</option>
                    <option value="Admin / Office Staff">Admin / Office Staff</option>
                    <option value="Caretaker / Security">Caretaker / Security</option>
                    <option value="Aya / Nanny">Aya / Nanny</option>
                    <option value="Cleaner / Support Staff">Cleaner / Support Staff</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="role">Role Type</label>
                <select name="role" id="role" class="form-control">
                    <option value="teacher">Teacher</option>
                    <option value="admin">Administrator / Principal</option>
                    <option value="support">Support / Cleaning Staff</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="status">Payroll Status</label>
                <select name="status" id="status" class="form-control">
                    <option value="on_payroll">On Payroll</option>
                    <option value="volunteer">Volunteer</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="date_of_joining">Date of Joining</label>
                <input type="date" id="date_of_joining" name="date_of_joining" class="form-control">
            </div>
            
            <div class="form-group">
                <label for="date_of_leaving">Date of Leaving / Discharge</label>
                <input type="date" id="date_of_leaving" name="date_of_leaving" class="form-control">
            </div>
            
            <div class="form-group">
                <label for="default_salary">Default Monthly Salary (PKR)</label>
                <input type="number" step="0.01" id="default_salary" name="default_salary" class="form-control" placeholder="0.00" value="0.00">
            </div>
        </div>

        <h3 style="margin-top: 2rem; margin-bottom: 1rem; color: var(--primary-color);">2. Personal & Contact Details</h3>
        <div class="form-grid">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" class="form-control" placeholder="e.g. employee@school.com">
            </div>
            
            <div class="form-group">
                <label for="phone">Phone Number</label>
                <input type="text" id="phone" name="phone" class="form-control" placeholder="e.g. 0300-1234567">
            </div>
            
            <div class="form-group">
                <label for="cnic_number">CNIC / ID Card Number</label>
                <input type="text" id="cnic_number" name="cnic_number" class="form-control" placeholder="e.g. 37405-XXXXXXX-X">
            </div>
            
            <div class="form-group">
                <label for="gender">Gender</label>
                <select name="gender" id="gender" class="form-control">
                    <option value="male">Male</option>
                    <option value="female">Female</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="qualification">Highest Qualification</label>
                <input type="text" id="qualification" name="qualification" class="form-control" placeholder="e.g. M.A. Islamic Studies, Matric">
            </div>
            
            <div class="form-group">
                <label for="previous_experience_years">Years of Experience</label>
                <input type="number" id="previous_experience_years" name="previous_experience_years" class="form-control" placeholder="0" value="0">
            </div>
        </div>
        
        <div class="form-grid" style="margin-top: 1rem;">
            <div class="form-group" style="grid-column: span 2;">
                <label for="address">Residential Address</label>
                <textarea id="address" name="address" class="form-control" rows="2"></textarea>
            </div>
            
            <div class="form-group" style="grid-column: span 2;">
                <label for="bank_account_info">Bank Account Details</label>
                <input type="text" id="bank_account_info" name="bank_account_info" class="form-control" placeholder="Bank Name, Account Title, Account Number/IBAN">
            </div>
        </div>

        <div style="margin-top: 2rem; display: flex; gap: 1rem;">
            <button type="submit" class="btn-primary">Onboard Employee</button>
            <a href="/employees" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

<%- include('partials/footer') %>
