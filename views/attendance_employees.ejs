<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-calendar2-check-fill"></i> Employee Attendance Dashboard</h1>
    <div style="display: flex; gap: 0.5rem;">
        <button type="button" onclick="openSettingsModal()" class="btn-secondary" style="height: 38px; display: inline-flex; align-items: center; gap: 0.35rem;"><i class="bi bi-gear-fill"></i> Settings</button>
        <a href="/attendance/employees/summary" class="btn-primary" style="height: 38px; display: inline-flex; align-items: center;"><i class="bi bi-calendar2-range" style="margin-right: 0.35rem;"></i> Attendance Summary</a>
    </div>
</div>

<!-- Date Selector -->
<form action="/attendance/employees" method="GET" class="filter-bar" style="align-items: center; margin-bottom: 1.5rem;">
    <div class="form-group" style="flex: 0 0 250px;">
        <label for="date">Select Date</label>
        <input type="date" name="date" id="date" class="form-control" value="<%= dateStr %>" onchange="this.form.submit()">
    </div>
    <span style="font-weight: 500; color: #64748b; margin-top: 1rem;">Marking attendance for: <%= new Date(dateStr).toLocaleDateString(undefined, {weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'}) %></span>
</form>

<!-- Warning banner if Sunday or Holiday -->
<% if (holiday) { %>
    <div style="background-color: #fef2f2; border-left: 4px solid #ef4444; color: #991b1b; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; font-weight: 500;">
        <i class="bi bi-info-circle-fill" style="margin-right: 0.5rem;"></i> Today is a public holiday: <strong><%= holiday.name %></strong>. Attendance statuses are not pre-marked by default.
    </div>
<% } else if (isSunday) { %>
    <div style="background-color: #fffbeb; border-left: 4px solid #f59e0b; color: #92400e; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; font-weight: 500;">
        <i class="bi bi-info-circle-fill" style="margin-right: 0.5rem;"></i> Today is Sunday (Weekly Holiday). Attendance statuses are not pre-marked by default.
    </div>
<% } %>

<!-- KPI Cards -->
<% 
    const totalStaff = employees.length;
    let presentCount = 0;
    let absentCount = 0;
    let leaveCount = 0;
    employees.forEach(e => {
        const status = attendanceMap[e.id] || (holiday || isSunday ? '' : 'present');
        if (status === 'present') presentCount++;
        else if (status === 'absent') absentCount++;
        else if (status === 'leave') leaveCount++;
    });
%>
<div class="dashboard-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
    <div class="card shadow-sm" style="background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); color: white; padding: 1.5rem; border-radius: 12px; border: none; margin-bottom: 0;">
        <div style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.8;">Total Staff</div>
        <div style="font-size: 2rem; font-weight: 700; margin-top: 0.5rem;"><%= totalStaff %></div>
    </div>
    <div class="card shadow-sm" style="background: linear-gradient(135deg, #10b981 0%, #047857 100%); color: white; padding: 1.5rem; border-radius: 12px; border: none; margin-bottom: 0;">
        <div style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.8;">Presents</div>
        <div style="font-size: 2rem; font-weight: 700; margin-top: 0.5rem;"><%= presentCount %></div>
    </div>
    <div class="card shadow-sm" style="background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%); color: white; padding: 1.5rem; border-radius: 12px; border: none; margin-bottom: 0;">
        <div style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.8;">Absents</div>
        <div style="font-size: 2rem; font-weight: 700; margin-top: 0.5rem;"><%= absentCount %></div>
    </div>
    <div class="card shadow-sm" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; padding: 1.5rem; border-radius: 12px; border: none; margin-bottom: 0;">
        <div style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.8;">On Leave</div>
        <div style="font-size: 2rem; font-weight: 700; margin-top: 0.5rem;"><%= leaveCount %></div>
    </div>
</div>

<!-- Settings Modal -->
<div id="settingsModal" class="modal" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.5); backdrop-filter: blur(4px); transition: opacity 0.3s ease;">
    <div class="modal-content" style="background-color: #ffffff; margin: 10% auto; padding: 2rem; border-radius: 12px; width: 90%; max-width: 500px; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1); border: 1px solid #e2e8f0; position: relative; animation: slideIn 0.3s ease-out; box-sizing: border-box;">
        <span class="close-btn" onclick="closeSettingsModal()" style="position: absolute; right: 1.5rem; top: 1.5rem; font-size: 1.5rem; font-weight: bold; color: #94a3b8; cursor: pointer; transition: color 0.2s;">&times;</span>
        <h2 style="margin-top: 0; font-size: 1.25rem; color: #1e293b; margin-bottom: 1.5rem; font-weight: 700;"><i class="bi bi-gear-fill"></i> School Work Hours Settings</h2>
        
        <form action="/attendance/settings" method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
            <input type="hidden" name="redirectDate" value="<%= dateStr %>">
            
            <% 
                const formattedStartTime = (tenantSettings.school_start_time || '08:00:00').slice(0, 5);
                const formattedEndTime = (tenantSettings.school_end_time || '14:00:00').slice(0, 5);
            %>
            
            <div class="form-group">
                <label for="school_start_time" style="font-weight: 600; font-size: 0.85rem; color: #475569; display: block; margin-bottom: 0.35rem;">School Start Time</label>
                <input type="time" name="school_start_time" id="school_start_time" class="form-control" value="<%= formattedStartTime %>" required>
            </div>
            
            <div class="form-group">
                <label for="school_end_time" style="font-weight: 600; font-size: 0.85rem; color: #475569; display: block; margin-bottom: 0.35rem;">School End Time</label>
                <input type="time" name="school_end_time" id="school_end_time" class="form-control" value="<%= formattedEndTime %>" required>
            </div>
            
            <div class="form-group">
                <label for="late_threshold_minutes" style="font-weight: 600; font-size: 0.85rem; color: #475569; display: block; margin-bottom: 0.35rem;">Late Threshold Margin</label>
                <select name="late_threshold_minutes" id="late_threshold_minutes" class="form-control" required>
                    <option value="0" <%= tenantSettings.late_threshold_minutes == 0 ? 'selected' : '' %>>No Threshold (0 min)</option>
                    <option value="5" <%= tenantSettings.late_threshold_minutes == 5 ? 'selected' : '' %>>5 Minutes</option>
                    <option value="10" <%= tenantSettings.late_threshold_minutes == 10 ? 'selected' : '' %>>10 Minutes</option>
                    <option value="15" <%= tenantSettings.late_threshold_minutes == 15 ? 'selected' : '' %>>15 Minutes</option>
                    <option value="30" <%= tenantSettings.late_threshold_minutes == 30 ? 'selected' : '' %>>30 Minutes</option>
                    <option value="45" <%= tenantSettings.late_threshold_minutes == 45 ? 'selected' : '' %>>45 Minutes</option>
                    <option value="60" <%= tenantSettings.late_threshold_minutes == 60 ? 'selected' : '' %>>1 Hour (60 min)</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="late_days_deduction_trigger" style="font-weight: 600; font-size: 0.85rem; color: #475569; display: block; margin-bottom: 0.35rem;">Late Marks triggering 1 Day Salary Deduction</label>
                <input type="number" name="late_days_deduction_trigger" id="late_days_deduction_trigger" class="form-control" min="1" value="<%= tenantSettings.late_days_deduction_trigger !== undefined ? tenantSettings.late_days_deduction_trigger : 4 %>" required>
            </div>
            
            <button type="submit" class="btn-primary" style="margin-top: 0.5rem; justify-content: center;"><i class="bi bi-gear-fill"></i> Save Settings</button>
        </form>
    </div>
</div>

<!-- Table Form -->
<div class="card">
    <form action="/attendance/employees" method="POST">
        <input type="hidden" name="date" value="<%= dateStr %>">
        
        <div class="table-container" style="border: none; margin-bottom: 1.5rem;">
            <table>
                <thead>
                    <tr>
                        <th>Employee Name</th>
                        <th>Designation</th>
                        <th>Role</th>
                        <th>Arrival Time (Hours & Mins)</th>
                        <th style="text-align: center;">Present</th>
                        <th style="text-align: center;">Absent</th>
                        <th style="text-align: center;">Leave</th>
                        <th style="text-align: center;">Reset</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (employees.length > 0) { %>
                        <% 
                            function parseTime(timeStr) {
                                if (!timeStr) return null;
                                const parts = timeStr.split(':');
                                let hour = parseInt(parts[0], 10);
                                const minute = parseInt(parts[1], 10);
                                let ampm = 'AM';
                                if (hour >= 12) {
                                    ampm = 'PM';
                                    if (hour > 12) hour -= 12;
                                }
                                if (hour === 0) hour = 12;
                                return { hour, minute, ampm };
                            }
                        %>
                        <% employees.forEach(e => { %>
                            <% 
                                const currentStatus = attendanceMap[e.id] || ''; 
                                const details = attendanceDetailsMap[e.id] || {};
                                const parsed = parseTime(details.arrival_time) || parseTime(tenantSettings.school_start_time) || { hour: 8, minute: 0, ampm: 'AM' };
                            %>
                            <tr id="row_emp_<%= e.id %>">
                                <td style="font-weight: 600;">
                                    <a href="#" onclick="showHistory('<%= e.id %>'); return false;" style="color: #2563eb; text-decoration: none; border-bottom: 1px dashed #2563eb;" title="Click to view attendance history"><%= e.name %></a>
                                    <a href="/employees/view/<%= e.id %>" style="margin-left: 8px; color: #64748b;" title="View Full Profile"><i class="bi bi-person-bounding-box"></i></a>
                                </td>
                                <td><%= e.designation %></td>
                                <td><%= e.role.toUpperCase() %></td>
                                <td>
                                    <div id="arrival_time_container_<%= e.id %>" style="display: <%= currentStatus === 'present' ? 'flex' : 'none' %>; gap: 0.35rem; align-items: center;">
                                        <select name="arrival_hour_emp_<%= e.id %>" class="form-control" style="width: 60px; padding: 0.25rem; font-size: 0.85rem; height: auto;">
                                            <% for (let h = 1; h <= 12; h++) { %>
                                                <option value="<%= h %>" <%= parsed.hour === h ? 'selected' : '' %>><%= h %></option>
                                            <% } %>
                                        </select>
                                        <span style="font-weight: bold; color: #64748b;">:</span>
                                        <select name="arrival_minute_emp_<%= e.id %>" class="form-control" style="width: 60px; padding: 0.25rem; font-size: 0.85rem; height: auto;">
                                            <% for (let m = 0; m < 60; m++) { %>
                                                <% const mStr = String(m).padStart(2, '0'); %>
                                                <option value="<%= mStr %>" <%= parsed.minute === m ? 'selected' : '' %>><%= mStr %></option>
                                            <% } %>
                                        </select>
                                        <select name="arrival_ampm_emp_<%= e.id %>" class="form-control" style="width: 65px; padding: 0.25rem; font-size: 0.85rem; height: auto;">
                                            <option value="AM" <%= parsed.ampm === 'AM' ? 'selected' : '' %>>AM</option>
                                            <option value="PM" <%= parsed.ampm === 'PM' ? 'selected' : '' %>>PM</option>
                                        </select>
                                        <% if (details.is_late === 1) { %>
                                            <span class="badge-absent" style="padding: 0.2rem 0.5rem; font-size: 0.75rem; border-radius: 9999px; font-weight: 600; display: inline-flex; align-items: center; gap: 0.15rem; background-color: #fee2e2; color: #991b1b;"><i class="bi bi-clock-fill"></i> Late</span>
                                        <% } %>
                                    </div>
                                    <div id="arrival_time_placeholder_<%= e.id %>" style="display: <%= currentStatus === 'present' ? 'none' : 'block' %>; color: #94a3b8; font-style: italic; font-size: 0.85rem;">
                                        N/A
                                    </div>
                                </td>
                                <td style="text-align: center;">
                                    <input type="radio" name="attendance[emp_<%= e.id %>]" value="present" <%= currentStatus === 'present' ? 'checked' : '' %> onchange="toggleArrivalTime('<%= e.id %>', true)" style="width: 20px; height: 20px; accent-color: #10b981;">
                                </td>
                                <td style="text-align: center;">
                                    <input type="radio" name="attendance[emp_<%= e.id %>]" value="absent" <%= currentStatus === 'absent' ? 'checked' : '' %> onchange="toggleArrivalTime('<%= e.id %>', false)" style="width: 20px; height: 20px; accent-color: #ef4444;">
                                </td>
                                <td style="text-align: center;">
                                    <input type="radio" name="attendance[emp_<%= e.id %>]" value="leave" <%= currentStatus === 'leave' ? 'checked' : '' %> onchange="toggleArrivalTime('<%= e.id %>', false)" style="width: 20px; height: 20px; accent-color: #f59e0b;">
                                </td>
                                <td style="text-align: center;">
                                    <button type="button" onclick="resetRow('<%= e.id %>')" class="btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.8rem; height: auto;" title="Reset selection">
                                        <i class="bi bi-arrow-counterclockwise"></i> Reset
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="8" style="text-align: center; color: #64748b;">No active employees found to mark attendance.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <button type="submit" class="btn-primary">Save Today's Attendance</button>
    </form>
</div>

<!-- Manage Public Holidays -->
<div class="card" style="margin-top: 2rem; padding: 1.5rem;">
    <h2 style="font-size: 1.25rem; font-weight: 700; margin-top: 0; margin-bottom: 1rem; color: #1e293b;">
        <i class="bi bi-calendar-event"></i> Manage Public Holidays
    </h2>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
        <div>
            <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; color: #475569;">Add Public Holiday</h3>
            <form action="/attendance/holidays/add" method="POST" style="display: flex; flex-direction: column; gap: 0.75rem;">
                <input type="hidden" name="redirectDate" value="<%= dateStr %>">
                <div class="form-group">
                    <label for="holiday_date">Date</label>
                    <input type="date" name="date" id="holiday_date" class="form-control" required value="<%= dateStr %>">
                </div>
                <div class="form-group">
                    <label for="holiday_name">Holiday Name</label>
                    <input type="text" name="name" id="holiday_name" class="form-control" placeholder="e.g., Eid-ul-Fitr, Independence Day" required>
                </div>
                <button type="submit" class="btn-primary" style="align-self: flex-start; margin-top: 0.5rem;">Add Holiday</button>
            </form>
        </div>
        <div>
            <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; color: #475569;">Registered Holidays</h3>
            <div style="max-height: 250px; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 8px;">
                <table style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead>
                        <tr style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0; color: #64748b; font-size: 0.85rem;">
                            <th style="padding: 0.5rem 0.75rem;">Date</th>
                            <th style="padding: 0.5rem 0.75rem;">Name</th>
                            <th style="padding: 0.5rem 0.75rem; text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (holidaysList.length > 0) { %>
                            <% holidaysList.forEach(h => { %>
                                <tr style="border-bottom: 1px solid #f1f5f9; font-size: 0.9rem;">
                                    <td style="padding: 0.5rem 0.75rem; color: #334155;">
                                        <%= new Date(h.date).toLocaleDateString(undefined, {year: 'numeric', month: 'short', day: 'numeric'}) %>
                                    </td>
                                    <td style="padding: 0.5rem 0.75rem; color: #334155; font-weight: 500;"><%= h.name %></td>
                                    <td style="padding: 0.5rem 0.75rem; text-align: right;">
                                        <form action="/attendance/holidays/delete/<%= h.id %>" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this holiday?')">
                                            <input type="hidden" name="redirectDate" value="<%= dateStr %>">
                                            <button type="submit" style="background: none; border: none; color: #ef4444; cursor: pointer; padding: 0;" title="Delete Holiday">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="3" style="text-align: center; color: #94a3b8; padding: 1rem;">No holidays registered.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Attendance History Modal -->
<div id="historyModal" class="modal" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.5); backdrop-filter: blur(4px); transition: opacity 0.3s ease;">
    <div class="modal-content" style="background-color: #ffffff; margin: 10% auto; padding: 2rem; border-radius: 12px; width: 90%; max-width: 600px; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1); border: 1px solid #e2e8f0; position: relative; animation: slideIn 0.3s ease-out; box-sizing: border-box;">
        <span class="close-btn" onclick="closeModal()" style="position: absolute; right: 1.5rem; top: 1.5rem; font-size: 1.5rem; font-weight: bold; color: #94a3b8; cursor: pointer; transition: color 0.2s;">&times;</span>
        <h2 id="modalTitle" style="margin-top: 0; font-size: 1.5rem; color: #1e293b; margin-bottom: 0.5rem; font-weight: 700;">Employee Attendance History</h2>
        <p id="modalSubtitle" style="color: #64748b; font-size: 0.9rem; margin-bottom: 1.5rem;"></p>
        
        <div id="modalLoading" style="text-align: center; padding: 2rem 0;">
            <div class="spinner" style="border: 4px solid #f3f3f3; border-top: 4px solid #3b82f6; border-radius: 50%; width: 36px; height: 36px; animation: spin 1s linear infinite; margin: 0 auto 1rem;"></div>
            <p style="color: #64748b;">Loading history...</p>
        </div>

        <div id="modalBody" style="display: none; max-height: 400px; overflow-y: auto;">
            <!-- History entries will be injected here -->
        </div>
    </div>
</div>

<style>
@keyframes slideIn {
    from { transform: translateY(-20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}
@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}
.close-btn:hover {
    color: #0f172a !important;
}
.history-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    display: inline-block;
}
.badge-present { background-color: #d1fae5; color: #065f46; }
.badge-absent { background-color: #fee2e2; color: #991b1b; }
.badge-leave { background-color: #fef3c7; color: #92400e; }
</style>

<script>
function showHistory(employeeId) {
    const modal = document.getElementById('historyModal');
    const title = document.getElementById('modalTitle');
    const subtitle = document.getElementById('modalSubtitle');
    const body = document.getElementById('modalBody');
    const loading = document.getElementById('modalLoading');

    modal.style.display = 'block';
    body.style.display = 'none';
    loading.style.display = 'block';

    fetch(`/attendance/employees/${employeeId}/history`)
        .then(res => res.json())
        .then(data => {
            if (data.error) {
                alert(data.error);
                closeModal();
                return;
            }
            title.textContent = data.employee.name;
            subtitle.textContent = `${data.employee.designation} • Attendance History (Last 60 Days)`;
            
            loading.style.display = 'none';
            body.style.display = 'block';

            if (data.history.length === 0) {
                body.innerHTML = `<div style="text-align: center; color: #64748b; padding: 2rem;">No attendance logs found for this employee.</div>`;
                return;
            }

            let html = `
                <table style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead>
                        <tr style="border-bottom: 2px solid #e2e8f0; color: #475569; font-size: 0.85rem; font-weight: 600;">
                            <th style="padding: 0.75rem 0.5rem;">Date</th>
                            <th style="padding: 0.75rem 0.5rem; text-align: center;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            data.history.forEach(item => {
                const formattedDate = new Date(item.date).toLocaleDateString(undefined, {
                    weekday: 'short',
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric'
                });
                
                let badgeClass = 'badge-present';
                if (item.status === 'absent') badgeClass = 'badge-absent';
                if (item.status === 'leave') badgeClass = 'badge-leave';

                html += `
                    <tr style="border-bottom: 1px solid #f1f5f9;">
                        <td style="padding: 0.75rem 0.5rem; color: #334155; font-size: 0.9rem;">${formattedDate}</td>
                        <td style="padding: 0.75rem 0.5rem; text-align: center;">
                            <span class="history-badge ${badgeClass}">${item.status}</span>
                        </td>
                    </tr>
                `;
            });

            html += `</tbody></table>`;
            body.innerHTML = html;
        })
        .catch(err => {
            console.error(err);
            alert('Failed to load history.');
            closeModal();
        });
}

function toggleArrivalTime(empId, show) {
    const container = document.getElementById('arrival_time_container_' + empId);
    const placeholder = document.getElementById('arrival_time_placeholder_' + empId);
    if (container && placeholder) {
        if (show) {
            container.style.display = 'flex';
            placeholder.style.display = 'none';
        } else {
            container.style.display = 'none';
            placeholder.style.display = 'block';
        }
    }
}

function resetRow(empId) {
    // Uncheck all radio buttons in that row
    const radios = document.getElementsByName('attendance[emp_' + empId + ']');
    radios.forEach(radio => {
        radio.checked = false;
    });
    // Hide arrival time inputs
    toggleArrivalTime(empId, false);
}

function openSettingsModal() {
    document.getElementById('settingsModal').style.display = 'block';
}

function closeSettingsModal() {
    document.getElementById('settingsModal').style.display = 'none';
}

function closeModal() {
    document.getElementById('historyModal').style.display = 'none';
}

// Close modals if clicked outside
window.onclick = function(event) {
    const historyModal = document.getElementById('historyModal');
    const settingsModal = document.getElementById('settingsModal');
    if (event.target == historyModal) {
        closeModal();
    }
    if (event.target == settingsModal) {
        closeSettingsModal();
    }
}
</script>

<%- include('partials/footer') %>
