<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-heart-fill"></i> Donations Overview</h1>
</div>

<div class="filter-bar" style="margin-bottom: 1.5rem;">
    <a href="/donations" class="nav-tab active">Overview</a>
    <a href="/donations/matrix" class="nav-tab">Matrix View</a>
</div>

<!-- KPI Cards -->
<div class="kpi-grid" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
    <div class="card kpi-card">
        <span class="kpi-icon green"><i class="bi bi-cash-coin"></i></span>
        <span class="kpi-label">This Month's Donations</span>
        <span class="kpi-value" style="font-size: 1.6rem;">PKR <%= thisMonthTotal.toLocaleString() %></span>
        <span class="kpi-subtitle"><%= thisMonthDonorCount %> donor(s) contributed</span>
    </div>
    <div class="card kpi-card">
        <span class="kpi-icon amber"><i class="bi bi-person-exclamation"></i></span>
        <span class="kpi-label">Donors to Reconnect With</span>
        <span class="kpi-value" style="font-size: 1.6rem;"><%= lapsedDonors.length %></span>
        <span class="kpi-subtitle">Gave 6 months straight, missed this month</span>
    </div>
    <div class="card kpi-card">
        <span class="kpi-icon purple"><i class="bi bi-piggy-bank-fill"></i></span>
        <span class="kpi-label">All-Time Total</span>
        <span class="kpi-value" style="font-size: 1.6rem; font-weight: 700;">PKR <%= totalAllTime.toLocaleString() %></span>
        <span class="kpi-subtitle">From <%= totalDonationsCount %> total donations</span>
    </div>
    <div class="card kpi-card" style="cursor: pointer;" onclick="const panel = document.getElementById('donors-directory-panel'); if (panel) { panel.open = true; panel.scrollIntoView({ behavior: 'smooth' }); }">
        <span class="kpi-icon blue"><i class="bi bi-people-fill"></i></span>
        <span class="kpi-label">Total Donors Registered</span>
        <span class="kpi-value" style="font-size: 2.2rem; font-weight: 800; color: var(--primary-color); line-height: 1.1; margin-top: 0.2rem; margin-bottom: 0.2rem;"><%= totalDonorCount %></span>
        <span class="kpi-subtitle"><%= monthlyDonorsCount %> monthly commitment donor(s)</span>
    </div>
    <div class="card kpi-card" style="grid-row: span 1; min-height: 160px;">
        <span class="kpi-icon teal"><i class="bi bi-trophy-fill"></i></span>
        <span class="kpi-label">Top 5 Donors (All-Time)</span>
        <ul style="list-style: none; font-size: 0.82rem; padding: 0; margin-top: 0.5rem; margin-bottom: 0;">
            <% topDonors.forEach((td, i) => { %>
                <li style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem; gap: 0.5rem;">
                    <span style="display: inline-flex; min-width: 0; flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        <%= i+1 %>. <a href="/donations/donor/<%= td.id %>" style="color: var(--primary-color, #4f46e5); text-decoration: none; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: inline;"><%= td.name %></a>
                    </span>
                    <span style="font-weight: 700; color: #15803d; flex-shrink: 0;">PKR <%= parseFloat(td.total_amount).toLocaleString() %></span>
                </li>
            <% }) %>
        </ul>
    </div>
</div>

<!-- Quick Add Forms -->
<div class="form-grid" style="grid-template-columns: 1fr 1fr; margin-bottom: 2rem;">
    <div class="card">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);"><i class="bi bi-person-plus-fill"></i> Register New Donor</h3>
        <form action="/donations/donor/add" method="POST">
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="donorName">Donor Name *</label>
                <input type="text" id="donorName" name="name" class="form-control" required placeholder="e.g. Ali Irfan">
            </div>
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="contactNo">Contact Number</label>
                <input type="text" id="contactNo" name="contact_no" class="form-control" placeholder="e.g. 0300-XXXXXXX">
            </div>
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="referredBy">Referred By</label>
                <div style="display: flex; gap: 0.5rem; align-items: center;">
                    <select id="referredBy" name="referred_by" class="form-control">
                        <option value="">-- None (Direct) --</option>
                        <option value="Faheem Zafar">Faheem Zafar</option>
                        <option value="Kamal Muhammad">Kamal Muhammad</option>
                        <option value="Khurram Shahzad">Khurram Shahzad</option>
                    </select>
                    <button type="button" class="btn-secondary" style="padding: 0.5rem; height: 38px; display: inline-flex; align-items: center; justify-content: center;" onclick="addNewReferredOption('referredBy')"><i class="bi bi-plus-lg"></i></button>
                </div>
            </div>
            <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                    <label for="preferred_fund_category">Preferred Account to Transfer Fund</label>
                    <select name="preferred_fund_category" id="preferred_fund_category" class="form-control" onchange="toggleDirectOption(this.value, 'new_preferred_member_group')">
                        <option value="general">Member Account</option>
                        <option value="trust" selected>Trust Account</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="preferred_payment_method">Preferred Method</label>
                    <select name="preferred_payment_method" id="preferred_payment_method" class="form-control">
                        <option value="Online">Online</option>
                        <option value="Cash">Cash</option>
                    </select>
                </div>
            </div>
            <div id="new_preferred_member_group" class="form-group" style="display: none; margin-bottom: 1rem;">
                <label for="preferred_member">Preferred Member Account Option</label>
                <div style="display: flex; gap: 0.5rem; align-items: center;">
                    <select id="preferred_member" name="preferred_member" class="form-control">
                        <option value="">-- Select Member --</option>
                        <option value="Faheem Zafar">Faheem Zafar</option>
                        <option value="Kamal Muhammad">Kamal Muhammad</option>
                        <option value="Khurram Shahzad">Khurram Shahzad</option>
                    </select>
                    <button type="button" class="btn-secondary" style="padding: 0.5rem; height: 38px; display: inline-flex; align-items: center; justify-content: center;" onclick="addNewDirectOption('preferred_member')"><i class="bi bi-plus-lg"></i></button>
                </div>
            </div>
            <div class="form-checkbox" style="margin-bottom: 1rem; display: flex; flex-direction: row; align-items: center; justify-content: flex-start; gap: 0.5rem;">
                <input type="checkbox" id="monthlyCommitment" name="monthly_commitment" value="1" style="width: 18px; height: 18px; cursor: pointer; margin: 0;" onchange="toggleCommitmentAmount(this.checked, 'new_commitment_amount_group')">
                <label for="monthlyCommitment" style="margin-bottom: 0; cursor: pointer; font-weight: 500;">Monthly Commitment Donor</label>
            </div>
            <div id="new_commitment_amount_group" class="form-group" style="display: none; margin-bottom: 1.5rem;">
                <label for="new_commitment_amount">Monthly Commitment Amount (PKR) *</label>
                <input type="number" step="0.01" id="new_commitment_amount" name="monthly_commitment_amount" class="form-control" placeholder="0.00">
            </div>
            <button type="submit" class="btn-primary"><i class="bi bi-check-circle-fill"></i> Register Donor</button>
        </form>
    </div>

    <div class="card">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);"><i class="bi bi-cash-coin"></i> Record Donation Received</h3>
        <form action="/donations/add" method="POST">
            <div class="form-group" style="margin-bottom: 1rem; position: relative;">
                <label for="donor_search">Select Donor *</label>
                <input type="text" id="donor_search" class="form-control" placeholder="Type to search donor..." autocomplete="off" required>
                <!-- Hidden select to submit the donor_id -->
                <select name="donor_id" id="donor_id" style="display: none;" required>
                    <option value="">-- Select Donor --</option>
                    <% donors.forEach(d => { %>
                        <option value="<%= d.id %>"><%= d.name %> (Ref: <%= d.referred_by || 'Direct' %>)</option>
                    <% }) %>
                </select>
                
                <div id="donor_dropdown_list" style="display: none; position: absolute; top: 100%; left: 0; right: 0; background: #ffffff; border: 1px solid #cbd5e1; border-radius: 8px; max-height: 250px; overflow-y: auto; z-index: 1000; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05); margin-top: 4px;">
                    <% donors.forEach(d => { %>
                        <div class="dropdown-donor-item" data-value="<%= d.id %>" data-name="<%= d.name %>" data-last-amount="<%= d.last_donation_amount || '' %>" data-commitment-amount="<%= d.monthly_commitment_amount || '' %>" data-preferred-fund="<%= d.preferred_fund_category || 'general' %>" data-preferred-payment="<%= d.preferred_payment_method || 'Online' %>" data-preferred-member="<%= d.preferred_member || '' %>" style="padding: 0.75rem 1rem; cursor: pointer; border-bottom: 1px solid #f1f5f9; transition: background 0.15s ease;">
                            <div style="font-weight: 600; color: #1e293b; display: flex; justify-content: space-between; align-items: center;">
                                <span><%= d.name %></span>
                                <% if (d.monthly_commitment) { %>
                                    <span style="font-size: 0.7rem; background-color: #e0f2fe; color: #0369a1; padding: 0.1rem 0.4rem; border-radius: 4px; font-weight: 700;">Monthly</span>
                                <% } %>
                            </div>
                            <div style="font-size: 0.75rem; color: #64748b;">Referred by: <%= d.referred_by || 'Direct' %></div>
                        </div>
                    <% }) %>
                    <div id="no_results" style="display: none; padding: 1rem; text-align: center; color: #94a3b8; font-size: 0.9rem;">
                        No donors found
                    </div>
                </div>
            </div>
            <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                    <label for="amount">Amount (PKR) *</label>
                    <input type="number" step="0.01" id="amount" name="amount" class="form-control" required placeholder="0.00">
                </div>
                <div class="form-group">
                    <label for="date">Date Received</label>
                    <input type="date" id="date" name="date" class="form-control" value="<%= new Date().toISOString().slice(0, 10) %>">
                </div>
            </div>
            <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                    <label for="fund_category">Account to Transfer Fund</label>
                    <select name="fund_category" id="fund_category" class="form-control" onchange="toggleDirectOption(this.value, 'direct_option_group')">
                        <option value="general">Member Account</option>
                        <option value="trust" selected>Trust Account</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="payment_method">Payment Method</label>
                    <select id="payment_method" name="payment_method" class="form-control">
                        <option value="Online" selected>Online</option>
                        <option value="Cash">Cash</option>
                    </select>
                </div>
            </div>
            
            <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                    <label for="donation_type">Donation Type</label>
                    <select name="donation_type" id="donation_type" class="form-control">
                        <option value="Sadqa" selected>Sadqa</option>
                        <option value="Zakat">Zakat</option>
                    </select>
                </div>
                <div id="direct_option_group" class="form-group" style="display: none; margin-bottom: 0;">
                    <label for="direct_ref">Member Account Option *</label>
                    <div style="display: flex; gap: 0.5rem; align-items: center;">
                        <select id="direct_ref" name="direct_ref" class="form-control">
                            <option value="Faheem Zafar">Faheem Zafar</option>
                            <option value="Kamal Muhammad">Kamal Muhammad</option>
                            <option value="Khurram Shahzad">Khurram Shahzad</option>
                        </select>
                        <button type="button" class="btn-secondary" style="padding: 0.5rem; height: 38px; display: inline-flex; align-items: center; justify-content: center;" onclick="addNewDirectOption('direct_ref')"><i class="bi bi-plus-lg"></i></button>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn-primary" style="margin-top: 0.5rem;"><i class="bi bi-check-circle-fill"></i> Log Donation</button>
        </form>
    </div>
</div>

<!-- Donors to Reconnect With -->
<% if (lapsedDonors.length > 0) { %>
<div class="section-header">
    <h2 class="section-title"><i class="bi bi-person-exclamation"></i> Donors to Reconnect With</h2>
</div>
<div class="card" style="border-left: 4px solid #d97706; margin-bottom: 2rem;">
    <p style="color: #64748b; font-size: 0.875rem; margin-bottom: 1rem;">
        These donors gave consistently for the last 6 months but haven't donated this month yet &mdash; a good list to call or message.
    </p>
    <div class="table-container" style="border: none; box-shadow: none; margin-bottom: 0;">
        <table>
            <thead>
                <tr>
                    <th>Donor Name</th>
                    <th>Contact No.</th>
                    <th>Referred By</th>
                    <th>Last Donation</th>
                    <th style="text-align: right;">Last Amount (PKR)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <% lapsedDonors.forEach(ld => { %>
                    <tr>
                        <td style="font-weight: 600;"><%= ld.donor.name %></td>
                        <td><%= ld.donor.contact_no || '-' %></td>
                        <td><%= ld.donor.referred_by || '-' %></td>
                        <td><%= ld.lastDonationDate ? new Date(ld.lastDonationDate).toLocaleDateString() : '-' %></td>
                        <td style="text-align: right;"><%= ld.lastDonationAmount ? parseFloat(ld.lastDonationAmount).toLocaleString() : '-' %></td>
                        <td><a href="/donations/donor/<%= ld.donor.id %>" class="btn-secondary nav-btn"><i class="bi bi-person-vcard-fill"></i> View</a></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<!-- Recent Donations This Month -->
<div class="section-header" style="margin-bottom: 1rem;">
    <h2 class="section-title"><i class="bi bi-clock-history"></i> Recent Donations This Month</h2>
    <div style="flex-shrink: 0; min-width: 250px;">
        <input type="text" id="searchRecentDonations" class="form-control" placeholder="Search by donor name..." style="height: 38px; font-size: 0.9rem;">
    </div>
</div>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Donor</th>
                <th>Date</th>
                <th style="text-align: right;">Amount (PKR)</th>
                <th>Fund</th>
                <th>Type</th>
                <th>Method</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            <% if (recentThisMonth.length > 0) { %>
                <% recentThisMonth.forEach((d, idx) => { %>
                    <tr class="recent-donation-row <%= idx >= 10 ? 'recent-donation-hidden' : '' %>" style="<%= idx >= 10 ? 'display: none;' : '' %>">
                        <td class="recent-donor-name" style="font-weight: 600;"><a href="/donations/donor/<%= d.donor_id %>" style="color: var(--primary-color); text-decoration: none;"><%= d.donor_name %></a></td>
                        <td><%= new Date(d.date).toLocaleDateString() %></td>
                        <td style="text-align: right; font-weight: 600; color: #15803d;"><%= parseFloat(d.amount).toLocaleString() %></td>
                        <td><%= fundLabels[d.fund_category] || d.fund_category %></td>
                        <td><%= d.donation_type || 'Sadqa' %></td>
                        <td><%= d.payment_method || '-' %></td>
                        <td>
                            <div style="display: flex; gap: 0.4rem;">
                                <a href="/donations/receipt/<%= d.id %>" class="btn-secondary nav-btn" target="_blank"><i class="bi bi-file-earmark-pdf-fill"></i></a>
                                <button type="button" class="btn-secondary nav-btn" onclick='openEditModal(<%- JSON.stringify({ id: d.id, amount: d.amount, date: new Date(d.date).toISOString().slice(0,10), fund_category: d.fund_category, payment_method: d.payment_method, notes: d.notes || "", donor_name: d.donor_name, donation_type: d.donation_type }) %>)'><i class="bi bi-pencil-square"></i></button>
                                <form action="/donations/delete/<%= d.id %>" method="POST" onsubmit="return confirm('Delete this donation record?')">
                                    <input type="hidden" name="redirect_to" value="/donations">
                                    <button type="submit" class="btn-danger nav-btn"><i class="bi bi-trash3-fill"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="7" style="text-align: center; color: #64748b;">No donations logged this month yet.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<% if (recentThisMonth.length > 10) { %>
    <div style="text-align: center; margin-top: 1rem;">
        <button type="button" id="btn-show-more-recent" class="btn-secondary" style="font-size: 0.9rem; padding: 0.5rem 1.5rem;" onclick="showAllRecentDonations()">
            <i class="bi bi-chevron-down"></i> Show All Recent Donations (<%= recentThisMonth.length - 10 %> more)
        </button>
    </div>
<% } %>

<!-- Donors Directory & Search Collapsible Panel -->
<details id="donors-directory-panel" class="ledger-details" <%= searchDonor ? 'open' : '' %> style="margin-top: 2rem;">
    <summary class="ledger-summary">
        <span><i class="bi bi-people-fill"></i> View & Search Donors Directory <%= searchDonor ? '(Active Search)' : '' %></span>
        <i class="bi bi-chevron-down toggle-icon"></i>
    </summary>
    <div style="padding: 1.5rem;">
        <!-- Search bar inside collapsible -->
        <form action="/donations" method="GET" class="filter-content" style="padding: 0 0 1.25rem 0; margin-bottom: 1.25rem; border-bottom: 1px solid var(--border);">
            <div class="form-group" style="max-width: 400px; flex: 1;">
                <label for="searchDonor" style="font-weight: 600; margin-bottom: 0.5rem; display: block;">Search Donors</label>
                <input type="text" name="searchDonor" id="searchDonor" class="form-control" value="<%= searchDonor || '' %>" placeholder="Search by donor name or referred by...">
            </div>
            <div style="display: flex; gap: 0.5rem; align-items: flex-end;">
                <button type="submit" class="btn-secondary" style="height: 38px;">Search</button>
                <a href="/donations" class="btn-secondary" style="height: 38px; display: inline-flex; align-items: center;">Reset</a>
            </div>
        </form>

        <div class="table-container" style="margin-bottom: 0; box-shadow: none; border: 1px solid var(--border);">
            <table>
                <thead>
                    <tr>
                        <th>Donor Name</th>
                        <th>Contact No.</th>
                        <th>Referred By</th>
                        <th>Monthly Commitment</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (donors.length > 0) { %>
                        <% donors.forEach((d, idx) => { %>
                            <tr class="donor-directory-row <%= idx >= 10 ? 'donor-directory-hidden' : '' %>" style="<%= idx >= 10 ? 'display: none;' : '' %>">
                                <td style="font-weight: 600;"><a href="/donations/donor/<%= d.id %>" style="color: var(--primary-color, #4f46e5); text-decoration: none;"><%= d.name %></a></td>
                                <td><%= d.contact_no || '-' %></td>
                                <td><%= d.referred_by || '-' %></td>
                                <td style="font-weight: 500; color: <%= d.monthly_commitment ? '#0369a1' : '#64748b' %>;">
                                    <%= d.monthly_commitment ? 'Yes' : 'No' %>
                                </td>
                                <td>
                                    <div style="display: flex; gap: 0.5rem;">
                                        <a href="/donations/donor/<%= d.id %>" class="btn-secondary nav-btn"><i class="bi bi-person-vcard-fill"></i> View Profile</a>
                                        <button type="button" class="btn-secondary nav-btn" onclick='openEditDonorModal(<%- JSON.stringify({ id: d.id, name: d.name, contact_no: d.contact_no || "", referred_by: d.referred_by || "", monthly_commitment: d.monthly_commitment || 0, monthly_commitment_amount: d.monthly_commitment_amount || "", preferred_fund_category: d.preferred_fund_category || "general", preferred_payment_method: d.preferred_payment_method || "Online", preferred_member: d.preferred_member || "" }) %>)'><i class="bi bi-pencil-square"></i> Edit</button>
                                        <form action="/donations/donor/delete/<%= d.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this donor and all their donation records?')">
                                            <button type="submit" class="btn-danger nav-btn"><i class="bi bi-trash3-fill"></i> Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" style="text-align: center; color: #64748b; padding: 1.5rem;">No donors found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <% if (donors.length > 10) { %>
            <div style="text-align: center; margin-top: 1rem;">
                <button type="button" id="btn-show-more-donors" class="btn-secondary" style="font-size: 0.9rem; padding: 0.5rem 1.5rem;" onclick="showAllDonors()">
                    <i class="bi bi-chevron-down"></i> Show All Donors (<%= donors.length - 10 %> more)
                </button>
            </div>
        <% } %>
    </div>
</details>

<!-- Edit Donation Modal -->
<div id="editModal" class="card" style="display: none; max-width: 420px; margin: 1rem auto; position: fixed; top: 15%; left: 50%; transform: translate(-50%, 0); z-index: 1000; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
    <h3 style="margin-bottom: 1rem;" id="editModalTitle">Edit Donation</h3>
    <form id="editForm" method="POST">
        <input type="hidden" name="redirect_to" value="/donations">
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Amount (PKR)</label>
            <input type="number" step="0.01" id="editAmount" name="amount" class="form-control" required>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Date</label>
            <input type="date" id="editDate" name="date" class="form-control" required>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Account to Transfer Fund</label>
            <select id="editFundCategory" name="fund_category" class="form-control" onchange="toggleDirectOption(this.value, 'edit_direct_option_group')">
                <option value="general">Member Account</option>
                <option value="trust">Trust Account</option>
            </select>
        </div>
        <div id="edit_direct_option_group" class="form-group" style="display: none; margin-bottom: 1rem;">
            <label>Member Account Option *</label>
            <div style="display: flex; gap: 0.5rem; align-items: center;">
                <select id="edit_direct_ref" name="direct_ref" class="form-control">
                    <option value="Faheem Zafar">Faheem Zafar</option>
                    <option value="Kamal Muhammad">Kamal Muhammad</option>
                    <option value="Khurram Shahzad">Khurram Shahzad</option>
                </select>
                <button type="button" class="btn-secondary" style="padding: 0.5rem; height: 38px; display: inline-flex; align-items: center; justify-content: center;" onclick="addNewDirectOption('edit_direct_ref')"><i class="bi bi-plus-lg"></i></button>
            </div>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Donation Type</label>
            <select id="editDonationType" name="donation_type" class="form-control">
                <option value="Sadqa">Sadqa</option>
                <option value="Zakat">Zakat</option>
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Payment Method</label>
            <select id="editPaymentMethod" name="payment_method" class="form-control">
                <option value="Cash">Cash</option>
                <option value="Online">Online</option>
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label>Notes</label>
            <input type="text" id="editNotes" name="notes" class="form-control">
        </div>
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
            <button type="button" class="btn-secondary" onclick="closeEditModal()">Cancel</button>
            <button type="submit" class="btn-primary">Save Changes</button>
        </div>
    </form>
</div>
<div id="editModalOverlay" style="display: none; position: fixed; top: 0; left: 0; width:100%; height:100%; background: rgba(0,0,0,0.4); z-index: 999;" onclick="closeEditModal()"></div>

<!-- Edit Donor Modal -->
<div id="editDonorModal" class="card" style="display: none; max-width: 420px; margin: 1rem auto; position: fixed; top: 20%; left: 50%; transform: translate(-50%, 0); z-index: 1000; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
    <h3 style="margin-bottom: 1rem;">Edit Donor Details</h3>
    <form id="editDonorForm" method="POST">
        <div class="form-group" style="margin-bottom: 1rem;">
            <label for="editDonorName">Donor Name *</label>
            <input type="text" id="editDonorName" name="name" class="form-control" required>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label for="editDonorContact">Contact Number</label>
            <input type="text" id="editDonorContact" name="contact_no" class="form-control">
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label for="editDonorReferred">Referred By</label>
            <div style="display: flex; gap: 0.5rem; align-items: center;">
                <select id="editDonorReferred" name="referred_by" class="form-control">
                    <option value="">-- None (Direct) --</option>
                    <option value="Faheem Zafar">Faheem Zafar</option>
                    <option value="Kamal Muhammad">Kamal Muhammad</option>
                    <option value="Khurram Shahzad">Khurram Shahzad</option>
                </select>
                <button type="button" class="btn-secondary" style="padding: 0.5rem; height: 38px; display: inline-flex; align-items: center; justify-content: center;" onclick="addNewReferredOption('editDonorReferred')"><i class="bi bi-plus-lg"></i></button>
            </div>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label for="editDonorPreferredFund">Preferred Account to Transfer Fund</label>
            <select name="preferred_fund_category" id="editDonorPreferredFund" class="form-control" onchange="toggleDirectOption(this.value, 'edit_preferred_member_group')">
                <option value="general">Member Account</option>
                <option value="trust">Trust Account</option>
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label for="editDonorPreferredMethod">Preferred Method</label>
            <select name="preferred_payment_method" id="editDonorPreferredMethod" class="form-control">
                <option value="Online">Online</option>
                <option value="Cash">Cash</option>
            </select>
        </div>
        <div id="edit_preferred_member_group" class="form-group" style="display: none; margin-bottom: 1rem;">
            <label for="editDonorPreferredMember">Preferred Member Account Option</label>
            <div style="display: flex; gap: 0.5rem; align-items: center;">
                <select id="editDonorPreferredMember" name="preferred_member" class="form-control">
                    <option value="">-- Select Member --</option>
                    <option value="Faheem Zafar">Faheem Zafar</option>
                    <option value="Kamal Muhammad">Kamal Muhammad</option>
                    <option value="Khurram Shahzad">Khurram Shahzad</option>
                </select>
                <button type="button" class="btn-secondary" style="padding: 0.5rem; height: 38px; display: inline-flex; align-items: center; justify-content: center;" onclick="addNewDirectOption('editDonorPreferredMember')"><i class="bi bi-plus-lg"></i></button>
            </div>
        </div>
        <div class="form-checkbox" style="margin-bottom: 1rem; display: flex; flex-direction: row; align-items: center; justify-content: flex-start; gap: 0.5rem;">
            <input type="checkbox" id="editDonorMonthlyCommitment" name="monthly_commitment" value="1" style="width: 18px; height: 18px; cursor: pointer; margin: 0;" onchange="toggleCommitmentAmount(this.checked, 'edit_commitment_amount_group')">
            <label for="editDonorMonthlyCommitment" style="margin-bottom: 0; cursor: pointer; font-weight: 500;">Monthly Commitment Donor</label>
        </div>
        <div id="edit_commitment_amount_group" class="form-group" style="display: none; margin-bottom: 1.5rem;">
            <label for="editDonorMonthlyCommitmentAmount">Monthly Commitment Amount (PKR) *</label>
            <input type="number" step="0.01" id="editDonorMonthlyCommitmentAmount" name="monthly_commitment_amount" class="form-control" placeholder="0.00">
        </div>
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
            <button type="button" class="btn-secondary" onclick="closeEditDonorModal()">Cancel</button>
            <button type="submit" class="btn-primary">Save Changes</button>
        </div>
    </form>
</div>
<div id="editDonorModalOverlay" style="display: none; position: fixed; top: 0; left: 0; width:100%; height:100%; background: rgba(0,0,0,0.4); z-index: 999;" onclick="closeEditDonorModal()"></div>

<script>
    function openEditModal(d) {
        document.getElementById('editForm').action = '/donations/edit/' + d.id;
        document.getElementById('editModalTitle').innerText = 'Edit Donation: ' + d.donor_name;
        document.getElementById('editAmount').value = d.amount;
        document.getElementById('editDate').value = d.date;
        document.getElementById('editFundCategory').value = d.fund_category;
        document.getElementById('editDonationType').value = d.donation_type || 'Sadqa';
        document.getElementById('editPaymentMethod').value = d.payment_method || '';
        
        let directVal = '';
        let cleanNotes = d.notes || '';
        if (cleanNotes.startsWith('[Direct: ')) {
            const endIndex = cleanNotes.indexOf(']');
            if (endIndex > -1) {
                directVal = cleanNotes.slice(9, endIndex);
                cleanNotes = cleanNotes.slice(endIndex + 1).trim();
            }
        }
        
        const editSelect = document.getElementById('edit_direct_ref');
        if (d.fund_category === 'general') {
            document.getElementById('edit_direct_option_group').style.display = 'block';
            if (directVal) {
                let exists = false;
                for (let i = 0; i < editSelect.options.length; i++) {
                    if (editSelect.options[i].value === directVal) {
                        exists = true;
                        break;
                    }
                }
                if (!exists) {
                    const opt = document.createElement('option');
                    opt.value = directVal;
                    opt.textContent = directVal;
                    editSelect.appendChild(opt);
                }
                editSelect.value = directVal;
            }
        } else {
            document.getElementById('edit_direct_option_group').style.display = 'none';
        }
        
        document.getElementById('editNotes').value = cleanNotes;
        document.getElementById('editModal').style.display = 'block';
        document.getElementById('editModalOverlay').style.display = 'block';
    }
    function closeEditModal() {
        document.getElementById('editModal').style.display = 'none';
        document.getElementById('editModalOverlay').style.display = 'none';
    }

    function openEditDonorModal(d) {
        document.getElementById('editDonorForm').action = '/donations/donor/edit/' + d.id;
        document.getElementById('editDonorName').value = d.name;
        document.getElementById('editDonorContact').value = d.contact_no || '';
        
        const refSelect = document.getElementById('editDonorReferred');
        const refVal = d.referred_by || '';
        if (refVal) {
            let exists = false;
            for (let i = 0; i < refSelect.options.length; i++) {
                if (refSelect.options[i].value === refVal) {
                    exists = true;
                    break;
                }
            }
            if (!exists) {
                const opt = document.createElement('option');
                opt.value = refVal;
                opt.textContent = refVal;
                refSelect.appendChild(opt);
            }
            refSelect.value = refVal;
        } else {
            refSelect.value = '';
        }
        
        const prefFund = d.preferred_fund_category || 'general';
        document.getElementById('editDonorPreferredFund').value = prefFund;
        document.getElementById('editDonorPreferredMethod').value = d.preferred_payment_method || 'Online';
        
        const prefMemberSelect = document.getElementById('editDonorPreferredMember');
        const prefMemberVal = d.preferred_member || '';
        if (prefFund === 'general') {
            document.getElementById('edit_preferred_member_group').style.display = 'block';
            if (prefMemberVal) {
                let exists = false;
                for (let i = 0; i < prefMemberSelect.options.length; i++) {
                    if (prefMemberSelect.options[i].value === prefMemberVal) {
                        exists = true;
                        break;
                    }
                }
                if (!exists) {
                    const opt = document.createElement('option');
                    opt.value = prefMemberVal;
                    opt.textContent = prefMemberVal;
                    prefMemberSelect.appendChild(opt);
                }
                prefMemberSelect.value = prefMemberVal;
            } else {
                prefMemberSelect.value = '';
            }
        } else {
            document.getElementById('edit_preferred_member_group').style.display = 'none';
            prefMemberSelect.value = '';
        }
        
        document.getElementById('editDonorMonthlyCommitment').checked = d.monthly_commitment === 1;
        document.getElementById('editDonorMonthlyCommitmentAmount').value = d.monthly_commitment_amount || '';
        toggleCommitmentAmount(d.monthly_commitment === 1, 'edit_commitment_amount_group');
        
        document.getElementById('editDonorModal').style.display = 'block';
        document.getElementById('editDonorModalOverlay').style.display = 'block';
    }
    function closeEditDonorModal() {
        document.getElementById('editDonorModal').style.display = 'none';
        document.getElementById('editDonorModalOverlay').style.display = 'none';
    }

    function showAllRecentDonations() {
        const hiddenRows = document.querySelectorAll('.recent-donation-hidden');
        hiddenRows.forEach(row => {
            row.style.display = '';
        });
        const btn = document.getElementById('btn-show-more-recent');
        if (btn) btn.style.display = 'none';
    }

    function showAllDonors() {
        const hiddenRows = document.querySelectorAll('.donor-directory-hidden');
        hiddenRows.forEach(row => {
            row.style.display = '';
        });
        const btn = document.getElementById('btn-show-more-donors');
        if (btn) btn.style.display = 'none';
    }

    // Toggle Direct Option Group visibility
    function toggleDirectOption(value, elementId) {
        const el = document.getElementById(elementId);
        if (el) {
            el.style.display = (value === 'general') ? 'block' : 'none';
        }
    }

    // Add new option to the direct select box dynamically
    function addNewDirectOption(selectId) {
        const name = prompt("Enter name of new direct option:");
        if (name && name.trim() !== "") {
            const selectEl = document.getElementById(selectId);
            const opt = document.createElement("option");
            opt.value = name.trim();
            opt.textContent = name.trim();
            selectEl.appendChild(opt);
            selectEl.value = name.trim();
        }
    }

    // Add new option to the referred select box dynamically
    function addNewReferredOption(selectId) {
        const name = prompt("Enter name of new referrer:");
        if (name && name.trim() !== "") {
            const selectEl = document.getElementById(selectId);
            const opt = document.createElement("option");
            opt.value = name.trim();
            opt.textContent = name.trim();
            selectEl.appendChild(opt);
            selectEl.value = name.trim();
        }
    }

    // Custom Searchable Dropdown
    document.addEventListener('DOMContentLoaded', function() {
        const donorSearch = document.getElementById('donor_search');
        const donorDropdown = document.getElementById('donor_dropdown_list');
        const donorSelect = document.getElementById('donor_id');
        const dropdownItems = donorDropdown.querySelectorAll('.dropdown-donor-item');
        const noResults = document.getElementById('no_results');

        if (!donorSearch) return;

        // Recent Donations filter
        const searchRecent = document.getElementById('searchRecentDonations');
        if (searchRecent) {
            searchRecent.addEventListener('input', function(e) {
                const query = e.target.value.toLowerCase().trim();
                const rows = document.querySelectorAll('.recent-donation-row');
                const showMoreBtn = document.getElementById('btn-show-more-recent');
                
                rows.forEach((row, idx) => {
                    const name = row.querySelector('.recent-donor-name').textContent.toLowerCase();
                    if (name.includes(query)) {
                        if (query !== '') {
                            row.style.display = '';
                        } else {
                            row.style.display = idx >= 10 ? 'none' : '';
                        }
                    } else {
                        row.style.display = 'none';
                    }
                });
                
                if (showMoreBtn) {
                    showMoreBtn.style.display = query !== '' ? 'none' : '';
                }
            });
        }

        // Show dropdown on focus
        donorSearch.addEventListener('focus', () => {
            donorDropdown.style.display = 'block';
        });

        // Filter items on input
        donorSearch.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase().trim();
            let matchCount = 0;
            
            dropdownItems.forEach(item => {
                const text = item.textContent.toLowerCase();
                if (text.includes(query)) {
                    item.style.display = 'block';
                    matchCount++;
                } else {
                    item.style.display = 'none';
                }
            });
            
            if (matchCount === 0) {
                noResults.style.display = 'block';
            } else {
                noResults.style.display = 'none';
            }
        });

        // Click item to select
        dropdownItems.forEach(item => {
            item.addEventListener('click', () => {
                const val = item.getAttribute('data-value');
                const name = item.getAttribute('data-name');
                const lastAmount = item.getAttribute('data-last-amount');
                const prefFund = item.getAttribute('data-preferred-fund') || 'general';
                const prefPayment = item.getAttribute('data-preferred-payment') || 'Online';
                const prefMember = item.getAttribute('data-preferred-member') || '';
                
                donorSelect.value = val;
                donorSearch.value = name;
                donorDropdown.style.display = 'none';
                
                const commitmentAmount = item.getAttribute('data-commitment-amount');
                
                // Pre-populate fields automatically
                if (commitmentAmount && commitmentAmount.trim() !== '') {
                    document.getElementById('amount').value = commitmentAmount;
                } else if (lastAmount) {
                    document.getElementById('amount').value = lastAmount;
                } else {
                    document.getElementById('amount').value = '';
                }
                
                document.getElementById('fund_category').value = prefFund;
                document.getElementById('payment_method').value = prefPayment;
                
                // Toggle Direct Option Group based on pre-populated Fund Category
                toggleDirectOption(prefFund, 'direct_option_group');
                
                if (prefFund === 'general' && prefMember) {
                    const directRefSelect = document.getElementById('direct_ref');
                    let exists = false;
                    for (let i = 0; i < directRefSelect.options.length; i++) {
                        if (directRefSelect.options[i].value === prefMember) {
                            exists = true;
                            break;
                        }
                    }
                    if (!exists) {
                        const opt = document.createElement('option');
                        opt.value = prefMember;
                        opt.textContent = prefMember;
                        directRefSelect.appendChild(opt);
                    }
                    directRefSelect.value = prefMember;
                }
            });
        });

        // Close dropdown if clicking outside
        document.addEventListener('click', (e) => {
            if (!donorSearch.contains(e.target) && !donorDropdown.contains(e.target)) {
                donorDropdown.style.display = 'none';
                
                // Reset search box if no valid selection is made
                if (donorSelect.value === "") {
                    donorSearch.value = "";
                } else {
                    // Match select option name
                    const activeItem = Array.from(dropdownItems).find(item => item.getAttribute('data-value') === donorSelect.value);
                    if (activeItem) {
                        donorSearch.value = activeItem.getAttribute('data-name');
                    }
                }
            }
        });
    });

    function toggleCommitmentAmount(checked, elementId) {
        const el = document.getElementById(elementId);
        if (el) {
            el.style.display = checked ? 'block' : 'none';
            const input = el.querySelector('input');
            if (input) {
                input.required = checked;
                if (!checked) input.value = '';
            }
        }
    }
</script>

<%- include('partials/footer') %>
