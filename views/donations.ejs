<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-heart-fill"></i> Donations Overview</h1>
</div>

<div class="filter-bar" style="margin-bottom: 1.5rem;">
    <a href="/donations" class="nav-tab active">Overview</a>
    <a href="/donations/matrix" class="nav-tab">Matrix View</a>
</div>

<!-- KPI Cards -->
<div class="kpi-grid" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
    <div class="card kpi-card">
        <span class="kpi-icon green"><i class="bi bi-cash-coin"></i></span>
        <span class="kpi-label">This Month's Donations</span>
        <span class="kpi-value" style="font-size: 1.6rem;">PKR <%= thisMonthTotal.toLocaleString() %></span>
        <span class="kpi-subtitle"><%= thisMonthDonorCount %> donor(s) contributed</span>
    </div>
    <div class="card kpi-card">
        <span class="kpi-icon amber"><i class="bi bi-person-exclamation"></i></span>
        <span class="kpi-label">Donors to Reconnect With</span>
        <span class="kpi-value" style="font-size: 1.6rem;"><%= lapsedDonors.length %></span>
        <span class="kpi-subtitle">Gave 6 months straight, missed this month</span>
    </div>
    <div class="card kpi-card">
        <span class="kpi-icon purple"><i class="bi bi-piggy-bank-fill"></i></span>
        <span class="kpi-label">All-Time Total</span>
        <span class="kpi-value" style="font-size: 1.6rem;">PKR <%= totalAllTime.toLocaleString() %></span>
    </div>
    <div class="card kpi-card" style="cursor: pointer;" onclick="const panel = document.getElementById('donors-directory-panel'); if (panel) { panel.open = true; panel.scrollIntoView({ behavior: 'smooth' }); }">
        <span class="kpi-icon blue"><i class="bi bi-people-fill"></i></span>
        <span class="kpi-label">Total Donors Registered</span>
        <span class="kpi-value" style="font-size: 1.6rem;"><%= totalDonorCount %></span>
    </div>
    <div class="card kpi-card" style="grid-row: span 1; min-height: 160px;">
        <span class="kpi-icon teal"><i class="bi bi-trophy-fill"></i></span>
        <span class="kpi-label">Top 5 Donors (All-Time)</span>
        <ul style="list-style: none; font-size: 0.82rem; padding: 0; margin-top: 0.5rem; margin-bottom: 0;">
            <% topDonors.forEach((td, i) => { %>
                <li style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem; gap: 0.5rem;">
                    <span style="display: inline-flex; min-width: 0; flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        <%= i+1 %>. <a href="/donations/donor/<%= td.id %>" style="color: var(--primary-color, #4f46e5); text-decoration: none; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: inline;"><%= td.name %></a>
                    </span>
                    <span style="font-weight: 700; color: #15803d; flex-shrink: 0;">PKR <%= parseFloat(td.total_amount).toLocaleString() %></span>
                </li>
            <% }) %>
        </ul>
    </div>
</div>

<!-- Quick Add Forms -->
<div class="form-grid" style="grid-template-columns: 1fr 1fr; margin-bottom: 2rem;">
    <div class="card">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);"><i class="bi bi-person-plus-fill"></i> Register New Donor</h3>
        <form action="/donations/donor/add" method="POST">
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="donorName">Donor Name *</label>
                <input type="text" id="donorName" name="name" class="form-control" required placeholder="e.g. Ali Irfan">
            </div>
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="contactNo">Contact Number</label>
                <input type="text" id="contactNo" name="contact_no" class="form-control" placeholder="e.g. 0300-XXXXXXX">
            </div>
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label for="referredBy">Referred By</label>
                <input type="text" id="referredBy" name="referred_by" class="form-control" placeholder="e.g. Faheem Zafar">
            </div>
            <button type="submit" class="btn-primary"><i class="bi bi-check-circle-fill"></i> Register Donor</button>
        </form>
    </div>

    <div class="card">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);"><i class="bi bi-cash-coin"></i> Record Donation Received</h3>
        <form action="/donations/add" method="POST">
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="donor_id">Select Donor *</label>
                <select name="donor_id" id="donor_id" class="form-control" required>
                    <option value="">-- Select Donor --</option>
                    <% donors.forEach(d => { %>
                        <option value="<%= d.id %>"><%= d.name %> (Ref: <%= d.referred_by || 'Direct' %>)</option>
                    <% }) %>
                </select>
            </div>
            <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                    <label for="amount">Amount (PKR) *</label>
                    <input type="number" step="0.01" id="amount" name="amount" class="form-control" required placeholder="0.00">
                </div>
                <div class="form-group">
                    <label for="date">Date Received</label>
                    <input type="date" id="date" name="date" class="form-control">
                </div>
            </div>
            <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                <div class="form-group">
                    <label for="fund_category">Fund Category</label>
                    <select name="fund_category" id="fund_category" class="form-control">
                        <option value="general">General / Direct</option>
                        <option value="trust">Trust Account</option>
                        <option value="student_support">Student Sponsorship</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="payment_method">Payment Method</label>
                    <input type="text" id="payment_method" name="payment_method" class="form-control" value="Cash">
                </div>
            </div>
            <button type="submit" class="btn-primary"><i class="bi bi-check-circle-fill"></i> Log Donation</button>
        </form>
    </div>
</div>

<!-- Donors to Reconnect With -->
<% if (lapsedDonors.length > 0) { %>
<div class="section-header">
    <h2 class="section-title"><i class="bi bi-person-exclamation"></i> Donors to Reconnect With</h2>
</div>
<div class="card" style="border-left: 4px solid #d97706; margin-bottom: 2rem;">
    <p style="color: #64748b; font-size: 0.875rem; margin-bottom: 1rem;">
        These donors gave consistently for the last 6 months but haven't donated this month yet &mdash; a good list to call or message.
    </p>
    <div class="table-container" style="border: none; box-shadow: none; margin-bottom: 0;">
        <table>
            <thead>
                <tr>
                    <th>Donor Name</th>
                    <th>Contact No.</th>
                    <th>Referred By</th>
                    <th>Last Donation</th>
                    <th style="text-align: right;">Last Amount (PKR)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <% lapsedDonors.forEach(ld => { %>
                    <tr>
                        <td style="font-weight: 600;"><%= ld.donor.name %></td>
                        <td><%= ld.donor.contact_no || '-' %></td>
                        <td><%= ld.donor.referred_by || '-' %></td>
                        <td><%= ld.lastDonationDate ? new Date(ld.lastDonationDate).toLocaleDateString() : '-' %></td>
                        <td style="text-align: right;"><%= ld.lastDonationAmount ? parseFloat(ld.lastDonationAmount).toLocaleString() : '-' %></td>
                        <td><a href="/donations/donor/<%= ld.donor.id %>" class="btn-secondary nav-btn"><i class="bi bi-person-vcard-fill"></i> View</a></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<!-- Recent Donations This Month -->
<div class="section-header">
    <h2 class="section-title"><i class="bi bi-clock-history"></i> Recent Donations This Month</h2>
</div>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Donor</th>
                <th>Date</th>
                <th style="text-align: right;">Amount (PKR)</th>
                <th>Fund</th>
                <th>Method</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            <% if (recentThisMonth.length > 0) { %>
                <% recentThisMonth.forEach(d => { %>
                    <tr>
                        <td style="font-weight: 600;"><a href="/donations/donor/<%= d.donor_id %>" style="color: var(--primary-color); text-decoration: none;"><%= d.donor_name %></a></td>
                        <td><%= new Date(d.date).toLocaleDateString() %></td>
                        <td style="text-align: right; font-weight: 600; color: #15803d;"><%= parseFloat(d.amount).toLocaleString() %></td>
                        <td><%= fundLabels[d.fund_category] || d.fund_category %></td>
                        <td><%= d.payment_method || '-' %></td>
                        <td>
                            <div style="display: flex; gap: 0.4rem;">
                                <a href="/donations/receipt/<%= d.id %>" class="btn-secondary nav-btn" target="_blank"><i class="bi bi-file-earmark-pdf-fill"></i></a>
                                <button type="button" class="btn-secondary nav-btn" onclick='openEditModal(<%- JSON.stringify({ id: d.id, amount: d.amount, date: new Date(d.date).toISOString().slice(0,10), fund_category: d.fund_category, payment_method: d.payment_method, notes: d.notes || "", donor_name: d.donor_name }) %>)'><i class="bi bi-pencil-square"></i></button>
                                <form action="/donations/delete/<%= d.id %>" method="POST" onsubmit="return confirm('Delete this donation record?')">
                                    <input type="hidden" name="redirect_to" value="/donations">
                                    <button type="submit" class="btn-danger nav-btn"><i class="bi bi-trash3-fill"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="6" style="text-align: center; color: #64748b;">No donations logged this month yet.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<!-- Donors Directory & Search Collapsible Panel -->
<details id="donors-directory-panel" class="ledger-details" <%= searchDonor ? 'open' : '' %> style="margin-top: 2rem;">
    <summary class="ledger-summary">
        <span><i class="bi bi-people-fill"></i> View & Search Donors Directory <%= searchDonor ? '(Active Search)' : '' %></span>
        <i class="bi bi-chevron-down toggle-icon"></i>
    </summary>
    <div style="padding: 1.5rem;">
        <!-- Search bar inside collapsible -->
        <form action="/donations" method="GET" class="filter-content" style="padding: 0 0 1.25rem 0; margin-bottom: 1.25rem; border-bottom: 1px solid var(--border);">
            <div class="form-group" style="max-width: 400px; flex: 1;">
                <label for="searchDonor" style="font-weight: 600; margin-bottom: 0.5rem; display: block;">Search Donors</label>
                <input type="text" name="searchDonor" id="searchDonor" class="form-control" value="<%= searchDonor || '' %>" placeholder="Search by donor name or referred by...">
            </div>
            <div style="display: flex; gap: 0.5rem; align-items: flex-end;">
                <button type="submit" class="btn-secondary" style="height: 38px;">Search</button>
                <a href="/donations" class="btn-secondary" style="height: 38px; display: inline-flex; align-items: center;">Reset</a>
            </div>
        </form>

        <div class="table-container" style="margin-bottom: 0; box-shadow: none; border: 1px solid var(--border);">
            <table>
                <thead>
                    <tr>
                        <th>Donor Name</th>
                        <th>Contact No.</th>
                        <th>Referred By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (donors.length > 0) { %>
                        <% donors.forEach(d => { %>
                            <tr>
                                <td style="font-weight: 600;"><a href="/donations/donor/<%= d.id %>" style="color: var(--primary-color, #4f46e5); text-decoration: none;"><%= d.name %></a></td>
                                <td><%= d.contact_no || '-' %></td>
                                <td><%= d.referred_by || '-' %></td>
                                <td>
                                    <a href="/donations/donor/<%= d.id %>" class="btn-secondary nav-btn"><i class="bi bi-person-vcard-fill"></i> View Profile</a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" style="text-align: center; color: #64748b; padding: 1.5rem;">No donors found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</details>

<!-- Edit Donation Modal -->
<div id="editModal" class="card" style="display: none; max-width: 420px; margin: 1rem auto; position: fixed; top: 15%; left: 50%; transform: translate(-50%, 0); z-index: 1000; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
    <h3 style="margin-bottom: 1rem;" id="editModalTitle">Edit Donation</h3>
    <form id="editForm" method="POST">
        <input type="hidden" name="redirect_to" value="/donations">
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Amount (PKR)</label>
            <input type="number" step="0.01" id="editAmount" name="amount" class="form-control" required>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Date</label>
            <input type="date" id="editDate" name="date" class="form-control" required>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Fund Category</label>
            <select id="editFundCategory" name="fund_category" class="form-control">
                <option value="general">General / Direct</option>
                <option value="trust">Trust Account</option>
                <option value="student_support">Student Sponsorship</option>
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Payment Method</label>
            <input type="text" id="editPaymentMethod" name="payment_method" class="form-control">
        </div>
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label>Notes</label>
            <input type="text" id="editNotes" name="notes" class="form-control">
        </div>
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
            <button type="button" class="btn-secondary" onclick="closeEditModal()">Cancel</button>
            <button type="submit" class="btn-primary">Save Changes</button>
        </div>
    </form>
</div>
<div id="editModalOverlay" style="display: none; position: fixed; top: 0; left: 0; width:100%; height:100%; background: rgba(0,0,0,0.4); z-index: 999;" onclick="closeEditModal()"></div>

<script>
    function openEditModal(d) {
        document.getElementById('editForm').action = '/donations/edit/' + d.id;
        document.getElementById('editModalTitle').innerText = 'Edit Donation: ' + d.donor_name;
        document.getElementById('editAmount').value = d.amount;
        document.getElementById('editDate').value = d.date;
        document.getElementById('editFundCategory').value = d.fund_category;
        document.getElementById('editPaymentMethod').value = d.payment_method || '';
        document.getElementById('editNotes').value = d.notes || '';
        document.getElementById('editModal').style.display = 'block';
        document.getElementById('editModalOverlay').style.display = 'block';
    }
    function closeEditModal() {
        document.getElementById('editModal').style.display = 'none';
        document.getElementById('editModalOverlay').style.display = 'none';
    }
</script>

<%- include('partials/footer') %>
