<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-heart-fill"></i> Donation Records & Donor Registry</h1>
</div>

<div class="form-grid" style="grid-template-columns: 1fr 1fr; margin-bottom: 2rem;">
    <!-- Form 1: Add Donor -->
    <div class="card">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);">Register New Donor</h3>
        <form action="/donations/donor/add" method="POST">
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="donorName">Donor Name *</label>
                <input type="text" id="donorName" name="name" class="form-control" required placeholder="e.g. Ali Irfan">
            </div>
            
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="contactNo">Contact Number</label>
                <input type="text" id="contactNo" name="contact_no" class="form-control" placeholder="e.g. 0300-XXXXXXX">
            </div>
            
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label for="referredBy">Referred By</label>
                <input type="text" id="referredBy" name="referred_by" class="form-control" placeholder="e.g. Faheem Zafar">
            </div>
            
            <button type="submit" class="btn-primary">Register Donor</button>
        </form>
    </div>
    
    <!-- Form 2: Log Donation -->
    <div class="card">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);">Record Donation Received</h3>
        <form action="/donations/add" method="POST">
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="donor_id">Select Donor *</label>
                <select name="donor_id" id="donor_id" class="form-control" required>
                    <option value="">-- Select Donor --</option>
                    <% donors.forEach(d => { %>
                        <option value="<%= d.id %>"><%= d.name %> (Ref: <%= d.referred_by || 'Direct' %>)</option>
                    <% }) %>
                </select>
            </div>
            
            <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                    <label for="amount">Amount (PKR) *</label>
                    <input type="number" step="0.01" id="amount" name="amount" class="form-control" required placeholder="0.00">
                </div>
                
                <div class="form-group">
                    <label for="date">Date Received</label>
                    <input type="date" id="date" name="date" class="form-control">
                </div>
            </div>
            
            <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                <div class="form-group">
                    <label for="fund_category">Fund Category</label>
                    <select name="fund_category" id="fund_category" class="form-control">
                        <option value="general">General / Direct</option>
                        <option value="trust">Trust Account</option>
                        <option value="student_support">Student Sponsorship</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="payment_method">Payment Method</label>
                    <input type="text" id="payment_method" name="payment_method" class="form-control" value="Cash">
                </div>
            </div>
            
            <button type="submit" class="btn-primary">Log Donation</button>
        </form>
    </div>
</div>

<div class="section-header">
    <h2 class="section-title">2026 Donors & Monthly Donations Matrix</h2>
</div>

<!-- Table -->
<div class="table-container">
    <table class="matrix-table">
        <thead>
            <tr>
                <th style="text-align: left;">Donor Name</th>
                <th style="text-align: left;">Referred By</th>
                <th>Jan</th>
                <th>Feb</th>
                <th>Mar</th>
                <th>Apr</th>
                <th>May</th>
                <th>Jun</th>
                <th>Jul</th>
                <th>Aug</th>
                <th>Sep</th>
                <th>Oct</th>
                <th>Nov</th>
                <th>Dec</th>
                <th style="text-align: right; background-color: #f1f5f9;">Total</th>
            </tr>
        </thead>
        <tbody>
            <% if (donors.length > 0) { %>
                <% donors.forEach(d => { %>
                    <% 
                        const donorPayments = donationMap[d.id] || {};
                        let donorTotal = 0;
                    %>
                    <tr>
                        <td style="font-weight: 600; text-align: left;"><%= d.name %></td>
                        <td style="text-align: left;"><%= d.referred_by || '-' %></td>
                        
                        <% for (let m = 1; m <= 12; m++) { %>
                            <% const amt = donorPayments[m]; %>
                            <% if (amt !== undefined && amt > 0) { %>
                                <% donorTotal += amt; %>
                                <td class="cell-amount" style="color: #15803d; font-weight: 600;">
                                    <%= amt.toLocaleString() %>
                                </td>
                            <% } else { %>
                                <td style="color: #cbd5e1;">-</td>
                            <% } %>
                        <% } %>
                        <td style="text-align: right; font-weight: 700; background-color: #f8fafc;"><%= donorTotal > 0 ? donorTotal.toLocaleString() : '-' %></td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="15" style="text-align: center; color: #64748b;">No donors registered.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('partials/footer') %>
