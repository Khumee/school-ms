<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= tenant ? tenant.school_name : 'School Management System' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root {
            --primary-color: <%= tenant ? tenant.primary_color : '#3b82f6' %>;
            --secondary-color: <%= tenant ? tenant.secondary_color : '#1d4ed8' %>;
        }
    </style>
</head>
<body>
    <% if (session && session.userId) { %>
        <nav class="main-nav">
            <div class="nav-container">
                <a href="/" class="brand-link">
                    <% if (tenant && tenant.logo_url) { %>
                        <img src="<%= tenant.logo_url %>" alt="Logo" class="nav-logo">
                    <% } %>
                    <span class="brand-name"><%= tenant ? tenant.school_name : 'School Portal' %></span>
                </a>
                <ul class="nav-links">
                    <li><a href="/"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
                    <li><a href="/students"><i class="bi bi-mortarboard-fill"></i> Students</a></li>
                    <li><a href="/employees"><i class="bi bi-person-badge-fill"></i> Employees</a></li>
                    <li class="dropdown">
                        <a href="#" class="dropbtn"><i class="bi bi-cash-coin"></i> Fees</a>
                        <div class="dropdown-content">
                            <a href="/fees/ledger"><i class="bi bi-table"></i> Monthly Ledger</a>
                            <a href="/fees/concessions"><i class="bi bi-tags-fill"></i> Concessions</a>
                        </div>
                    </li>
                    <li><a href="/donations"><i class="bi bi-heart-fill"></i> Donations</a></li>
                    <li><a href="/attendance/employees"><i class="bi bi-calendar2-check-fill"></i> Attendance</a></li>
                    <li class="dropdown">
                        <a href="#" class="dropbtn"><i class="bi bi-journal-richtext"></i> Ledgers</a>
                        <div class="dropdown-content">
                            <a href="/expenses"><i class="bi bi-receipt"></i> Overhead Expenses</a>
                            <a href="/salaries"><i class="bi bi-wallet2"></i> Salaries/Payroll</a>
                        </div>
                    </li>
                    <li class="user-menu">
                        <span class="user-greeting"><i class="bi bi-person-circle"></i> Hi, <%= session.username %></span>
                        <a href="/change-password" class="btn-secondary nav-btn"><i class="bi bi-key-fill"></i> Password</a>
                        <a href="/logout" class="btn-danger nav-btn"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
    <% } %>
    <main class="main-content">
