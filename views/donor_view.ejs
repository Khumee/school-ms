<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-person-heart"></i> <%= donor.name %></h1>
    <a href="/donations" class="btn-secondary"><i class="bi bi-arrow-left"></i> Back to Donations</a>
</div>

<div class="kpi-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 1.5rem;">
    <div class="card kpi-card">
        <span class="kpi-icon pink"><i class="bi bi-telephone-fill"></i></span>
        <span class="kpi-label">Contact No.</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= donor.contact_no || '-' %></span>
    </div>
    <div class="card kpi-card">
        <span class="kpi-icon purple"><i class="bi bi-person-plus-fill"></i></span>
        <span class="kpi-label">Referred By</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= donor.referred_by || 'Direct' %></span>
    </div>
    <div class="card kpi-card">
        <span class="kpi-icon green"><i class="bi bi-heart-fill"></i></span>
        <span class="kpi-label">Total Donated (All Time)</span>
        <span class="kpi-value" style="font-size: 1.4rem;">PKR <%= totalDonated.toLocaleString() %></span>
    </div>
    <div class="card kpi-card">
        <span class="kpi-icon blue"><i class="bi bi-receipt"></i></span>
        <span class="kpi-label">Total Donations Logged</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= donations.length %></span>
    </div>
</div>

<div class="section-header">
    <h2 class="section-title"><i class="bi bi-clock-history"></i> Donation History</h2>
</div>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th style="text-align: right;">Amount (PKR)</th>
                <th>Fund Category</th>
                <th>Type</th>
                <th>Payment Method</th>
                <th>Notes</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            <% if (donations.length > 0) { %>
                <% donations.forEach(d => { %>
                    <tr>
                        <td><%= new Date(d.date).toLocaleDateString() %></td>
                        <td style="text-align: right; font-weight: 600; color: #15803d;"><%= parseFloat(d.amount).toLocaleString() %></td>
                        <td><%= fundLabels[d.fund_category] || d.fund_category %></td>
                        <td><%= d.donation_type || 'Sadqa' %></td>
                        <td><%= d.payment_method || '-' %></td>
                        <td><%= d.notes || '-' %></td>
                        <td>
                            <div style="display: flex; gap: 0.4rem;">
                                <a href="/donations/receipt/<%= d.id %>" class="btn-secondary nav-btn" target="_blank"><i class="bi bi-file-earmark-pdf-fill"></i></a>
                                <button type="button" class="btn-secondary nav-btn" onclick='openEditModal(<%- JSON.stringify({ id: d.id, amount: d.amount, date: new Date(d.date).toISOString().slice(0,10), fund_category: d.fund_category, payment_method: d.payment_method, notes: d.notes || "", donor_name: donor.name, donation_type: d.donation_type }) %>)'><i class="bi bi-pencil-square"></i></button>
                                <form action="/donations/delete/<%= d.id %>" method="POST" onsubmit="return confirm('Delete this donation record?')">
                                    <input type="hidden" name="redirect_to" value="/donations/donor/<%= donor.id %>">
                                    <button type="submit" class="btn-danger nav-btn"><i class="bi bi-trash3-fill"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="7" style="text-align: center; color: #64748b;">No donations recorded yet.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<!-- Edit Donation Modal -->
<div id="editModal" class="card" style="display: none; max-width: 420px; margin: 1rem auto; position: fixed; top: 15%; left: 50%; transform: translate(-50%, 0); z-index: 1000; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
    <h3 style="margin-bottom: 1rem;" id="editModalTitle">Edit Donation</h3>
    <form id="editForm" method="POST">
        <input type="hidden" name="redirect_to" value="/donations/donor/<%= donor.id %>">
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Amount (PKR)</label>
            <input type="number" step="0.01" id="editAmount" name="amount" class="form-control" required>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Date</label>
            <input type="date" id="editDate" name="date" class="form-control" required>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Fund Category</label>
            <select id="editFundCategory" name="fund_category" class="form-control">
                <option value="general">General / Direct</option>
                <option value="trust">Trust Account</option>
                <option value="student_support">Student Sponsorship</option>
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Donation Type</label>
            <select id="editDonationType" name="donation_type" class="form-control">
                <option value="Sadqa">Sadqa</option>
                <option value="Zakat">Zakat</option>
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label>Payment Method</label>
            <input type="text" id="editPaymentMethod" name="payment_method" class="form-control">
        </div>
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label>Notes</label>
            <input type="text" id="editNotes" name="notes" class="form-control">
        </div>
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
            <button type="button" class="btn-secondary" onclick="closeEditModal()">Cancel</button>
            <button type="submit" class="btn-primary">Save Changes</button>
        </div>
    </form>
</div>
<div id="editModalOverlay" style="display: none; position: fixed; top: 0; left: 0; width:100%; height:100%; background: rgba(0,0,0,0.4); z-index: 999;" onclick="closeEditModal()"></div>

<script>
    function openEditModal(d) {
        document.getElementById('editForm').action = '/donations/edit/' + d.id;
        document.getElementById('editModalTitle').innerText = 'Edit Donation: ' + d.donor_name;
        document.getElementById('editAmount').value = d.amount;
        document.getElementById('editDate').value = d.date;
        document.getElementById('editFundCategory').value = d.fund_category;
        document.getElementById('editDonationType').value = d.donation_type || 'Sadqa';
        document.getElementById('editPaymentMethod').value = d.payment_method || '';
        document.getElementById('editNotes').value = d.notes || '';
        document.getElementById('editModal').style.display = 'block';
        document.getElementById('editModalOverlay').style.display = 'block';
    }
    function closeEditModal() {
        document.getElementById('editModal').style.display = 'none';
        document.getElementById('editModalOverlay').style.display = 'none';
    }
</script>

<%- include('partials/footer') %>
