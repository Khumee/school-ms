<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-person-plus-fill"></i> New Student Admission</h1>
    <a href="/students" class="btn-secondary"><i class="bi bi-arrow-left"></i> Back to Directory</a>
</div>

<% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="card">
    <form action="/students/add" method="POST">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);">1. Academic & Admission Information</h3>
        <div class="form-grid">
            <div class="form-group">
                <label for="reg_no">Registration / Roll Number *</label>
                <input type="text" id="reg_no" name="reg_no" class="form-control" required placeholder="e.g. MIS-201">
            </div>
            
            <div class="form-group">
                <label for="class_id">Class</label>
                <select name="class_id" id="class_id" class="form-control">
                    <option value="">-- Select Class --</option>
                    <% classes.forEach(c => { %>
                        <option value="<%= c.id %>"><%= c.name %></option>
                    <% }) %>
                </select>
            </div>
            
            <div class="form-group">
                <label for="date_of_admission">Admission Date</label>
                <input type="date" id="date_of_admission" name="date_of_admission" class="form-control">
            </div>
            
            <div class="form-group">
                <label for="status">Status</label>
                <select name="status" id="status" class="form-control">
                    <option value="active">Active</option>
                    <option value="left">Left</option>
                    <option value="graduated">Graduated</option>
                </select>
            </div>
        </div>

        <h3 style="margin-top: 2rem; margin-bottom: 1rem; color: var(--primary-color);">2. Personal Information</h3>
        <div class="form-grid">
            <div class="form-group">
                <label for="name">Student Full Name *</label>
                <input type="text" id="name" name="name" class="form-control" required placeholder="e.g. Ahmed Ali">
            </div>
            
            <div class="form-group">
                <label for="gender">Gender</label>
                <select name="gender" id="gender" class="form-control">
                    <option value="male">Male</option>
                    <option value="female">Female</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="date_of_birth">Date of Birth</label>
                <input type="date" id="date_of_birth" name="date_of_birth" class="form-control">
            </div>
            
            <div class="form-group">
                <label for="blood_group">Blood Group</label>
                <input type="text" id="blood_group" name="blood_group" class="form-control" placeholder="e.g. O+">
            </div>
        </div>

        <h3 style="margin-top: 2rem; margin-bottom: 1rem; color: var(--primary-color);">3. Family & Contact Details</h3>
        <div class="form-grid">
            <div class="form-group">
                <label for="father_name">Father / Guardian Name</label>
                <input type="text" id="father_name" name="father_name" class="form-control">
            </div>
            
            <div class="form-group">
                <label for="father_phone">Father / Guardian Phone</label>
                <input type="text" id="father_phone" name="father_phone" class="form-control">
            </div>
            
            <div class="form-group">
                <label for="emergency_contact">Emergency Contact No</label>
                <input type="text" id="emergency_contact" name="emergency_contact" class="form-control">
            </div>
            
            <div class="form-group">
                <label for="previous_school_info">Previous School Details</label>
                <input type="text" id="previous_school_info" name="previous_school_info" class="form-control">
            </div>
        </div>
        
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="address">Residential Address</label>
            <textarea id="address" name="address" class="form-control" rows="2"></textarea>
        </div>

        <h3 style="margin-top: 2rem; margin-bottom: 1rem; color: var(--primary-color);">4. Admission Fee Details</h3>
        <div class="form-grid" style="margin-bottom: 1.5rem;">
            <div class="form-group">
                <label for="admission_fee">Admission Fee (PKR)</label>
                <input type="number" step="0.01" id="admission_fee" name="admission_fee" class="form-control" value="0.00">
            </div>
            
            <div class="form-group">
                <label for="admission_fee_status">Admission Fee Status</label>
                <select name="admission_fee_status" id="admission_fee_status" class="form-control" onchange="toggleAdmissionPaymentDate(this.value)">
                    <option value="unpaid">Unpaid</option>
                    <option value="paid">Paid</option>
                    <option value="waived">Waived</option>
                </select>
            </div>
            
            <div class="form-group" id="admission_payment_date_group" style="display: none;">
                <label for="admission_fee_payment_date">Payment Date</label>
                <input type="date" id="admission_fee_payment_date" name="admission_fee_payment_date" class="form-control">
            </div>
        </div>

        <div id="concession_settings_section">
            <h3 style="margin-top: 2rem; margin-bottom: 1rem; color: var(--primary-color);">5. Tuition Fee Concession Settings</h3>
            <div class="form-grid">
                <div class="form-group">
                    <label>Class Standard Fee (PKR)</label>
                    <input type="text" id="class_fee_display" class="form-control" readonly value="N/A" style="background-color: #f1f5f9;">
                </div>

                <div class="form-group">
                    <label for="custom_monthly_fee">Concession Amount (PKR)</label>
                    <input type="number" step="0.01" id="custom_monthly_fee" name="custom_monthly_fee" class="form-control" placeholder="0.00" value="0">
                </div>
                
                <div class="form-group form-checkbox" style="margin-top: 1.8rem;">
                    <input type="checkbox" id="has_concession" name="has_concession" value="1">
                    <label for="has_concession">Apply Fee Concession Support</label>
                </div>
                
                <div class="form-group" style="grid-column: span 2;">
                    <label for="concession_notes">Concession Notes / Remarks</label>
                    <textarea id="concession_notes" name="concession_notes" class="form-control" rows="4" placeholder="e.g. Welfare support, Staff discount"></textarea>
                </div>
            </div>
        </div>

        <div style="margin-top: 2rem; display: flex; gap: 1rem;">
            <button type="submit" class="btn-primary">Admit Student</button>
            <a href="/students" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

<script>
    const classFees = {
        <% classes.forEach(c => { %>
            "<%= c.id %>": <%= c.default_monthly_fee %>,
        <% }) %>
    };

    const classHifzStatus = {
        <% classes.forEach(c => { %>
            "<%= c.id %>": <%= c.is_hifz_class === 1 || c.is_hifz_class === true ? 'true' : 'false' %>,
        <% }) %>
    };

    const classSelect = document.getElementById('class_id');
    const classFeeDisplay = document.getElementById('class_fee_display');
    const concessionSection = document.getElementById('concession_settings_section');

    function updateClassFee() {
        const classId = classSelect.value;
        if (classId && classFees[classId] !== undefined) {
            classFeeDisplay.value = 'PKR ' + parseFloat(classFees[classId]).toLocaleString();
        } else {
            classFeeDisplay.value = 'N/A';
        }

        if (classId && classHifzStatus[classId] === true) {
            concessionSection.style.display = 'none';
        } else {
            concessionSection.style.display = 'block';
        }
    }

    function toggleAdmissionPaymentDate(status) {
        const dateGroup = document.getElementById('admission_payment_date_group');
        const dateInput = document.getElementById('admission_fee_payment_date');
        if (status === 'paid') {
            dateGroup.style.display = 'block';
            if (!dateInput.value) {
                dateInput.value = new Date().toISOString().substring(0, 10);
            }
        } else {
            dateGroup.style.display = 'none';
        }
    }

    classSelect.addEventListener('change', updateClassFee);
    updateClassFee(); // Run on initial load
    toggleAdmissionPaymentDate(document.getElementById('admission_fee_status').value);
</script>

<%- include('partials/footer') %>
