<%- include('partials/header') %>

<div style="display: flex; align-items: center; justify-content: center; min-height: 60vh;">
    <div style="text-align: center; max-width: 440px; padding: 2.5rem;">
        <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
                    display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; 
                    box-shadow: 0 4px 16px rgba(0,0,0,0.08);">
            <i class="bi bi-lock-fill" style="font-size: 2rem; color: #94a3b8;"></i>
        </div>
        <h2 style="font-size: 1.4rem; font-weight: 700; color: #1e293b; margin-bottom: 0.75rem;">
            Module Not Enabled
        </h2>
        <p style="color: #64748b; margin-bottom: 0.5rem; font-size: 0.95rem;">
            The <strong><%= moduleName %></strong> module is not active for your school.
        </p>
        <p style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 2rem;">
            Contact your system administrator to enable this feature from the Super Admin panel.
        </p>
        <a href="/" class="btn-primary" style="display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none;">
            <i class="bi bi-arrow-left"></i> Go to Dashboard
        </a>
    </div>
</div>

<%- include('partials/footer') %>
