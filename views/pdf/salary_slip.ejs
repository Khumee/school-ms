<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Salary Slip</title>
<style>
    @page { size: A4; margin: 0; }
    * { box-sizing: border-box; }
    body {
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #0f172a;
        margin: 0;
        padding: 40px 50px;
    }
    .receipt-box {
        border: 2px solid <%= tenant.primary_color || '#4f46e5' %>;
        border-radius: 14px;
        padding: 32px;
    }
    .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 3px solid <%= tenant.primary_color || '#4f46e5' %>;
        padding-bottom: 16px;
        margin-bottom: 20px;
    }
    .header-left { display: flex; align-items: center; gap: 14px; }
    .header-left img { height: 56px; max-width: 140px; object-fit: contain; }
    .school-name { font-size: 20px; font-weight: 800; color: #0f172a; margin: 0; }
    .school-sub { font-size: 11px; color: #64748b; margin: 2px 0 0; }
    .doc-title { text-align: right; }
    .doc-title h2 {
        margin: 0;
        font-size: 18px;
        color: <%= tenant.primary_color || '#4f46e5' %>;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .doc-title p { margin: 2px 0 0; font-size: 12px; color: #64748b; }
    .meta-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        margin-bottom: 22px;
        color: #334155;
    }
    table.details {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 18px;
    }
    table.details td {
        padding: 10px 12px;
        border: 1px solid #e2e8f0;
        font-size: 13px;
    }
    table.details td.label {
        background-color: #f8fafc;
        font-weight: 600;
        width: 35%;
        color: #475569;
    }
    table.breakdown {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 24px;
    }
    table.breakdown th, table.breakdown td {
        padding: 10px 12px;
        border: 1px solid #e2e8f0;
        font-size: 13px;
        text-align: left;
    }
    table.breakdown th {
        background-color: #f1f5f9;
        color: #475569;
    }
    table.breakdown td.amount { text-align: right; }
    .amount-box {
        background: linear-gradient(135deg, #059669, #047857);
        color: #fff;
        border-radius: 10px;
        padding: 18px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }
    .amount-box .label { font-size: 13px; opacity: 0.9; }
    .amount-box .value { font-size: 26px; font-weight: 800; }
    .signatures {
        display: flex;
        justify-content: space-between;
        margin-top: 50px;
    }
    .sign-block { text-align: center; width: 200px; }
    .sign-line { border-top: 1px solid #94a3b8; margin-bottom: 6px; }
    .sign-label { font-size: 11px; color: #64748b; }
    .footer-note { text-align: center; font-size: 10px; color: #94a3b8; margin-top: 30px; }
</style>
</head>
<body>
    <div class="receipt-box">
        <div class="header">
            <div class="header-left">
                <% if (tenant.logo_url) { %><img src="<%= tenant.logo_url %>" alt="logo"><% } %>
                <div>
                    <p class="school-name"><%= tenant.school_name %></p>
                    <p class="school-sub">Salary Slip</p>
                </div>
            </div>
            <div class="doc-title">
                <h2>Salary Slip</h2>
                <p>No. SL-<%= String(salary.id).padStart(5, '0') %></p>
            </div>
        </div>

        <div class="meta-row">
            <span>Pay Period: <strong><%= monthName %> <%= salary.year %></strong></span>
            <span>Paid Date: <strong><%= paidDateFormatted %></strong></span>
        </div>

        <table class="details">
            <tr>
                <td class="label">Employee Name</td>
                <td><%= employee.name %></td>
            </tr>
            <tr>
                <td class="label">Designation</td>
                <td><%= employee.designation %></td>
            </tr>
        </table>

        <table class="breakdown">
            <thead>
                <tr><th>Description</th><th style="text-align: right;">Amount (PKR)</th></tr>
            </thead>
            <tbody>
                <tr>
                    <td>Basic Salary</td>
                    <td class="amount"><%= Number(salary.basic_salary).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                </tr>
                <% if (salary.bonus > 0) { %>
                <tr>
                    <td>Bonus<%= salary.bonus_description ? ' (' + salary.bonus_description + ')' : '' %></td>
                    <td class="amount"><%= Number(salary.bonus).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                </tr>
                <% } %>
            </tbody>
        </table>

        <div class="amount-box">
            <span class="label">Net Amount Paid</span>
            <span class="value">PKR <%= Number(totalPaid).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
        </div>

        <div class="signatures">
            <div class="sign-block">
                <div class="sign-line"></div>
                <div class="sign-label">Employee Signature</div>
            </div>
            <div class="sign-block">
                <div class="sign-line"></div>
                <div class="sign-label">Authorized Signature</div>
            </div>
        </div>

        <p class="footer-note">This is a computer-generated salary slip from <%= tenant.school_name %>.</p>
    </div>
</body>
</html>
