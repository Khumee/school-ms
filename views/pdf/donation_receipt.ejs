<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Donation Receipt</title>
<style>
    @page { size: A4; margin: 0; }
    * { box-sizing: border-box; }
    body {
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #0f172a;
        margin: 0;
        padding: 40px 50px;
    }
    .receipt-box {
        border: 2px solid <%= tenant.primary_color || '#4f46e5' %>;
        border-radius: 14px;
        padding: 32px;
    }
    .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 3px solid <%= tenant.primary_color || '#4f46e5' %>;
        padding-bottom: 16px;
        margin-bottom: 20px;
    }
    .header-left { display: flex; align-items: center; gap: 14px; }
    .header-left img { height: 56px; max-width: 140px; object-fit: contain; }
    .logo-fallback {
        width: 56px;
        height: 56px;
        border-radius: 10px;
        background: linear-gradient(135deg, <%= tenant.primary_color || '#4f46e5' %>, <%= tenant.secondary_color || '#4338ca' %>);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: 800;
        flex-shrink: 0;
    }
    .school-name { font-size: 20px; font-weight: 800; color: #0f172a; margin: 0; }
    .school-sub { font-size: 11px; color: #64748b; margin: 2px 0 0; }
    .doc-title { text-align: right; }
    .doc-title h2 {
        margin: 0;
        font-size: 18px;
        color: <%= tenant.primary_color || '#4f46e5' %>;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .doc-title p { margin: 2px 0 0; font-size: 12px; color: #64748b; }
    .meta-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        margin-bottom: 22px;
        color: #334155;
    }
    table.details {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 24px;
    }
    table.details td {
        padding: 10px 12px;
        border: 1px solid #e2e8f0;
        font-size: 13px;
    }
    table.details td.label {
        background-color: #f8fafc;
        font-weight: 600;
        width: 35%;
        color: #475569;
    }
    .amount-box {
        background: linear-gradient(135deg, #db2777, #be185d);
        color: #fff;
        border-radius: 10px;
        padding: 18px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }
    .amount-box .label { font-size: 13px; opacity: 0.9; }
    .amount-box .value { font-size: 26px; font-weight: 800; }
    .footer-note { text-align: center; font-size: 10px; color: #94a3b8; margin-top: 30px; }
    .thanks { text-align: center; font-size: 13px; color: #334155; margin-bottom: 20px; font-style: italic; }
</style>
</head>
<body>
    <div class="receipt-box">
        <div class="header">
            <div class="header-left">
                <% if (tenant.logo_url) { %>
                    <img src="<%= tenant.logo_url %>" alt="logo">
                <% } else { %>
                    <div class="logo-fallback"><%= (tenant.school_name || 'S').trim().charAt(0).toUpperCase() %></div>
                <% } %>
                <div>
                    <p class="school-name"><%= tenant.school_name %></p>
                    <p class="school-sub">Donation Receipt</p>
                </div>
            </div>
            <div class="doc-title">
                <h2>Receipt</h2>
                <p>No. DN-<%= String(donation.id).padStart(5, '0') %></p>
            </div>
        </div>

        <div class="meta-row">
            <span>Date: <strong><%= dateFormatted %></strong></span>
            <span>Fund: <strong><%= fundCategoryLabel %></strong></span>
        </div>

        <table class="details">
            <tr>
                <td class="label">Donor Name</td>
                <td><%= donor.name %></td>
            </tr>
            <% if (donor.contact_no) { %>
            <tr>
                <td class="label">Contact No.</td>
                <td><%= donor.contact_no %></td>
            </tr>
            <% } %>
            <% if (donor.referred_by) { %>
            <tr>
                <td class="label">Referred By</td>
                <td><%= donor.referred_by %></td>
            </tr>
            <% } %>
            <tr>
                <td class="label">Payment Method</td>
                <td><%= donation.payment_method || 'Cash' %></td>
            </tr>
        </table>

        <div class="amount-box">
            <span class="label">Donation Amount</span>
            <span class="value">PKR <%= Number(donation.amount).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
        </div>

        <h4 style="margin: 20px 0 8px 0; font-size: 13px; text-transform: uppercase; color: <%= tenant.primary_color || '#4f46e5' %>; letter-spacing: 0.05em; border-bottom: 1px solid #cbd5e1; padding-bottom: 4px;">Donation Summary (Since Jan 1, 2026)</h4>
        <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 11px;">
            <thead>
                <tr style="background-color: #f8fafc; font-weight: 600; color: #475569;">
                    <th style="padding: 6px 8px; border: 1px solid #e2e8f0; text-align: left;">Date</th>
                    <th style="padding: 6px 8px; border: 1px solid #e2e8f0; text-align: right;">Amount (PKR)</th>
                </tr>
            </thead>
            <tbody>
                <% recentDonations.forEach(d => { %>
                    <tr style="<%= d.id === donation.id ? 'background-color: #fdf2f8;' : '' %>">
                        <td style="padding: 6px 8px; border: 1px solid #e2e8f0; text-align: left;"><%= new Date(d.date).toLocaleDateString('en-GB') %> <%= d.id === donation.id ? '(This Payment)' : '' %></td>
                        <td style="padding: 6px 8px; border: 1px solid #e2e8f0; text-align: right; font-weight: 600;">PKR <%= Number(d.amount).toLocaleString('en-US', {minimumFractionDigits: 2}) %></td>
                    </tr>
                <% }) %>
                <tr style="background-color: #f1f5f9; font-weight: 700; color: #0f172a;">
                    <td style="padding: 8px; border: 1px solid #e2e8f0; text-align: left;">Total Donated in 2026</td>
                    <td style="padding: 8px; border: 1px solid #e2e8f0; text-align: right;">PKR <%= Number(total_donated_2026).toLocaleString('en-US', {minimumFractionDigits: 2}) %></td>
                </tr>
            </tbody>
        </table>

        <p class="thanks">"On behalf of <%= tenant.school_name %>, we sincerely thank you for your generous contribution."</p>

        <p class="footer-note">This is a computer-generated receipt from <%= tenant.school_name %>.</p>
    </div>
</body>
</html>
