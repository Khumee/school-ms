<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-journal-check"></i> Hifz Class Roster</h1>
    <div style="display: flex; gap: 0.75rem;">
        <a href="/hifz/mark-all" class="btn-primary"><i class="bi bi-grid-3x3-gap-fill"></i> Quick Mark All</a>
        <a href="/hifz/enroll" class="btn-secondary"><i class="bi bi-person-plus-fill"></i> Enroll Student</a>
    </div>
</div>

<!-- Quick Statistics Summary -->
<div class="kpi-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 1.5rem;">
    <div class="card kpi-card">
        <span class="kpi-icon blue"><i class="bi bi-people-fill"></i></span>
        <span class="kpi-label">Active Hifz Students</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= totalStudents %></span>
        <span class="kpi-subtitle">Currently enrolled</span>
    </div>
    <div class="card kpi-card">
        <span class="kpi-icon green"><i class="bi bi-check2-circle"></i></span>
        <span class="kpi-label">Entries Marked Today</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= markedToday %> / <%= totalStudents %></span>
        <span class="kpi-subtitle">Records filled on <%= today %></span>
    </div>
    <div class="card kpi-card">
        <span class="kpi-icon <%= alarmCount > 0 ? 'red' : 'green' %>"><i class="bi bi-exclamation-triangle-fill"></i></span>
        <span class="kpi-label">Alarms Triggered</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= alarmCount %></span>
        <span class="kpi-subtitle">Students with alerts</span>
    </div>
</div>

<!-- Class Filter Panel -->
<div class="card" style="margin-bottom: 1.5rem; padding: 1.25rem;">
    <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; justify-content: space-between;">
        <div style="display: flex; gap: 1rem; align-items: center;">
            <label for="classFilter" style="font-weight: 600; color: #475569;"><i class="bi bi-funnel"></i> Filter by Class:</label>
            <select id="classFilter" class="form-control" style="width: auto; min-width: 200px;" onchange="filterClass(this.value)">
                <option value="all">-- All Hifz Classes --</option>
                <% hifzClasses.forEach(c => { %>
                    <option value="<%= c.id %>"><%= c.name %></option>
                <% }) %>
            </select>
        </div>
        <div style="display: flex; gap: 0.5rem;">
            <a href="/hifz/calendar" class="btn-secondary"><i class="bi bi-calendar-event"></i> Manage Holidays</a>
            <a href="/hifz/report/weekly" class="btn-secondary"><i class="bi bi-printer"></i> Weekly Report</a>
        </div>
    </div>
</div>

<!-- Roster Table -->
<div class="table-container">
    <table id="rosterTable">
        <thead>
            <tr>
                <th>Reg No</th>
                <th>Name</th>
                <th>Class</th>
                <th>Phase</th>
                <th>Current Para</th>
                <th>Total Memorized</th>
                <th>Daily Entry (Today)</th>
                <th>Alert Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (students.length > 0) { %>
                <% students.forEach(s => { %>
                    <tr class="student-row" data-class-id="<%= s.class_id %>">
                        <td style="font-weight: 600;"><%= s.reg_no %></td>
                        <td>
                            <a href="/hifz/student/<%= s.student_id %>" style="font-weight: 600; text-decoration: none; color: var(--primary-color);">
                                <%= s.student_name %>
                            </a>
                        </td>
                        <td><%= s.class_name %></td>
                        <td>
                            <span class="status-cell" style="background-color: #f1f5f9; color: #1e293b; font-weight: 500;">
                                <%= s.phase.label %>
                            </span>
                        </td>
                        <td style="text-align: center; font-weight: bold; color: #1e3a8a;">
                            <%= s.current_para || '-' %>
                        </td>
                        <td>
                            <%= s.total_lines_memorized %> lines 
                            <small style="color: #64748b; display: block;">(~<%= (s.total_lines_memorized / 15).toFixed(1) %> pages)</small>
                        </td>
                        <td>
                            <% if (s.today_entry_id) { %>
                                <% if (s.today_absent) { %>
                                    <span class="status-cell status-unpaid" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;"><i class="bi bi-person-x-fill"></i> ABSENT</span>
                                <% } else { %>
                                    <span class="status-cell status-paid" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;"><i class="bi bi-check-circle-fill"></i> MARKED</span>
                                <% } %>
                            <% } else { %>
                                <span class="status-cell" style="background-color: #fef3c7; color: #d97706; padding: 0.25rem 0.5rem; font-size: 0.75rem;"><i class="bi bi-clock-history"></i> PENDING</span>
                            <% } %>
                        </td>
                        <td>
                            <% if (s.alarmLevel === 'critical') { %>
                                <span class="status-cell status-unpaid" title="<%= s.alarms.map(a => a.message).join(', ') %>" style="cursor: help;">
                                    <i class="bi bi-exclamation-octagon-fill"></i> CRITICAL
                                </span>
                            <% } else if (s.alarmLevel === 'warning') { %>
                                <span class="status-cell" style="background-color: #fffbeb; color: #b45309; border: 1px solid #fde68a; cursor: help;" title="<%= s.alarms.map(a => a.message).join(', ') %>">
                                    <i class="bi bi-exclamation-triangle-fill"></i> ALERT
                                </span>
                            <% } else { %>
                                <span class="status-cell status-paid">
                                    <i class="bi bi-check-circle"></i> CLEAR
                                </span>
                            <% } %>
                        </td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                <a href="/hifz/student/<%= s.student_id %>" class="btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.8rem;" title="View Hifz Profile">
                                    <i class="bi bi-eye"></i> Profile
                                </a>
                                <a href="/hifz/student/<%= s.student_id %>/diary" class="btn-primary" style="padding: 0.25rem 0.5rem; font-size: 0.8rem;" title="Mark Daily Diary">
                                    <i class="bi bi-pencil-square"></i> Mark Diary
                                </a>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="9" style="text-align: center; color: #64748b; padding: 2rem;">
                        <i class="bi bi-info-circle" style="font-size: 1.5rem; display: block; margin-bottom: 0.5rem;"></i>
                        No active students enrolled in the Hifz program.
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<script>
    function filterClass(classId) {
        const rows = document.querySelectorAll('.student-row');
        rows.forEach(row => {
            if (classId === 'all' || row.getAttribute('data-class-id') === classId) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>

<%- include('partials/footer') %>
