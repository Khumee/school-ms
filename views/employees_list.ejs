<%- include('partials/header') %>

<%
    let totalCount = employees.length;
    let teachersCount = employees.filter(e => e.role === 'teacher').length;
    let adminsCount = employees.filter(e => e.role === 'admin').length;
    let supportCount = employees.filter(e => e.role === 'support').length;
%>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-person-badge-fill"></i> Employee Registry</h1>
    <a href="/employees/add" class="btn-primary"><i class="bi bi-person-plus-fill"></i> Add New Employee</a>
</div>

<!-- KPI Cards -->
<div class="kpi-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 1.5rem;">
    <div class="card kpi-card" style="cursor: pointer;" onclick="filterEmployees('all')" id="kpi-all">
        <span class="kpi-icon blue"><i class="bi bi-people-fill"></i></span>
        <span class="kpi-label">Total Employees</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= totalCount %></span>
        <span class="kpi-subtitle">Click to view all</span>
    </div>
    <div class="card kpi-card" style="cursor: pointer;" onclick="filterEmployees('teacher')" id="kpi-teacher">
        <span class="kpi-icon green"><i class="bi bi-person-workspace"></i></span>
        <span class="kpi-label">Teachers</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= teachersCount %></span>
        <span class="kpi-subtitle">Click to view teachers</span>
    </div>
    <div class="card kpi-card" style="cursor: pointer;" onclick="filterEmployees('admin')" id="kpi-admin">
        <span class="kpi-icon purple"><i class="bi bi-briefcase-fill"></i></span>
        <span class="kpi-label">Administrators</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= adminsCount %></span>
        <span class="kpi-subtitle">Click to view admins</span>
    </div>
    <div class="card kpi-card" style="cursor: pointer;" onclick="filterEmployees('support')" id="kpi-support">
        <span class="kpi-icon amber"><i class="bi bi-tools"></i></span>
        <span class="kpi-label">Support Staff</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= supportCount %></span>
        <span class="kpi-subtitle">Click to view support</span>
    </div>
</div>

<!-- Filters Collapsible Panel -->
<details class="filter-panel" <%= (role || status || search) ? 'open' : '' %>>
    <summary>
        <span><i class="bi bi-funnel-fill"></i> Filter & Search Employees <%= (role || status || search) ? '(Active)' : '' %></span>
        <i class="bi bi-chevron-down toggle-icon"></i>
    </summary>
    <form action="/employees" method="GET" class="filter-content">
        <div class="form-group">
            <label for="role">Role Type</label>
            <select name="role" id="role" class="form-control" onchange="this.form.submit()">
                <option value="">-- All Roles --</option>
                <option value="teacher" <%= role === 'teacher' ? 'selected' : '' %>>Teacher</option>
                <option value="admin" <%= role === 'admin' ? 'selected' : '' %>>Administrator</option>
                <option value="support" <%= role === 'support' ? 'selected' : '' %>>Support Staff</option>
            </select>
        </div>
        
        <div class="form-group">
            <label for="status">Payroll Status</label>
            <select name="status" id="status" class="form-control" onchange="this.form.submit()">
                <option value="">-- All Statuses --</option>
                <option value="on_payroll" <%= status === 'on_payroll' ? 'selected' : '' %>>On Payroll</option>
                <option value="volunteer" <%= status === 'volunteer' ? 'selected' : '' %>>Volunteer</option>
                <option value="inactive" <%= status === 'inactive' ? 'selected' : '' %>>Inactive</option>
            </select>
        </div>
        
        <div class="form-group">
            <label for="search">Search</label>
            <input type="text" name="search" id="search" class="form-control" value="<%= search || '' %>" placeholder="Search by name or designation...">
        </div>
        
        <div style="display: flex; gap: 0.5rem; align-items: flex-end;">
            <button type="submit" class="btn-secondary" style="height: 38px;">Search</button>
            <a href="/employees" class="btn-secondary" style="height: 38px; display: inline-flex; align-items: center;">Reset</a>
        </div>
    </form>
</details>

<!-- Table -->
<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Designation</th>
                <th>Role</th>
                <th>Payroll Status</th>
                <th style="text-align: right;">Default Salary (PKR)</th>
                <th>Joining Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (employees.length > 0) { %>
                <% employees.forEach(e => { %>
                    <tr class="employee-row" data-role="<%= e.role %>">
                        <td style="font-weight: 600;"><a href="/employees/view/<%= e.id %>" style="color: var(--primary-color, #3b82f6); text-decoration: none; hover: underline;"><%= e.name %></a></td>
                        <td><%= e.designation %></td>
                        <td><%= e.role.toUpperCase() %></td>
                        <td>
                            <span class="status-cell <%= e.status === 'on_payroll' ? 'status-paid' : 'status-unpaid' %>">
                                <%= e.status.replace('_', ' ').toUpperCase() %>
                            </span>
                        </td>
                        <td style="text-align: right; font-weight: 600;"><%= e.default_salary > 0 ? e.default_salary.toLocaleString() : '-' %></td>
                        <td><%= e.date_of_joining ? new Date(e.date_of_joining).toLocaleDateString() : '-' %></td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                <a href="/employees/view/<%= e.id %>" class="btn-secondary nav-btn"><i class="bi bi-person-vcard-fill"></i> View</a>
                                <a href="/employees/edit/<%= e.id %>" class="btn-secondary nav-btn"><i class="bi bi-pencil-square"></i> Edit</a>
                                <form action="/employees/delete/<%= e.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this employee?')">
                                    <button type="submit" class="btn-danger nav-btn"><i class="bi bi-trash3-fill"></i> Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="7" style="text-align: center; color: #64748b;">No employees found.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<script>
    function filterEmployees(role) {
        const rows = document.querySelectorAll('.employee-row');
        rows.forEach(row => {
            const empRole = row.getAttribute('data-role');
            if (role === 'all') {
                row.style.display = '';
            } else {
                row.style.display = empRole === role ? '' : 'none';
            }
        });
        
        // Add visual active state to cards
        document.getElementById('kpi-all').style.border = role === 'all' ? '2px solid var(--primary-color)' : '';
        document.getElementById('kpi-teacher').style.border = role === 'teacher' ? '2px solid var(--primary-color)' : '';
        document.getElementById('kpi-admin').style.border = role === 'admin' ? '2px solid var(--primary-color)' : '';
        document.getElementById('kpi-support').style.border = role === 'support' ? '2px solid var(--primary-color)' : '';
    }
</script>

<%- include('partials/footer') %>
