<%- include('partials/header') %>

<style>
    .quality-btn {
        border: 1px solid #cbd5e1;
        background-color: #f8fafc;
        padding: 0.35rem 0.75rem;
        font-size: 0.85rem;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s;
    }
    .quality-btn:hover {
        background-color: #f1f5f9;
        border-color: #94a3b8;
    }
    .quality-btn.active-exc { background-color: #dcfce7; color: #16a34a; border-color: #86efac; font-weight: bold; }
    .quality-btn.active-gd  { background-color: #e0f2fe; color: #0284c7; border-color: #7dd3fc; font-weight: bold; }
    .quality-btn.active-avg { background-color: #fef9c3; color: #ca8a04; border-color: #fde047; font-weight: bold; }
    .quality-btn.active-wk  { background-color: #ffedd5; color: #ea580c; border-color: #fdba74; font-weight: bold; }
    .quality-btn.active-vwk { background-color: #fef2f2; color: #dc2626; border-color: #fca5a5; font-weight: bold; }
</style>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-journal-plus"></i> Daily Hifz Entry Form</h1>
    <a href="/hifz" class="btn-secondary"><i class="bi bi-arrow-left"></i> Back to Roster</a>
</div>

<div style="display: grid; grid-template-columns: 1fr 2fr; gap: 1.5rem; margin-bottom: 2rem;">
    <!-- Left: Student Info Card -->
    <div class="card" style="padding: 1.5rem; height: fit-content;">
        <h3 style="margin-top: 0; font-size: 1.25rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.75rem; color: #0f172a;">Student details</h3>
        <div style="font-weight: 700; font-size: 1.2rem; color: var(--primary-color); margin-bottom: 0.25rem;"><%= enrollment.student_name %></div>
        <div style="font-size: 0.9rem; color: #64748b; margin-bottom: 1rem;">Reg No: <strong><%= enrollment.reg_no %></strong></div>
        
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 0.5rem 0; color: #64748b;">Class</td>
                <td style="padding: 0.5rem 0; text-align: right; font-weight: 600;"><%= enrollment.class_name %></td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 0.5rem 0; color: #64748b;">Phase</td>
                <td style="padding: 0.5rem 0; text-align: right; font-weight: 600;"><span class="status-cell" style="background-color: #e2e8f0; color: #1e293b;"><%= phase.label %></span></td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 0.5rem 0; color: #64748b;">Current Para</td>
                <td style="padding: 0.5rem 0; text-align: right; font-weight: 600;"><%= enrollment.current_para || 'None' %></td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 0.5rem 0; color: #64748b;">Total Memorized</td>
                <td style="padding: 0.5rem 0; text-align: right; font-weight: 600;"><%= enrollment.total_lines_memorized %> lines (~<%= (enrollment.total_lines_memorized/15).toFixed(1) %> pages)</td>
            </tr>
            <tr>
                <td style="padding: 0.5rem 0; color: #64748b;">Current Streak</td>
                <td style="padding: 0.5rem 0; text-align: right; font-weight: 600; color: #16a34a;"><i class="bi bi-fire"></i> <%= streak %> Days</td>
            </tr>
        </table>

        <!-- Active Waqaf Alert -->
        <% if (activeWaqaf) { %>
            <div style="background-color: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; border-radius: 6px; padding: 0.75rem; margin-top: 1rem; font-size: 0.85rem;">
                <i class="bi bi-info-circle-fill"></i> <strong>Waqaf Test Mode Active:</strong> Student is currently preparing for testing on Para <strong><%= activeWaqaf.para_no %></strong>.
            </div>
        <% } %>
    </div>

    <!-- Right: Diary Form -->
    <div class="card" id="diary-form" style="padding: 1.5rem;">
        <h3 style="margin-top: 0; font-size: 1.25rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.75rem; color: #0f172a;"><i class="bi bi-pencil-square"></i> Record Entry</h3>
        
        <form action="/hifz/student/<%= studentId %>/diary" method="POST">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                    <label for="entry_date" style="font-weight: 600;">Date</label>
                    <input type="date" name="entry_date" id="entry_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>" required>
                </div>
                <div class="form-group" style="display: flex; align-items: flex-end; padding-bottom: 0.5rem;">
                    <label style="font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;">
                        <input type="checkbox" name="is_absent" id="is_absent" style="transform: scale(1.3);" onchange="toggleAbsentView()">
                        Student is Absent
                    </label>
                </div>
            </div>

            <div id="recitation-sections">
                <!-- SABAQ -->
                <div style="background-color: #eff6ff; border-left: 4px solid #3b82f6; padding: 1rem; border-radius: 0 6px 6px 0; margin-bottom: 1rem;">
                    <div style="font-weight: 700; color: #1e3a8a; margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center;">
                        <span>Sabaq (New Lesson)</span>
                        <span style="font-size: 0.8rem; font-weight: normal; color: #475569;">Target: <%= phase.minLines %>-<%= phase.maxLines %> lines</span>
                    </div>
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.75rem; margin-bottom: 0.75rem;">
                        <div class="form-group">
                            <label style="font-size: 0.85rem; font-weight: 600;">Status</label>
                            <select name="sabaq_status" class="form-control">
                                <option value="recited" selected>Recited</option>
                                <option value="not_recited">Not Recited</option>
                                <option value="memorized_no_recite">Memorized, No Recite</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label style="font-size: 0.85rem; font-weight: 600;">Para No</label>
                            <input type="number" name="sabaq_para" class="form-control" min="1" max="30" value="<%= enrollment.current_para %>">
                        </div>
                        <div class="form-group">
                            <label style="font-size: 0.85rem; font-weight: 600;">Lines Memorized</label>
                            <input type="number" name="sabaq_lines" class="form-control" min="1" max="30" value="<%= phase.minLines %>">
                        </div>
                    </div>
                    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 0.75rem;">
                        <div class="form-group">
                            <label style="font-size: 0.85rem; font-weight: 600;">Quality</label>
                            <div style="display: flex; gap: 0.25rem; flex-wrap: wrap;">
                                <button type="button" class="quality-btn" onclick="setQuality('sabaq', 'Excellent', this, 'exc')">ممتاز (Exc)</button>
                                <button type="button" class="quality-btn" onclick="setQuality('sabaq', 'Good', this, 'gd')">جید جداً (Gd)</button>
                                <button type="button" class="quality-btn" onclick="setQuality('sabaq', 'Average', this, 'avg')">جید (Avg)</button>
                                <button type="button" class="quality-btn" onclick="setQuality('sabaq', 'Weak', this, 'wk')">مقبول (Wk)</button>
                                <button type="button" class="quality-btn" onclick="setQuality('sabaq', 'Very Weak', this, 'vwk')">غیر مقبول (V.Wk)</button>
                            </div>
                            <input type="hidden" name="sabaq_quality" id="sabaq_quality" value="">
                        </div>
                        <div class="form-group">
                            <label style="font-size: 0.85rem; font-weight: 600;">Tajweed</label>
                            <select name="sabaq_tajweed" class="form-control">
                                <option value="clear" selected>Clear</option>
                                <option value="mistakes">Mistakes</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- SABQI -->
                <div style="background-color: #f0fdf4; border-left: 4px solid #22c55e; padding: 1rem; border-radius: 0 6px 6px 0; margin-bottom: 1rem;">
                    <div style="font-weight: 700; color: #14532d; margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center;">
                        <span>Sabqi (Recent Lessons)</span>
                        <span style="font-size: 0.8rem; font-weight: normal; color: #475569;">Target: Para <%= Math.max(1, enrollment.current_para - 1) %></span>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 0.75rem;">
                        <div class="form-group">
                            <label style="font-size: 0.85rem; font-weight: 600;">Status</label>
                            <select name="sabqi_status" class="form-control">
                                <option value="recited" selected>Recited</option>
                                <option value="not_recited">Not Recited</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label style="font-size: 0.85rem; font-weight: 600;">Para No</label>
                            <input type="number" name="sabqi_para" class="form-control" min="1" max="30" value="<%= Math.max(1, enrollment.current_para - 1) %>">
                        </div>
                    </div>
                    <div class="form-group">
                        <label style="font-size: 0.85rem; font-weight: 600;">Quality</label>
                        <div style="display: flex; gap: 0.25rem; flex-wrap: wrap;">
                            <button type="button" class="quality-btn" onclick="setQuality('sabqi', 'Excellent', this, 'exc')">ممتاز (Exc)</button>
                            <button type="button" class="quality-btn" onclick="setQuality('sabqi', 'Good', this, 'gd')">جید جداً (Gd)</button>
                            <button type="button" class="quality-btn" onclick="setQuality('sabqi', 'Average', this, 'avg')">جید (Avg)</button>
                            <button type="button" class="quality-btn" onclick="setQuality('sabqi', 'Weak', this, 'wk')">مقبول (Wk)</button>
                            <button type="button" class="quality-btn" onclick="setQuality('sabqi', 'Very Weak', this, 'vwk')">غیر مقبول (V.Wk)</button>
                        </div>
                        <input type="hidden" name="sabqi_quality" id="sabqi_quality" value="">
                    </div>
                </div>

                <!-- MANZIL -->
                <div style="background-color: #fffbeb; border-left: 4px solid #eab308; padding: 1rem; border-radius: 0 6px 6px 0; margin-bottom: 1rem;">
                    <div style="font-weight: 700; color: #78350f; margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center;">
                        <span>Manzil (Revision)</span>
                        <span style="font-size: 0.8rem; font-weight: normal; color: #475569;">Target: Para 1 to <%= Math.max(1, enrollment.current_para - 1) %></span>
                    </div>
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 0.75rem; margin-bottom: 0.75rem;">
                        <div class="form-group">
                            <label style="font-size: 0.85rem; font-weight: 600;">Status</label>
                            <select name="manzil_status" class="form-control">
                                <option value="recited" selected>Recited</option>
                                <option value="not_recited">Not Recited</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label style="font-size: 0.85rem; font-weight: 600;">From Para</label>
                            <input type="number" name="manzil_from_para" class="form-control" min="1" max="30" value="1">
                        </div>
                        <div class="form-group">
                            <label style="font-size: 0.85rem; font-weight: 600;">To Para</label>
                            <input type="number" name="manzil_to_para" class="form-control" min="1" max="30" value="<%= Math.max(1, enrollment.current_para - 1) %>">
                        </div>
                    </div>
                    <div class="form-group">
                        <label style="font-size: 0.85rem; font-weight: 600;">Quality</label>
                        <div style="display: flex; gap: 0.25rem; flex-wrap: wrap;">
                            <button type="button" class="quality-btn" onclick="setQuality('manzil', 'Excellent', this, 'exc')">ممتاز (Exc)</button>
                            <button type="button" class="quality-btn" onclick="setQuality('manzil', 'Good', this, 'gd')">جید جداً (Gd)</button>
                            <button type="button" class="quality-btn" onclick="setQuality('manzil', 'Average', this, 'avg')">جید (Avg)</button>
                            <button type="button" class="quality-btn" onclick="setQuality('manzil', 'Weak', this, 'wk')">مقبول (Wk)</button>
                            <button type="button" class="quality-btn" onclick="setQuality('manzil', 'Very Weak', this, 'vwk')">غیر مقبول (V.Wk)</button>
                        </div>
                        <input type="hidden" name="manzil_quality" id="manzil_quality" value="">
                    </div>
                </div>
            </div>

            <!-- Remarks -->
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label for="teacher_remarks" style="font-weight: 600;">Teacher Remarks</label>
                <textarea name="teacher_remarks" id="teacher_remarks" class="form-control" rows="2" placeholder="Write any specific feedback or mistakes here..."></textarea>
            </div>

            <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                <a href="/hifz" class="btn-secondary" style="height: 42px; display: inline-flex; align-items: center;">Cancel</a>
                <button type="submit" class="btn-primary" style="height: 42px; padding: 0 2rem; font-weight: 600;"><i class="bi bi-save"></i> Save Diary Entry</button>
            </div>
        </form>
    </div>
</div>

<script>
    function toggleAbsentView() {
        const isAbsent = document.getElementById('is_absent').checked;
        const sections = document.getElementById('recitation-sections');
        if (isAbsent) {
            sections.style.display = 'none';
        } else {
            sections.style.display = 'block';
        }
    }

    function setQuality(type, val, btn, classSuffix) {
        const parent = btn.parentElement;
        parent.querySelectorAll('.quality-btn').forEach(b => {
            b.className = 'quality-btn';
        });
        btn.classList.add('active-' + classSuffix);
        document.getElementById(type + '_quality').value = val;
    }
</script>

<%- include('partials/footer') %>
