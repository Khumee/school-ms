<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - <%= typeof tenant !== 'undefined' && tenant && tenant.subdomain === 'school-ms' ? 'My Islamic School (Demo)' : (typeof tenant !== 'undefined' && tenant ? tenant.school_name : 'School Portal') %></title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root {
            --primary-color: <%= typeof tenant !== 'undefined' && tenant ? tenant.primary_color : '#0f766e' %>;
            --secondary-color: <%= typeof tenant !== 'undefined' && tenant ? tenant.secondary_color : '#0d9488' %>;
            --font-family: 'Outfit', sans-serif;
        }
        body {
            font-family: var(--font-family);
            margin: 0;
            padding: 0;
        }
        .login-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 1.5rem;
            background: radial-gradient(circle at top left, var(--secondary-color), #042f2e);
            position: relative;
            overflow: hidden;
        }
        /* Decorative background shapes for premium aesthetic */
        .bg-shape-1 {
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(13, 148, 136, 0.2), rgba(15, 118, 110, 0.05));
            top: -100px;
            left: -100px;
            filter: blur(80px);
            z-index: 1;
        }
        .bg-shape-2 {
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(20, 184, 166, 0.15), rgba(13, 148, 136, 0.02));
            bottom: -150px;
            right: -150px;
            filter: blur(100px);
            z-index: 1;
        }
        .login-card {
            max-width: 440px;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(16px);
            border-radius: 24px;
            padding: 3rem 2.5rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.2);
            z-index: 10;
            box-sizing: border-box;
            transition: transform 0.3s ease;
        }
        .login-icon {
            width: 70px;
            height: 70px;
            border-radius: 20px;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin: 0 auto 1.5rem;
            box-shadow: 0 10px 20px -5px rgba(13, 148, 136, 0.4);
        }
        .login-logo {
            height: 70px;
            width: auto;
            display: block;
            margin: 0 auto 1.5rem;
        }
        .login-title {
            font-size: 1.75rem;
            font-weight: 800;
            color: #0f172a;
            text-align: center;
            margin-bottom: 0.5rem;
            letter-spacing: -0.025em;
        }
        .login-subtitle {
            font-size: 0.925rem;
            color: #64748b;
            text-align: center;
            margin-bottom: 2.25rem;
            font-weight: 500;
        }
        .form-group label {
            font-size: 0.875rem;
            font-weight: 600;
            color: #475569;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .form-group label i {
            color: var(--primary-color);
        }
        .form-control {
            height: 48px;
            border-radius: 12px;
            border: 1.5px solid #cbd5e1;
            padding: 0 1rem;
            font-size: 0.95rem;
            font-family: var(--font-family);
            transition: all 0.2s ease;
            width: 100%;
            box-sizing: border-box;
        }
        .form-control:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(13, 148, 136, 0.15);
        }
        .btn-submit {
            width: 100%;
            height: 48px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: #ffffff;
            border: none;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 8px 16px -4px rgba(13, 148, 136, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            font-family: var(--font-family);
        }
        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 20px -4px rgba(13, 148, 136, 0.4);
        }
        .btn-submit:active {
            transform: translateY(0);
        }
        .alert-danger {
            background-color: #fef2f2;
            border: 1px solid #fca5a5;
            color: #b91c1c;
            border-radius: 12px;
            padding: 0.75rem 1rem;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="bg-shape-1"></div>
        <div class="bg-shape-2"></div>
        
        <div class="login-card">
            <% if (typeof tenant !== 'undefined' && tenant && tenant.logo_url && tenant.logo_url !== '/images/default_logo.png') { %>
                <img src="<%= tenant.logo_url %>" alt="Logo" class="login-logo">
            <% } else { %>
                <div class="login-icon"><i class="bi bi-mortarboard-fill"></i></div>
            <% } %>
            
            <h1 class="login-title">
                <%= typeof tenant !== 'undefined' && tenant && tenant.subdomain === 'school-ms' ? 'My Islamic School (Demo)' : (typeof tenant !== 'undefined' && tenant ? tenant.school_name : 'School Portal') %>
            </h1>
            <p class="login-subtitle">Sign in to manage your school database</p>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i> <%= error %>
                </div>
            <% } %>

            <form action="/login" method="POST">
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label for="username"><i class="bi bi-person-fill"></i> Username</label>
                    <input type="text" id="username" name="username" class="form-control" required placeholder="Enter username">
                </div>
                <div class="form-group" style="margin-bottom: 2.25rem;">
                    <label for="password"><i class="bi bi-lock-fill"></i> Password</label>
                    <input type="password" id="password" name="password" class="form-control" required placeholder="Enter password">
                </div>
                <button type="submit" class="btn-submit">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                </button>
            </form>
        </div>
    </div>
</body>
</html>
