<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-building"></i> Class Management</h1>
</div>

<% if (error) { %>
    <div style="background-color: #fef2f2; border: 1px solid #fee2e2; color: #991b1b; padding: 1rem; border-radius: 0.375rem; margin-bottom: 1.5rem;">
        <%= error %>
    </div>
<% } %>

<div class="form-grid" style="grid-template-columns: 1fr 2fr; gap: 1.5rem; margin-bottom: 2rem;">
    <!-- Form to Add Class -->
    <div class="card">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);">Create New Class</h3>
        <form action="/classes/add" method="POST">
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="name">Class Name *</label>
                <input type="text" id="name" name="name" class="form-control" required placeholder="e.g. Class 1, Class 2, Hifz Section">
            </div>
            
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="default_monthly_fee">Class Fee (PKR) *</label>
                <input type="number" step="0.01" id="default_monthly_fee" name="default_monthly_fee" class="form-control" required placeholder="0.00" value="0">
            </div>
            
            <div class="form-group form-checkbox" style="margin-bottom: 1.5rem;">
                <input type="checkbox" id="is_hifz_class" name="is_hifz_class" value="1">
                <label for="is_hifz_class">Is Hifz Class (No Fees)</label>
            </div>
            
            <button type="submit" class="btn-primary" style="width: 100%;">Create Class</button>
        </form>
    </div>
    
    <!-- Table list -->
    <div class="card">
        <h3 style="margin-bottom: 1rem;">Available Classes</h3>
        
        <div class="table-container" style="border: none; max-height: 450px; overflow-y: auto;">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Class Name</th>
                        <th style="text-align: right;">Class Fee (PKR)</th>
                        <th style="text-align: center;">Is Hifz?</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (classes.length > 0) { %>
                        <% classes.forEach(c => { %>
                            <tr>
                                <td><%= c.id %></td>
                                <td style="font-weight: 600;"><%= c.name %></td>
                                <td style="text-align: right; font-weight: 600;">PKR <%= parseFloat(c.default_monthly_fee || 0).toLocaleString() %></td>
                                <td style="text-align: center;">
                                    <% if (c.is_hifz_class) { %>
                                        <span class="status-cell status-paid">YES</span>
                                    <% } else { %>
                                        <span class="status-cell status-unpaid" style="background-color: #f1f5f9; color: #64748b; border: 1px solid #cbd5e1;">NO</span>
                                    <% } %>
                                </td>
                                <td style="text-align: right;">
                                    <button type="button" class="btn-secondary nav-btn" onclick="openClassModal('<%= c.id %>', '<%= c.name %>', '<%= c.default_monthly_fee %>', '<%= c.is_hifz_class ? 1 : 0 %>')">
                                        <i class="bi bi-pencil-fill"></i> Edit
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" style="text-align: center; color: #64748b;">No classes defined yet.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Class Edit Modal -->
<div id="classModal" class="card" style="display: none; max-width: 400px; margin: 1rem auto; position: fixed; top: 20%; left: 50%; transform: translate(-50%, 0); z-index: 1000; box-shadow: 0 10px 25px rgba(0,0,0,0.2); box-sizing: border-box; width: 90%;">
    <h3 style="margin-bottom: 1.25rem;">Edit Class</h3>
    <form id="editClassForm" action="/classes/edit/" method="POST">
        <div class="form-group" style="margin-bottom: 1rem;">
            <label for="modalClassName">Class Name *</label>
            <input type="text" id="modalClassName" name="name" class="form-control" required>
        </div>

        <div class="form-group" style="margin-bottom: 1rem;">
            <label for="modalClassFee">Class Fee (PKR) *</label>
            <input type="number" step="0.01" id="modalClassFee" name="default_monthly_fee" class="form-control" required>
        </div>

        <div class="form-group form-checkbox" style="margin-bottom: 1.25rem;">
            <input type="checkbox" id="modalIsHifz" name="is_hifz_class" value="1">
            <label for="modalIsHifz">Is Hifz Class (No Fees)</label>
        </div>
        
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
            <button type="button" class="btn-secondary" onclick="closeClassModal()">Cancel</button>
            <button type="submit" class="btn-primary">Save Changes</button>
        </div>
    </form>
</div>
<div id="classModalOverlay" style="display: none; position: fixed; top: 0; left: 0; width:100%; height:100%; background: rgba(0,0,0,0.4); z-index: 999;" onclick="closeClassModal()"></div>

<script>
    function openClassModal(id, name, fee, isHifz) {
        document.getElementById('editClassForm').action = '/classes/edit/' + id;
        document.getElementById('modalClassName').value = name;
        document.getElementById('modalClassFee').value = fee;
        
        const isHifzChecked = (isHifz === '1' || isHifz === 1);
        const modalIsHifzCheckbox = document.getElementById('modalIsHifz');
        modalIsHifzCheckbox.checked = isHifzChecked;
        
        const feeInput = document.getElementById('modalClassFee');
        if (isHifzChecked) {
            feeInput.value = 0;
            feeInput.readOnly = true;
            feeInput.style.backgroundColor = '#f1f5f9';
        } else {
            feeInput.readOnly = false;
            feeInput.style.backgroundColor = '';
        }
        
        document.getElementById('classModal').style.display = 'block';
        document.getElementById('classModalOverlay').style.display = 'block';
    }

    function closeClassModal() {
        document.getElementById('classModal').style.display = 'none';
        document.getElementById('classModalOverlay').style.display = 'none';
    }

    // Add Class Form fee reset logic
    document.getElementById('is_hifz_class').addEventListener('change', function() {
        const feeInput = document.getElementById('default_monthly_fee');
        if (this.checked) {
            feeInput.value = 0;
            feeInput.readOnly = true;
            feeInput.style.backgroundColor = '#f1f5f9';
        } else {
            feeInput.readOnly = false;
            feeInput.style.backgroundColor = '';
        }
    });

    // Edit Class Form fee reset logic
    document.getElementById('modalIsHifz').addEventListener('change', function() {
        const feeInput = document.getElementById('modalClassFee');
        if (this.checked) {
            feeInput.value = 0;
            feeInput.readOnly = true;
            feeInput.style.backgroundColor = '#f1f5f9';
        } else {
            feeInput.readOnly = false;
            feeInput.style.backgroundColor = '';
        }
    });
</script>

<%- include('partials/footer') %>
