<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-building"></i> Class Management</h1>
</div>

<% if (error) { %>
    <div style="background-color: #fef2f2; border: 1px solid #fee2e2; color: #991b1b; padding: 1rem; border-radius: 0.375rem; margin-bottom: 1.5rem;">
        <%= error %>
    </div>
<% } %>

<div class="form-grid" style="grid-template-columns: 1fr 2fr; gap: 1.5rem; margin-bottom: 2rem;">
    <!-- Form to Add Class -->
    <div class="card">
        <h3 style="margin-bottom: 1rem; color: var(--primary-color);">Create New Class</h3>
        <form action="/classes/add" method="POST">
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="name">Class Name *</label>
                <input type="text" id="name" name="name" class="form-control" required placeholder="e.g. Class 1, Class 2, Hifz Section">
            </div>
            
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label for="default_monthly_fee">Class Fee (PKR) *</label>
                <input type="number" step="0.01" id="default_monthly_fee" name="default_monthly_fee" class="form-control" required placeholder="0.00" value="0">
            </div>
            
            <button type="submit" class="btn-primary" style="width: 100%;">Create Class</button>
        </form>
    </div>
    
    <!-- Table list -->
    <div class="card">
        <h3 style="margin-bottom: 1rem;">Available Classes</h3>
        
        <div class="table-container" style="border: none; max-height: 450px; overflow-y: auto;">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Class Name</th>
                        <th style="text-align: right;">Class Fee (PKR)</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (classes.length > 0) { %>
                        <% classes.forEach(c => { %>
                            <tr>
                                <td><%= c.id %></td>
                                <td style="font-weight: 600;"><%= c.name %></td>
                                <td style="text-align: right; font-weight: 600;">PKR <%= parseFloat(c.default_monthly_fee || 0).toLocaleString() %></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" style="text-align: center; color: #64748b;">No classes defined yet.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
