<%- include('partials/header') %>

<div class="section-header">
    <h1 class="section-title">Student Directory</h1>
    <a href="/students/add" class="btn-primary">+ Add New Student</a>
</div>

<!-- Filters -->
<form action="/students" method="GET" class="filter-bar">
    <div class="form-group">
        <label for="classId">Class</label>
        <select name="classId" id="classId" class="form-control" onchange="this.form.submit()">
            <option value="">-- All Classes --</option>
            <% classes.forEach(c => { %>
                <option value="<%= c.id %>" <%= classId == c.id ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
        </select>
    </div>
    
    <div class="form-group">
        <label for="search">Search</label>
        <input type="text" name="search" id="search" class="form-control" value="<%= search || '' %>" placeholder="Search by name or Reg No...">
    </div>
    
    <button type="submit" class="btn-secondary">Search</button>
    <a href="/students" class="btn-secondary" style="height: 38px; display: inline-flex; align-items: center;">Reset</a>
</form>

<!-- Table -->
<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Reg/Roll No</th>
                <th>Name</th>
                <th>Class</th>
                <th>Status</th>
                <th>Fees Override</th>
                <th>Admission Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (students.length > 0) { %>
                <% students.forEach(s => { %>
                    <tr>
                        <td style="font-weight: 600;"><%= s.reg_no %></td>
                        <td><%= s.name %></td>
                        <td><%= s.class_name || 'Unassigned' %></td>
                        <td>
                            <span class="status-cell <%= s.status === 'active' ? 'status-paid' : 'status-unpaid' %>">
                                <%= s.status.toUpperCase() %>
                            </span>
                        </td>
                        <td>
                            <% if (s.has_concession) { %>
                                <span style="color: #b91c1c; font-weight: 600;">PKR <%= s.custom_monthly_fee %> (Concession)</span>
                            <% } else if (s.custom_monthly_fee !== null) { %>
                                <span>PKR <%= s.custom_monthly_fee %> (Standard)</span>
                            <% } else { %>
                                <span style="color: #64748b; font-style: italic;">Class Default</span>
                            <% } %>
                        </td>
                        <td><%= s.date_of_admission ? new Date(s.date_of_admission).toLocaleDateString() : '-' %></td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                <a href="/students/edit/<%= s.id %>" class="btn-secondary nav-btn">Edit</a>
                                <form action="/students/delete/<%= s.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this student?')">
                                    <button type="submit" class="btn-danger nav-btn">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="7" style="text-align: center; color: #64748b;">No students found.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('partials/footer') %>
