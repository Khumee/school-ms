<%- include('partials/header') %>

<%
    let totalCount = students.length;
    let concessionCount = students.filter(s => s.has_concession).length;
    let standardCount = totalCount - concessionCount;
%>

<div class="section-header">
    <h1 class="section-title"><i class="bi bi-mortarboard-fill"></i> Student Directory</h1>
    <a href="/students/add" class="btn-primary"><i class="bi bi-person-plus-fill"></i> Add New Student</a>
</div>

<!-- KPI Cards -->
<div class="kpi-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 1.5rem;">
    <div class="card kpi-card" style="cursor: pointer;" onclick="filterStudents('all')" id="kpi-all">
        <span class="kpi-icon blue"><i class="bi bi-people-fill"></i></span>
        <span class="kpi-label">Total Students</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= totalCount %></span>
        <span class="kpi-subtitle">Click to view all</span>
    </div>
    <div class="card kpi-card" style="cursor: pointer;" onclick="filterStudents('standard')" id="kpi-standard">
        <span class="kpi-icon green"><i class="bi bi-dash-circle"></i></span>
        <span class="kpi-label">Standard Rate</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= standardCount %></span>
        <span class="kpi-subtitle">Click to view standard only</span>
    </div>
    <div class="card kpi-card" style="cursor: pointer;" onclick="filterStudents('concession')" id="kpi-concession">
        <span class="kpi-icon red"><i class="bi bi-tags-fill"></i></span>
        <span class="kpi-label">Concessions</span>
        <span class="kpi-value" style="font-size: 1.4rem;"><%= concessionCount %></span>
        <span class="kpi-subtitle">Click to view concessions only</span>
    </div>
</div>

<!-- Filters Collapsible Panel -->
<details class="filter-panel" <%= (classId || search) ? 'open' : '' %>>
    <summary>
        <span><i class="bi bi-funnel-fill"></i> Filter & Search Students <%= (classId || search) ? '(Active)' : '' %></span>
        <i class="bi bi-chevron-down toggle-icon"></i>
    </summary>
    <form action="/students" method="GET" class="filter-content">
        <div class="form-group">
            <label for="classId">Class</label>
            <select name="classId" id="classId" class="form-control" onchange="this.form.submit()">
                <option value="">-- All Classes --</option>
                <% classes.forEach(c => { %>
                    <option value="<%= c.id %>" <%= classId == c.id ? 'selected' : '' %>><%= c.name %></option>
                <% }) %>
            </select>
        </div>
        
        <div class="form-group">
            <label for="search">Search</label>
            <input type="text" name="search" id="search" class="form-control" value="<%= search || '' %>" placeholder="Search by name or Reg No...">
        </div>
        
        <div style="display: flex; gap: 0.5rem; align-items: flex-end;">
            <button type="submit" class="btn-secondary" style="height: 38px;">Search</button>
            <a href="/students" class="btn-secondary" style="height: 38px; display: inline-flex; align-items: center;">Reset</a>
        </div>
    </form>
</details>

<!-- Table -->
<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Reg/Roll No</th>
                <th>Name</th>
                <th>Class</th>
                <th>Status</th>
                <th>Concession Amount</th>
                <th>Monthly Tuition Fee</th>
                <th>Admission Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (students.length > 0) { %>
                <% students.forEach(s => { %>
                    <tr class="student-row" data-has-concession="<%= s.has_concession ? 'true' : 'false' %>">
                        <td style="font-weight: 600;"><%= s.reg_no %></td>
                        <td><a href="/students/view/<%= s.id %>" style="color: var(--primary-color); text-decoration: underline; font-weight: 600;"><%= s.name %></a></td>
                        <td><%= s.class_name || 'Unassigned' %></td>
                        <td>
                            <span class="status-cell <%= s.status === 'active' ? 'status-paid' : 'status-unpaid' %>">
                                <%= s.status.toUpperCase() %>
                            </span>
                        </td>
                        <td>
                            <% if (s.is_hifz_class) { %>
                                <span>-</span>
                            <% } else if (s.has_concession) { %>
                                <span style="color: #b91c1c; font-weight: 600;">PKR <%= parseFloat(s.custom_monthly_fee || 0).toLocaleString() %></span>
                            <% } else { %>
                                <span>-</span>
                            <% } %>
                        </td>
                        <td>
                            <% if (s.is_hifz_class) { %>
                                <span style="color: #16a34a; font-weight: 600;">PKR 0 (Hifz)</span>
                            <% } else if (s.has_concession) { %>
                                <span style="font-weight: 600;">
                                    PKR <%= (parseFloat(s.default_monthly_fee || 0) - parseFloat(s.custom_monthly_fee || 0)).toLocaleString() %>
                                </span>
                            <% } else { %>
                                <span>PKR <%= parseFloat(s.default_monthly_fee || 0).toLocaleString() %></span>
                            <% } %>
                        </td>
                        <td><%= s.date_of_admission ? new Date(s.date_of_admission).toLocaleDateString() : '-' %></td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                <a href="/students/edit/<%= s.id %>" class="btn-secondary nav-btn"><i class="bi bi-pencil-square"></i> Edit</a>
                                <form action="/students/delete/<%= s.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this student?')">
                                    <button type="submit" class="btn-danger nav-btn"><i class="bi bi-trash3-fill"></i> Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="8" style="text-align: center; color: #64748b;">No students found.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<script>
    function filterStudents(type) {
        const rows = document.querySelectorAll('.student-row');
        rows.forEach(row => {
            const hasConcession = row.getAttribute('data-has-concession') === 'true';
            if (type === 'all') {
                row.style.display = '';
            } else if (type === 'standard') {
                row.style.display = hasConcession ? 'none' : '';
            } else if (type === 'concession') {
                row.style.display = hasConcession ? '' : 'none';
            }
        });
        
        // Add visual active state to cards
        document.getElementById('kpi-all').style.border = type === 'all' ? '2px solid var(--primary-color)' : '';
        document.getElementById('kpi-standard').style.border = type === 'standard' ? '2px solid var(--primary-color)' : '';
        document.getElementById('kpi-concession').style.border = type === 'concession' ? '2px solid var(--primary-color)' : '';
    }
</script>

<%- include('partials/footer') %>
